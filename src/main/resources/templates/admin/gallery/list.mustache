{{> layout/admin-header}}
<div class="p-4 p-lg-5">
    <!-- Page Title -->
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="display-6 fw-black text-dark mb-1">포토갤러리 관리</h2>
            <p class="text-secondary fw-medium m-0">캠핑장 주요 현장 사진을 관리하고 구성합니다.</p>
        </div>
        <button onclick="location.href='/admin/galleries/save-form'" class="btn btn-primary px-4 py-2.5 fw-bold d-flex align-items-center gap-2 shadow-lg rounded-3 border-0">
            <span class="material-symbols-outlined fs-5">add</span>
            <span>새 게시글 작성</span>
        </button>
    </div>

    <!-- Table Card -->
    <div class="fh-card shadow-sm border-primary border-opacity-10 overflow-hidden bg-white mb-4">
        <div class="table-responsive">
            <table class="fh-table m-0">
                <thead class="bg-light">
                    <tr>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider px-4">썸네일</th>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider px-4">제목</th>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider px-4">카테고리</th>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider px-4">등록일</th>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider text-center px-4">조회수</th>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider text-end px-4">관리</th>
                    </tr>
                </thead>
                <tbody>
                    {{#galleries.content}}
                    <tr>
                        <td class="px-4">
                            <div class="thumbnail-box shadow-sm rounded-3 overflow-hidden" style="width: 80px; height: 60px;">
                                <img src="{{thumbnailPath}}" alt="Thumbnail" class="w-100 h-100 object-fit-cover">
                            </div>
                        </td>
                        <td class="px-4">
                            <div class="fw-bold text-dark mb-0">{{title}}</div>
                            <div class="text-secondary text-xs">촬영일: {{shootingDate}}</div>
                        </td>
                        <td class="px-4"><span class="badge bg-primary bg-opacity-10 text-primary fw-bold px-2.5 py-1 rounded-pill text-xs">{{category}}</span></td>
                        <td class="px-4 text-secondary small">{{getCreatedAt}}</td>
                        <td class="px-4 text-center fw-medium">{{viewCount}}</td>
                        <td class="px-4 text-end">
                            <div class="d-flex justify-content-end gap-1">
                                <a href="/admin/galleries/{{id}}/update-form" class="btn btn-icon btn-sm hover-primary bg-light rounded-2">
                                    <span class="material-symbols-outlined fs-5">edit</span>
                                </a>
                                <form action="/admin/galleries/{{id}}/delete" method="POST" onsubmit="return confirm('정말 삭제하시겠습니까?');" style="display: inline;">
                                    <button type="submit" class="btn btn-icon btn-sm hover-danger bg-light rounded-2 border-0">
                                        <span class="material-symbols-outlined fs-5 text-danger opacity-75">delete</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {{/galleries.content}}
                    {{^galleries.content}}
                    <tr>
                        <td colspan="6" class="text-center py-5 text-secondary fw-medium">등록된 포토갤러리 게시글이 없습니다.</td>
                    </tr>
                    {{/galleries.content}}
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="px-4 py-3 bg-light bg-opacity-50 d-flex justify-content-between align-items-center border-top">
            <div class="text-secondary small">총 {{galleries.totalElements}}개 항목</div>
            <nav>
                <ul class="pagination pagination-sm m-0 gap-1">
                    {{#galleries.hasPrevious}}
                    <li class="page-item">
                        <a class="page-link border-0 rounded-2 text-dark fw-bold bg-white shadow-sm d-flex align-items-center justify-content-center" href="?page={{galleries.previousPage}}" style="width: 32px; height: 32px;">
                            <span class="material-symbols-outlined fs-6">chevron_left</span>
                        </a>
                    </li>
                    {{/galleries.hasPrevious}}
                    {{^galleries.hasPrevious}}
                    <li class="page-item disabled">
                        <a class="page-link border-0 rounded-2 text-secondary bg-white opacity-50 d-flex align-items-center justify-content-center" href="#" style="width: 32px; height: 32px;">
                            <span class="material-symbols-outlined fs-6">chevron_left</span>
                        </a>
                    </li>
                    {{/galleries.hasPrevious}}
                    
                    {{#galleries.pageNumbers}}
                    <li class="page-item {{#active}}active{{/active}}">
                        <a class="page-link border-0 rounded-2 {{#active}}bg-primary text-white{{/active}}{{^active}}bg-white text-dark{{/active}} fw-bold shadow-sm d-flex align-items-center justify-content-center" href="?page={{pageIndex}}" style="width: 32px; height: 32px;">{{number}}</a>
                    </li>
                    {{/galleries.pageNumbers}}
                    
                    {{#galleries.hasNext}}
                    <li class="page-item">
                        <a class="page-link border-0 rounded-2 text-dark fw-bold bg-white shadow-sm d-flex align-items-center justify-content-center" href="?page={{galleries.nextPage}}" style="width: 32px; height: 32px;">
                            <span class="material-symbols-outlined fs-6">chevron_right</span>
                        </a>
                    </li>
                    {{/galleries.hasNext}}
                    {{^galleries.hasNext}}
                    <li class="page-item disabled">
                        <a class="page-link border-0 rounded-2 text-secondary bg-white opacity-50 d-flex align-items-center justify-content-center" href="#" style="width: 32px; height: 32px;">
                            <span class="material-symbols-outlined fs-6">chevron_right</span>
                        </a>
                    </li>
                    {{/galleries.hasNext}}
                </ul>
            </nav>
        </div>
    </div>
</div>
{{> layout/admin-footer}}
