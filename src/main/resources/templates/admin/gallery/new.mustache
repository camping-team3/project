{{> layout/admin-header}}
<div class="p-4 p-lg-5">
    <div class="max-w-4xl mx-auto">
        <div class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <h2 class="display-6 fw-bold text-dark mb-2">새 갤러리 게시글 작성</h2>
                <p class="text-secondary fw-medium mb-0">캠핑장의 생생한 현장 소식을 사진과 함께 공유하세요.</p>
            </div>
            <div class="d-flex gap-2">
                <button onclick="history.back()" class="btn btn-light px-4 py-2.5 fw-bold text-secondary border border-secondary border-opacity-10 bg-white rounded-3">취소</button>
                <button class="btn btn-primary px-4 py-2.5 fw-bold shadow-md border-0 rounded-3">게시하기</button>
            </div>
        </div>

        <div class="fh-card shadow-sm border-0 p-4 p-md-5 bg-white rounded-4">
            <div class="mb-4">
                <label class="form-label small fw-bold text-dark">제목</label>
                <input type="text" class="form-control py-3 shadow-none border-secondary border-opacity-25 bg-light bg-opacity-50 rounded-3" placeholder="포스트의 제목을 입력하세요 (예: 2024년 봄맞이 불멍 축제)">
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <label class="form-label small fw-bold text-dark">이벤트/카테고리</label>
                    <select class="form-select py-3 shadow-none border-secondary border-opacity-25 bg-light bg-opacity-50 rounded-3">
                        <option value="">카테고리 선택</option>
                        <option value="event">특별 이벤트</option>
                        <option value="view">캠핑장 전경</option>
                        <option value="food">캠핑 요리</option>
                        <option value="review">방문객 후기</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-bold text-dark">촬영 날짜</label>
                    <input type="date" class="form-control py-3 shadow-none border-secondary border-opacity-25 bg-light bg-opacity-50 rounded-3">
                </div>
            </div>

            <div class="mb-5">
                <label class="form-label small fw-bold text-dark mb-3">이미지 업로드</label>
                <div class="gallery-upload-zone shadow-sm mb-4 rounded-4">
                    <div class="mx-auto bg-white rounded-circle shadow-sm d-flex align-items-center justify-content-center mb-3 preview-img-box-large">
                        <span class="material-symbols-outlined text-primary fs-2">cloud_upload</span>
                    </div>
                    <h3 class="h6 fw-bold text-dark mb-1">클릭하거나 사진을 드래그하세요</h3>
                    <p class="text-secondary text-xxs">최대 20MB 이하의 고화질 JPG, PNG 파일 (권장: 1920x1080px)</p>
                </div>

                <div class="d-flex align-items-center gap-2 mb-3">
                    <span class="material-symbols-outlined text-primary fs-5">visibility</span>
                    <h4 class="small fw-bold text-dark m-0">업로드 예정 이미지</h4>
                </div>
                <div class="preview-grid">
                    <div class="preview-item shadow-sm">
                        <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuCHk4pRegiHDCZBU3Dx7Bquw34mEsN6VCqwW5NgyFYcNetCYu6_HrG4oOSji5rWZAWKVzyj9hcMpBGbccQ9hrsA4X9BX0rNwwuuv1DIzkzB9zGqS2Cr3RkJbuB-wb7dV98W016W8ep5HSEgQebmbenKYX59I3unrN0I4g_G7k-xuJAcEPVB3cIbvciwHKUiuYzKqeug7z7MkktmICCGeHEmXleWH6YANjwMBEUepNeZjNhjtD1IARUB2b9WJJw5RMnPFQoSb4QKT2b8" alt="Preview">
                        <button class="remove-preview-btn shadow-sm">×</button>
                    </div>
                    <div class="preview-item shadow-sm">
                        <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAjxwyrF_GK3S5KA8BkCjNWaV8g1pscId3aShqCabFkZxSfsYlbT58aeBPnpjHR2yAzdxorG4mLeV-WVCX7X_DaO5S28db7dnS5zwvP0bgVH0o_j7P63A7sWeiusvExIxilVbLCpT_9wc-PjtlJv95_DabfiACqLj_X6KwLSP85t6wjbN4wxnTleNftBY90FrDT1TomtD8oN09VUBlTEruWXIds2OO5JSPROfEqf8yvzAW-whygJYt0DJndZ3Rr5VNXd8yASXLeXmGD" alt="Preview">
                        <button class="remove-preview-btn shadow-sm">×</button>
                    </div>
                    <div class="preview-item border-dashed d-flex align-items-center justify-content-center bg-light opacity-50">
                        <span class="material-symbols-outlined text-secondary fs-2">add_photo_alternate</span>
                    </div>
                    <div class="preview-item border-dashed d-flex align-items-center justify-content-center bg-light opacity-50">
                        <span class="material-symbols-outlined text-secondary fs-2">add_photo_alternate</span>
                    </div>
                </div>
            </div>

            <div class="mb-0">
                <label class="form-label small fw-bold text-dark mb-2">상세 설명</label>
                <div class="fh-editor-container">
                    <div class="fh-editor-toolbar bg-light bg-opacity-50">
                        <button class="btn btn-icon btn-sm"><span class="material-symbols-outlined fs-6">format_bold</span></button>
                        <button class="btn btn-icon btn-sm"><span class="material-symbols-outlined fs-6">format_italic</span></button>
                        <button class="btn btn-icon btn-sm"><span class="material-symbols-outlined fs-6">format_list_bulleted</span></button>
                        <button class="btn btn-icon btn-sm"><span class="material-symbols-outlined fs-6">link</span></button>
                    </div>
                    <textarea class="fh-editor-content bg-transparent" rows="8" placeholder="사진에 대한 이야기나 설명을 자유롭게 작성해주세요..."></textarea>
                </div>
            </div>
        </div>

        <footer class="mt-5 text-center">
            <p class="text-secondary opacity-50 text-xxs">© 2024 Camping Jigi. All rights reserved.</p>
        </footer>
    </div>
</div>
{{> layout/admin-footer}}
