{{> layout/admin-header}}

<div class="p-5" style="max-width: 896px; margin: 0 auto;">
    <form id="galleryUpdateForm" action="/admin/galleries/{{gallery.id}}/update" method="POST" enctype="multipart/form-data">
        <!-- Page Title Section -->
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h2 class="display-6 fw-bold text-dark mb-1 tracking-tight">갤러리 게시글 수정</h2>
                <p class="text-secondary small mt-1">기존 포토갤러리 게시글의 내용을 수정합니다.</p>
            </div>
            <div class="d-flex gap-3">
                <button type="button" onclick="history.back()" class="btn btn-light px-4 py-2.5 fw-bold text-secondary border bg-white rounded-3 small">취소</button>
                <button type="button" class="btn btn-primary px-4 py-2.5 fw-bold shadow-md border-0 rounded-3 small btn-gallery-update">수정 완료</button>
            </div>
        </div>

        <div id="deleteInputArea">
            <!-- 삭제할 이미지 ID들이 hidden input으로 여기에 쌓입니다 -->
        </div>

        <div class="space-y-6">
            <!-- Form Card -->
            <div class="form-card shadow-sm p-4 bg-white rounded-4 border border-secondary border-opacity-10">
                <!-- Title & Category -->
                <div class="row g-4 mb-4">
                    <div class="col-md-8">
                        <label class="form-label small fw-bold text-dark mb-2">게시글 제목</label>
                        <input type="text" name="title" class="form-control py-2.5 shadow-none border-secondary border-opacity-25 text-sm" placeholder="제목을 입력해주세요" value="{{gallery.title}}" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-dark mb-2">카테고리</label>
                        <select name="category" id="categorySelect" class="form-select py-2.5 shadow-none border-secondary border-opacity-25 text-sm">
                            <option value="특별 이벤트">특별 이벤트</option>
                            <option value="캠핑장 전경">캠핑장 전경</option>
                            <option value="기타">기타</option>
                        </select>
                    </div>
                </div>

                <!-- Shooting Date -->
                <div class="mb-4">
                    <label class="form-label small fw-bold text-dark mb-2">촬영일</label>
                    <input type="date" name="shootingDate" class="form-control py-2.5 shadow-none border-secondary border-opacity-25 text-sm" value="{{gallery.shootingDate}}" required>
                </div>

                <!-- Content -->
                <div class="mb-4">
                    <label class="form-label small fw-bold text-dark mb-2">게시글 내용</label>
                    <textarea name="content" class="form-control py-2.5 shadow-none border-secondary border-opacity-25 text-sm" rows="5" placeholder="내용을 입력해주세요" required>{{gallery.content}}</textarea>
                </div>

                <!-- File Upload -->
                <div class="mb-0">
                    <label class="form-label small fw-bold text-dark mb-3">첨부 이미지 수정</label>
                    
                    <input type="file" id="imageInput" name="images" multiple accept="image/*" style="display:none">
                    
                    <div id="dropZone" class="file-drop-zone border-dashed p-5 text-center bg-light rounded-4" style="border: 2px dashed #dee2e6; cursor: pointer; transition: all 0.3s ease;">
                        <span class="material-symbols-outlined icon-upload fs-1 text-secondary opacity-50">upload_file</span>
                        <p class="small fw-medium text-dark mb-1 mt-2">이미지 파일을 추가로 드래그하거나 클릭하세요</p>
                    </div>

                    <!-- 프리뷰 그리드 영역 (기존 이미지 + 새로 선택한 이미지) -->
                    <div id="previewGrid" class="d-flex flex-wrap gap-3 mt-3">
                        {{#gallery.images}}
                        <div class="position-relative" style="width: 120px; height: 120px;">
                            <img src="{{filePath}}" class="w-100 h-100 object-fit-cover rounded-3 border shadow-sm">
                            <div class="position-absolute top-0 start-0 bg-primary text-white text-xs px-2 py-0.5 rounded-br-3 small" style="font-size: 10px;">기존</div>
                            <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 p-0 d-flex align-items-center justify-content-center" 
                                    style="width: 24px; height: 24px; border-radius: 50%; transform: translate(30%, -30%); border: 2px solid white;" 
                                    onclick="removeExistingFile(this, {{id}})">×</button>
                        </div>
                        {{/gallery.images}}
                    </div>
                </div>
            </div>

            <!-- Bottom Actions -->
            <div class="d-flex align-items-center justify-content-end gap-3 pt-4">
                <button type="button" onclick="history.back()" class="btn btn-light px-4 py-2.5 rounded-lg border border-secondary border-opacity-10 bg-white small fw-bold text-secondary">취소</button>
                <button type="button" class="btn btn-primary px-4 py-2.5 rounded-lg fw-bold shadow-md border-0 small btn-gallery-update">수정 완료</button>
            </div>
        </div>
    </form>
</div>

<!-- JQuery -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
