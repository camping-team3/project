{{> layout/admin-header}}
<div class="p-4 p-lg-5">
    <!-- Header with Title and Buttons -->
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="display-6 fw-bold text-dark mb-2">예약 변경 요청 상세</h2>
            <p class="text-secondary fw-medium mb-0">고객이 요청한 변경 사항을 기존 예약과 비교하여 승인 또는 거절합니다.</p>
        </div>
        <div class="d-flex gap-2">
            <!-- 목록에서 사용한 디자인과 동일한 승인/거절 버튼 -->
            <button class="btn btn-primary px-4 py-2 fw-bold border-0 shadow-sm">승인</button>
            <button class="btn btn-light bg-danger bg-opacity-10 text-danger px-4 py-2 fw-bold border-0">거절</button>
        </div>
    </div>

    <!-- [Top Section] 기존 예약 정보 -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom-0 py-3">
            <h5 class="card-title m-0 fw-bold text-dark d-flex align-items-center gap-2">
                <span class="material-symbols-outlined text-secondary">event_available</span>
                기존 예약 정보
            </h5>
        </div>
        <div class="card-body">
            <div class="row g-4">
                <div class="col-md-3">
                    <label class="small text-secondary fw-bold">예약자명</label>
                    <p class="fs-5 fw-bold mb-0">{{detail.username}}</p>
                </div>
                <div class="col-md-3">
                    <label class="small text-secondary fw-bold">기존 사이트</label>
                    <p class="fs-5 fw-bold mb-0">{{detail.oldSiteName}}</p>
                </div>
                <div class="col-md-4">
                    <label class="small text-secondary fw-bold">기존 일정</label>
                    <p class="fs-5 fw-bold mb-0 text-dark">{{detail.oldCheckIn}} ~ {{detail.oldCheckOut}} ({{detail.oldNights}}박)</p>
                </div>
                <div class="col-md-2">
                    <label class="small text-secondary fw-bold">인원</label>
                    <p class="fs-5 fw-bold mb-0">{{detail.oldPeopleCount}}명</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Arrow Indicator -->
    <div class="text-center mb-4">
        <span class="material-symbols-outlined fs-1 text-primary bg-primary bg-opacity-10 rounded-circle p-2">south</span>
    </div>

    <!-- [Bottom Section] 변경 요청 정보 -->
    <div class="card border-0 shadow-sm border-2 border-primary border-opacity-25">
        <div class="card-header bg-white border-bottom-0 py-3">
            <h5 class="card-title m-0 fw-bold text-primary d-flex align-items-center gap-2">
                <span class="material-symbols-outlined">edit_notifications</span>
                변경 요청 사항 (승인 대기 중)
            </h5>
        </div>
        <div class="card-body">
            <div class="row g-4">
                <div class="col-md-3">
                    <label class="small text-secondary fw-bold">예약 번호</label>
                    <p class="fs-5 fw-bold mb-0 text-secondary">RSV-{{detail.id}}</p>
                </div>
                <div class="col-md-3">
                    <label class="small text-secondary fw-bold">요청 사이트</label>
                    <p class="fs-5 fw-bold mb-0 text-primary">{{detail.newSiteName}}</p>
                </div>
                <div class="col-md-4">
                    <label class="small text-secondary fw-bold">요청 일정</label>
                    <p class="fs-5 fw-bold mb-0 text-primary">{{detail.newCheckIn}} ~ {{detail.newCheckOut}} ({{detail.newNights}}박)</p>
                </div>
                <div class="col-md-2">
                    <label class="small text-secondary fw-bold">요청 인원</label>
                    <p class="fs-5 fw-bold mb-0 text-primary">{{detail.newPeopleCount}}명</p>
                </div>
            </div>
        </div>
    </div>
</div>
{{> layout/admin-footer}}
