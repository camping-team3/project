<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <form id="rejectForm" method="POST">
                <div class="modal-header border-bottom bg-light p-4">
                    <h5 class="modal-title fw-bold text-dark d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-danger">cancel</span>
                        요청 거절 처리
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="text-secondary small mb-3">사용자에게 전달될 거절 사유를 입력해주세요.</p>
                    <textarea name="rejectionReason" class="form-control border-light bg-light rounded-3 p-3" 
                              rows="4" placeholder="예: 해당 날짜에 사이트 보수 공사가 예정되어 있습니다." required></textarea>
                </div>
                <div class="modal-footer border-top p-4 bg-light bg-opacity-50">
                    <button type="button" class="btn btn-light fw-bold px-4" data-bs-dismiss="modal">취소</button>
                    <button type="submit" class="btn btn-danger fw-bold px-4">거절 확정</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function openRejectModal(id) {
    const form = document.getElementById('rejectForm');
    form.action = `/admin/reservations/${id}/reject`;
    const modal = new bootstrap.Modal(document.getElementById('rejectModal'));
    modal.show();
}
</script>
