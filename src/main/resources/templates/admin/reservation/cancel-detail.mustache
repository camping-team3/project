{{> layout/admin-header}}
<div class="p-4 p-lg-5">
    <!-- Header with Title and Buttons -->
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="display-6 fw-bold text-dark mb-2">예약 취소 요청 상세</h2>
            <p class="text-secondary fw-medium mb-0">고객이 요청한 취소 사유 및 환불 정보를 확인하고 승인 또는 거절합니다.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary px-4 py-2 fw-bold border-0 shadow-sm">승인</button>
            <button class="btn btn-light bg-danger bg-opacity-10 text-danger px-4 py-2 fw-bold border-0">거절</button>
        </div>
    </div>

    <!-- [Top Section] 예약 기본 정보 -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom-0 py-3">
            <h5 class="card-title m-0 fw-bold text-dark d-flex align-items-center gap-2">
                <span class="material-symbols-outlined text-secondary">info</span>
                원본 예약 정보
            </h5>
        </div>
        <div class="card-body">
            <div class="row g-4">
                <div class="col-md-3">
                    <label class="small text-secondary fw-bold">예약자명</label>
                    <p class="fs-5 fw-bold mb-0">{{detail.username}}</p>
                </div>
                <div class="col-md-3">
                    <label class="small text-secondary fw-bold">사이트</label>
                    <p class="fs-5 fw-bold mb-0">{{detail.siteName}}</p>
                </div>
                <div class="col-md-4">
                    <label class="small text-secondary fw-bold">일정</label>
                    <p class="fs-5 fw-bold mb-0 text-dark">{{detail.checkIn}} ~ {{detail.checkOut}} ({{detail.nights}}박)</p>
                </div>
                <div class="col-md-2">
                    <label class="small text-secondary fw-bold">결제금액</label>
                    <p class="fs-5 fw-bold mb-0 text-primary">₩ {{detail.totalPrice}}</p>
                </div>
            </div>
        </div>
    </div>

    <!-- [Bottom Section] 취소 요청 사유 및 환불 정보 -->
    <div class="card border-0 shadow-sm border-2 border-danger border-opacity-25">
        <div class="card-header bg-white border-bottom-0 py-3">
            <h5 class="card-title m-0 fw-bold text-danger d-flex align-items-center gap-2">
                <span class="material-symbols-outlined">cancel</span>
                취소 사유 및 환불 정보
            </h5>
        </div>
        <div class="card-body">
            <div class="mb-4">
                <label class="small text-secondary fw-bold mb-2 d-block">취소 사유</label>
                <div class="p-3 bg-light rounded-3 text-dark fw-medium">
                    {{detail.reason}}
                </div>
            </div>
            <div class="row g-4">
                <div class="col-md-4">
                    <label class="small text-secondary fw-bold">환불 은행</label>
                    <p class="fs-5 fw-bold mb-0">{{detail.refundBank}}</p>
                </div>
                <div class="col-md-4">
                    <label class="small text-secondary fw-bold">계좌번호</label>
                    <p class="fs-5 fw-bold mb-0">{{detail.refundAccount}}</p>
                </div>
                <div class="col-md-4">
                    <label class="small text-secondary fw-bold">예금주</label>
                    <p class="fs-5 fw-bold mb-0">{{detail.refundAccountHolder}}</p>
                </div>
            </div>
        </div>
    </div>
</div>
{{> layout/admin-footer}}
