{{> layout/admin-header}}
<div class="p-4 p-lg-5 content-inner-max">
    <!-- Breadcrumbs & Actions -->
    <div class="mb-5">
        <nav class="d-flex align-items-center gap-2 small text-secondary mb-4">
            <span>예약 관리</span>
            <span class="material-symbols-outlined fs-6 opacity-25">chevron_right</span>
            <span>예약 상세</span>
            <span class="material-symbols-outlined fs-6 opacity-25">chevron_right</span>
            <span class="text-primary fw-bold">#RSV-98234-77</span>
        </nav>
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-4">
            <div class="d-flex align-items-center gap-4">
                <h1 class="display-6 fw-black text-dark m-0">취소 요청 상세 정보</h1>
                <span class="badge bg-danger bg-opacity-10 text-danger fw-bold px-3 py-2 border border-danger border-opacity-25 d-flex align-items-center gap-1 badge-cancel-request">
                    <span class="material-symbols-outlined fs-6">cancel</span> 취소 요청
                </span>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-danger px-4 py-2.5 fw-bold small shadow-lg border-0 d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined fs-5">check_circle</span> 취소 승인 (환불 진행)
                </button>
                <button class="btn btn-light bg-white border border-secondary border-opacity-20 text-secondary px-4 py-2.5 fw-bold small">취소 거절</button>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Left Column -->
        <div class="col-lg-8">
            <!-- Cancellation Summary Card -->
            <div class="fh-card border-0 shadow-sm overflow-hidden mb-4 bg-white">
                <div class="px-4 py-4 border-bottom border-danger border-opacity-10 bg-red-soft">
                    <div class="d-flex align-items-center gap-2 text-red-strong">
                        <span class="material-symbols-outlined fs-4 icon-fill-1">warning</span>
                        <h3 class="h5 fw-bold m-0">취소 사유 및 환불 정보</h3>
                    </div>
                </div>
                <div class="p-4">
                    <div class="mb-4">
                        <p class="text-xs fw-bold text-danger uppercase tracking-wider mb-2">고객 취소 사유</p>
                        <div class="bg-light p-4 rounded-3 border-0">
                            <p class="text-dark small m-0 italic-relaxed opacity-75">
                                "개인적인 사정으로 인해 갑작스러운 일정 변경이 생겼습니다. 캠핑 참여가 어려울 것 같아 취소 요청 드립니다. 다음에 꼭 다시 예약하겠습니다."
                            </p>
                        </div>
                    </div>
                    <div class="row g-4">
                        <div class="col-md-6">
                            <p class="text-xs fw-bold text-danger uppercase tracking-wider mb-3">환불 규정 및 금액</p>
                            <div class="bg-white p-4 rounded-3 border shadow-sm">
                                <div class="d-flex justify-content-between small mb-2 pb-2 border-bottom border-light">
                                    <span class="text-secondary">결제 총액</span>
                                    <span class="fw-bold text-dark">185,000원</span>
                                </div>
                                <div class="d-flex justify-content-between small mb-3">
                                    <span class="text-secondary">취소 정책 적용</span>
                                    <span class="text-primary fw-bold">이용 7일 전 (100% 환불)</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-end pt-2">
                                    <span class="fw-bold text-dark">예상 환불 금액</span>
                                    <span class="h4 fw-black text-danger m-0">185,000원</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="bg-primary bg-opacity-5 rounded-3 p-4 h-100 border border-primary border-opacity-10 d-flex align-items-start gap-3">
                                <span class="material-symbols-outlined text-primary fs-5">info</span>
                                <div>
                                    <p class="text-xs fw-bold text-primary uppercase mb-1">관리자 안내</p>
                                    <p class="text-secondary admin-notice-box">취소 승인 시 PG사를 통해 즉시 환불 처리가 시작되며, 고객님께 안내 문자가 발송됩니다.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Reservation Details Card -->
            <div class="fh-card border-0 shadow-sm p-0 overflow-hidden bg-white">
                <div class="bg-light px-4 py-3 border-bottom">
                    <h3 class="h6 fw-bold text-dark mb-0 d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-primary fs-5">article</span> 예약 상세 내역
                    </h3>
                </div>
                <div class="p-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="text-xs fw-bold text-secondary uppercase tracking-tight mb-1">선택 사이트</label>
                            <p class="h6 fw-bold text-dark m-0">오토캠핑 A-1 구역 (숲속 뷰)</p>
                            <label class="text-xs fw-bold text-secondary uppercase tracking-tight mb-1 mt-4">예약 일정</label>
                            <p class="h6 fw-bold text-dark m-0">2024.06.15 (토) - 2024.06.17 (월) / 2박</p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-xs fw-bold text-secondary uppercase tracking-tight mb-1">인원 정보</label>
                            <p class="h6 fw-bold text-dark m-0">성인 2명, 소인 1명 (총 3명)</p>
                            <label class="text-xs fw-bold text-secondary uppercase tracking-tight mb-1 mt-4">결제 수단</label>
                            <p class="h6 fw-bold text-dark d-flex align-items-center gap-2 m-0">
                                <span class="material-symbols-outlined fs-6 text-primary">credit_card</span>
                                신용카드 (현대 4421-****)
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column -->
        <div class="col-lg-4">
            <!-- Customer Info Card -->
            <div class="fh-card border-0 shadow-sm p-4 mb-4 bg-white">
                <h3 class="h6 fw-bold text-dark mb-4 d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined text-primary fs-5">account_circle</span> 예약 고객 정보
                </h3>
                <div class="d-flex align-items-center gap-4 mb-4 pb-4 border-bottom border-light">
                    <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuDgvaOxC-svqil2c3qpycViz2eXgIuHpjFhBnFsTbpRRAGL4cmOwYuAYKPJ5lF8kOoYfw-9GiVTXFcGsZYKM9Iwxg1JYModWL7B9SkkesmLokRloh90H_F4P1hjBPlCaHKa6sTPHe-5mFoW0MJrRwkax5YWjWgqUQVlq3NRwpB1Oi0Yis7KyxuOB_HLJ_eQrMPsQlTEp5qy6c3uixkuyy4XxqYOCOURUycy5qAYHH2xcu_4nDnBxwd3JTiFG-R7_mUwx8JXzW4gjgIJ" class="rounded-3 shadow-sm customer-avatar-mid" alt="Customer">
                    <div>
                        <p class="h6 fw-bold text-dark m-0">이지은 님</p>
                        <p class="text-primary small fw-bold mb-0">VVIP 회원</p>
                    </div>
                </div>
                <div class="d-flex flex-column gap-3 mb-4">
                    <div class="d-flex justify-content-between small">
                        <span class="text-secondary">연락처</span>
                        <span class="fw-bold text-dark">010-1234-5678</span>
                    </div>
                    <div class="d-flex justify-content-between small">
                        <span class="text-secondary">이메일</span>
                        <span class="fw-bold text-dark">jieun.lee@example.com</span>
                    </div>
                    <div class="d-flex justify-content-between small">
                        <span class="text-secondary">최근 이용</span>
                        <span class="text-primary fw-bold">12일 전 이용</span>
                    </div>
                </div>
                <button class="btn btn-light bg-primary bg-opacity-5 text-primary w-100 fw-bold small border-0 py-2.5">고객 상세 이력 보기</button>
            </div>

            <!-- Timeline Card -->
            <div class="fh-card border-0 shadow-sm p-4 bg-white">
                <h4 class="h6 fw-bold text-dark mb-4 d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined text-primary fs-5">history</span> 예약 타임라인
                </h4>
                <div class="fh-timeline-v2">
                    <div class="timeline-v2-item">
                        <div class="timeline-v2-dot shadow-sm bg-dot-danger timeline-dot-offset">
                            <span class="material-symbols-outlined text-white icon-12">close</span>
                        </div>
                        <p class="text-xs font-bold text-danger mb-0">오늘 14:22</p>
                        <p class="small fw-bold text-dark mb-0">취소 요청 접수</p>
                        <p class="text-secondary text-xs-muted">고객 직접 취소 요청 (Web)</p>
                    </div>
                    <div class="timeline-v2-item">
                        <div class="timeline-v2-dot shadow-sm bg-dot-success timeline-dot-offset">
                            <span class="material-symbols-outlined text-white icon-12">payments</span>
                        </div>
                        <p class="text-xs font-bold text-secondary mb-0">2024.05.20 10:15</p>
                        <p class="small fw-bold text-dark mb-0">결제 완료</p>
                        <p class="text-secondary text-xs-muted">신용카드 일시불 결제 승인</p>
                    </div>
                    <div class="timeline-v2-item mb-0">
                        <div class="timeline-v2-dot shadow-sm bg-dot-primary timeline-dot-offset">
                            <span class="material-symbols-outlined text-white icon-12">add</span>
                        </div>
                        <p class="text-xs font-bold text-secondary mb-0">2024.05.20 10:10</p>
                        <p class="small fw-bold text-dark mb-0">예약 신청</p>
                        <p class="text-secondary text-xs-muted">오토캠핑 A-1 구역 대기 접수</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{{> layout/admin-footer}}
