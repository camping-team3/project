{{> layout/admin-header}}
<div class="p-4 p-lg-5">
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <h2 class="display-6 fw-bold text-dark mb-2">통합 예약 관리</h2>
            <p class="text-secondary fw-medium mb-0">캠핑장의 모든 실시간 예약 내역을 확인하고 처리합니다.</p>
        </div>
        <button class="btn btn-primary px-4 py-2.5 fw-bold d-flex align-items-center gap-2 shadow-sm border-0">
            <span class="material-symbols-outlined fs-5">add</span>
            <span>신규 예약 등록</span>
        </button>
    </div>

    <!-- Filters -->
    <form action="/admin/reservations" method="GET" class="filter-section shadow-sm mb-5 border-0">
        <div class="row g-4">
            <div class="col-md-3">
                <label class="form-label small fw-bold text-secondary text-uppercase tracking-wider">예약자명 / ID</label>
                <input type="text" name="keyword" class="form-control py-2 shadow-none border-secondary border-opacity-25" 
                       placeholder="이름 또는 ID" value="{{#search.keyword}}{{search.keyword}}{{/search.keyword}}">
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold text-secondary text-uppercase tracking-wider">체크인 날짜</label>
                <input type="date" name="checkIn" class="form-control py-2 shadow-none border-secondary border-opacity-25" 
                       value="{{#search.checkIn}}{{search.checkIn}}{{/search.checkIn}}">
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold text-secondary text-uppercase tracking-wider">예약 상태</label>
                <select name="status" id="status-filter" class="form-select py-2 shadow-none border-secondary border-opacity-25">
                    <option value="">전체 상태</option>
                    <option value="PENDING">대기 중 (Pending)</option>
                    <option value="CONFIRMED">확정됨 (Confirmed)</option>
                    <option value="CANCEL_REQ">취소 요청 (Cancel Req)</option>
                    <option value="CANCEL_COMP">취소 완료 (Cancel Comp)</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-light bg-primary bg-opacity-10 text-primary w-100 py-2 fw-bold border-0">필터 적용</button>
            </div>
        </div>
    </form>

    <!-- Table -->
    <div class="fh-table-container shadow-sm border-0 bg-white overflow-hidden">
        <table class="fh-table m-0">
            <thead>
                <tr>
                    <th class="px-4 py-3">예약 ID</th>
                    <th class="px-4 py-3">예약자</th>
                    <th class="px-4 py-3">캠핑 사이트</th>
                    <th class="px-4 py-3">체크인/아웃</th>
                    <th class="px-4 py-3 text-end">결제 금액</th>
                    <th class="px-4 py-3 text-center">상태</th>
                    <th class="px-4 py-3 text-end">관리</th>
                </tr>
            </thead>
            <tbody>
                {{#response.reservations}}
                <tr class="reservation-table-row {{#isPending}}pending{{/isPending}}">
                    <td class="px-4 py-4 font-monospace small text-secondary">{{reservationIdDisplay}}</td>
                    <td class="px-4 py-4 fw-bold text-dark">{{username}}</td>
                    <td class="px-4 py-4 small">{{siteName}}</td>
                    <td class="px-4 py-4 small">
                        <div class="fw-bold">{{checkIn}}</div>
                        <div class="text-secondary stay-duration-text">{{nights}}박 <span class="days-display">{{nights}}</span>일</div>
                    </td>
                    <td class="px-4 py-4 fw-bold text-dark text-end">₩ {{totalPrice}}</td>
                    <td class="px-4 py-4 text-center">
                        <span class="badge bg-{{statusClass}} bg-opacity-10 text-{{statusClass}} fw-bold px-2 py-1 badge-res-status">{{statusText}}</span>
                    </td>
                    <td class="px-4 py-4 text-end">
                        <div class="d-flex justify-content-end gap-2">
                            <button class="btn btn-icon text-primary" onclick="location.href='/admin/reservations/{{id}}'"><span class="material-symbols-outlined fs-5">visibility</span></button>
                            {{#isPending}}
                            <button class="btn btn-primary btn-sm px-3 fw-bold border-0">승인</button>
                            <button class="btn btn-light bg-danger bg-opacity-10 text-danger btn-sm px-3 fw-bold border-0">거절</button>
                            {{/isPending}}
                            {{^isPending}}
                            <button class="btn btn-icon text-secondary" onclick="location.href='/admin/reservations/{{id}}/change'"><span class="material-symbols-outlined fs-5">edit</span></button>
                            <button class="btn btn-icon text-danger"><span class="material-symbols-outlined fs-5">block</span></button>
                            {{/isPending}}
                        </div>
                    </td>
                </tr>
                {{/response.reservations}}
                {{^response.reservations}}
                <tr>
                    <td colspan="7" class="px-4 py-5 text-center text-secondary opacity-50">
                        <span class="material-symbols-outlined fs-1 mb-2">event_busy</span>
                        <p class="m-0">예약 내역이 없습니다.</p>
                    </td>
                </tr>
                {{/response.reservations}}
            </tbody>
        </table>

        <!-- Pagination -->
        <div class="p-4 bg-light bg-opacity-50 d-flex justify-content-between align-items-center border-top">
            {{#response.pagination}}
            <p class="text-secondary small m-0 fw-medium">총 {{totalElements}}건의 내역 ({{totalPages}} 페이지)</p>
            <nav>
                <ul class="pagination pagination-sm m-0 gap-1">
                    <!-- Previous -->
                    <li class="page-item {{^hasPrev}}disabled{{/hasPrev}}">
                        <a class="page-link border-0 rounded-2 bg-transparent text-secondary" 
                           href="?page={{prevPage}}{{#search.keyword}}&keyword={{.}}{{/search.keyword}}{{#search.checkIn}}&checkIn={{.}}{{/search.checkIn}}{{#search.status}}&status={{.}}{{/search.status}}">
                            <span class="material-symbols-outlined fs-6">chevron_left</span>
                        </a>
                    </li>
                    
                    <!-- Numbers -->
                    {{#pageNumbers}}
                    <li class="page-item {{#isCurrent}}active{{/isCurrent}}">
                        <a class="page-link border-0 rounded-2 {{#isCurrent}}bg-primary text-white fw-bold{{/isCurrent}} {{^isCurrent}}text-secondary{{/isCurrent}}" 
                           href="?page={{number}}{{#search.keyword}}&keyword={{.}}{{/search.keyword}}{{#search.checkIn}}&checkIn={{.}}{{/search.checkIn}}{{#search.status}}&status={{.}}{{/search.status}}">
                            {{displayDigit}}
                        </a>
                    </li>
                    {{/pageNumbers}}
                    
                    <!-- Next -->
                    <li class="page-item {{^hasNext}}disabled{{/hasNext}}">
                        <a class="page-link border-0 rounded-2 text-secondary" 
                           href="?page={{nextPage}}{{#search.keyword}}&keyword={{.}}{{/search.keyword}}{{#search.checkIn}}&checkIn={{.}}{{/search.checkIn}}{{#search.status}}&status={{.}}{{/search.status}}">
                            <span class="material-symbols-outlined fs-6">chevron_right</span>
                        </a>
                    </li>
                </ul>
            </nav>
            {{/response.pagination}}
        </div>
    </div>
</div>

<script>
    // 일수 계산
    document.querySelectorAll('.days-display').forEach(el => {
        const nights = parseInt(el.innerText);
        el.innerText = nights + 1;
    });

    // 검색 조건 유지 (Select)
    const currentStatus = "{{#search.status}}{{search.status}}{{/search.status}}";
    if (currentStatus) {
        document.getElementById('status-filter').value = currentStatus;
    }
</script>

{{> layout/admin-footer}}
