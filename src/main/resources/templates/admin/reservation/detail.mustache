{{> layout/admin-header}}

<div class="container-fluid py-4">
    <!-- Header Actions -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center gap-3">
            <button onclick="history.back()" class="btn btn-icon-square bg-white shadow-sm rounded-3">
                <span class="material-symbols-outlined fs-5">arrow_back</span>
            </button>
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item"><a href="/admin/reservations" class="text-decoration-none text-muted small fw-bold">예약 관리</a></li>
                        <li class="breadcrumb-item active small fw-bold" aria-current="page">예약 상세 내역</li>
                    </ol>
                </nav>
                <h2 class="h4 fw-bold text-dark m-0">예약 상세 내역 <span class="text-muted fs-6 fw-normal ms-2">RSV-{{detail.id}}</span></h2>
            </div>
        </div>
        <div class="d-flex gap-2">
            <span class="badge bg-{{detail.statusClass}} bg-opacity-10 text-{{detail.statusClass}} fw-bold px-3 py-2 rounded-3 fs-6 d-flex align-items-center gap-2">
                <span class="material-symbols-outlined fs-5">info</span>
                {{detail.statusText}}
            </span>
        </div>
    </div>

    <!-- Main Content Row -->
    <div class="row g-4">
        
        <!-- [LEFT] Main Column (8/12) -->
        <div class="col-lg-8">

            <!-- 1. 예약 상세 정보 카드 -->
            <div class="fh-card p-4 mb-4 shadow-sm border-start border-4 border-primary">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h3 class="h6 fw-bold m-0 d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-primary">event_note</span>
                        예약 및 사이트 정보
                    </h3>
                </div>
                <div class="row g-4">
                    <div class="col-md-4">
                        <p class="small text-muted mb-1">예약 사이트</p>
                        <p class="fw-bold text-dark mb-0 fs-5">{{detail.siteName}}</p>
                    </div>
                    <div class="col-md-5 border-start border-end px-md-4">
                        <p class="small text-muted mb-1">이용 일정</p>
                        <p class="fw-bold text-dark mb-0 fs-5">{{detail.checkIn}} ~ {{detail.checkOut}}</p>
                        <p class="small text-secondary m-0">{{detail.nights}}박 이용</p>
                    </div>
                    <div class="col-md-3">
                        <p class="small text-muted mb-1">결제 금액 / 인원</p>
                        <p class="fw-bold text-primary mb-0 fs-5">₩ {{detail.totalPrice}}</p>
                        <p class="small text-secondary m-0">{{detail.peopleCount}}명 방문</p>
                    </div>
                </div>
            </div>

            <!-- 2. 요청 통합 이력 카드 -->
            <div class="fh-card p-0 overflow-hidden shadow-sm">
                <div class="p-4 border-bottom bg-light bg-opacity-50">
                    <h3 class="h6 fw-bold m-0 d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-primary">history</span>
                        예약 관련 요청 이력 (변경 및 취소)
                    </h3>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover m-0 small">
                        <thead class="bg-light">
                            <tr>
                                <th class="px-4 py-3 fw-bold text-secondary">요청일자</th>
                                <th class="px-4 py-3 fw-bold text-secondary">유형</th>
                                <th class="px-4 py-3 fw-bold text-secondary">상태</th>
                                <th class="px-4 py-3 fw-bold text-secondary">상세 내용</th>
                                <th class="px-4 py-3 fw-bold text-secondary">거절 사유</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#detail.changeRequests}}
                            <tr>
                                <td class="px-4 py-3 text-muted">{{requestDate}}</td>
                                <td class="px-4 py-3"><span class="badge bg-info bg-opacity-10 text-info fw-bold">변경</span></td>
                                <td class="px-4 py-3 fw-bold text-dark">{{statusDescription}}</td>
                                <td class="px-4 py-3 text-muted">{{newSiteName}} ({{newCheckIn}}~{{newCheckOut}})</td>
                                <td class="px-4 py-3 text-danger fw-bold">{{rejectionReason}}</td>
                            </tr>
                            {{/detail.changeRequests}}
                            {{#detail.cancelRequests}}
                            <tr>
                                <td class="px-4 py-3 text-muted">{{requestDate}}</td>
                                <td class="px-4 py-3"><span class="badge bg-danger bg-opacity-10 text-danger fw-bold">취소</span></td>
                                <td class="px-4 py-3 fw-bold text-dark">{{statusDescription}}</td>
                                <td class="px-4 py-3 text-muted">사유: {{reason}}</td>
                                <td class="px-4 py-3 text-danger fw-bold">{{rejectionReason}}</td>
                            </tr>
                            {{/detail.cancelRequests}}
                            {{^detail.changeRequests}}
                            {{^detail.cancelRequests}}
                            <tr>
                                <td colspan="5" class="px-4 py-5 text-center text-muted">과거 요청 이력이 없습니다.</td>
                            </tr>
                            {{/detail.cancelRequests}}
                            {{/detail.changeRequests}}
                        </tbody>
                    </table>
                </div>
            </div>

        </div> <!-- [LEFT] col-lg-8 END -->

        <!-- [RIGHT] Sidebar Column (4/12) -->
        <div class="col-lg-4">

            <!-- 3. 예약자 및 방문자 정보 카드 -->
            <div class="fh-card p-4 mb-4 shadow-sm">
                <h3 class="h6 fw-bold mb-4 d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined text-primary">person</span>
                    예약자 및 방문자 정보
                </h3>
                <div class="d-flex align-items-center gap-3 mb-4 p-3 bg-light rounded-3">
                    <div class="bg-white rounded-circle shadow-sm d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                        <span class="material-symbols-outlined text-primary fs-3">account_circle</span>
                    </div>
                    <div>
                        <p class="fw-bold text-dark m-0">{{detail.username}}</p>
                        <p class="small text-secondary m-0">{{detail.userRole}}</p>
                    </div>
                </div>
                <div class="d-flex flex-column gap-3">
                    <div class="d-flex justify-content-between">
                        <span class="small text-muted">방문자 성함</span>
                        <span class="small fw-bold">{{detail.visitorName}}</span>
                    </div>
                    <div class="d-flex justify-content-between border-top pt-2">
                        <span class="small text-muted">비상 연락처</span>
                        <span class="small fw-bold">{{detail.visitorPhone}}</span>
                    </div>
                </div>
                <button onclick="location.href='/admin/users/{{detail.userId}}'" class="btn btn-outline-primary btn-sm w-100 mt-4 fw-bold rounded-2">사용자 상세 정보 보기</button>
            </div>

            <!-- 4. 관리자 메모 카드 -->
            <div class="fh-card p-4 shadow-sm">
                <h3 class="h6 fw-bold mb-3 d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined text-primary">edit_note</span>
                    관리자 메모
                </h3>
                <textarea class="form-control bg-light border-0 small mb-3" rows="4" placeholder="특이사항을 기록하세요..."></textarea>
                <button class="btn btn-primary btn-sm w-100 fw-bold rounded-2 py-2">메모 저장하기</button>
            </div>

        </div> <!-- [RIGHT] col-lg-4 END -->

    </div> <!-- Main Content Row END -->
</div> <!-- container-fluid END -->

{{> layout/admin-footer}}
