{{> layout/admin-header}}

<div class="container-fluid py-4">
    <!-- Header Actions -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center gap-3">
            <button onclick="location.href='/admin/reservations'" class="btn btn-icon-square bg-white shadow-sm rounded-3">
                <span class="material-symbols-outlined fs-5">arrow_back</span>
            </button>
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item"><a href="/admin/reservations" class="text-decoration-none text-muted small fw-bold">예약 관리</a></li>
                        <li class="breadcrumb-item active small fw-bold" aria-current="page">예약 상세</li>
                    </ol>
                </nav>
                <h2 class="h4 fw-bold text-dark m-0">예약 상세 내역 <span class="text-muted fs-6 fw-normal ms-2">RSV-20231024-001</span></h2>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-white fw-bold shadow-sm d-flex align-items-center gap-2 border-0 rounded-3 px-3 py-2">
                <span class="material-symbols-outlined fs-5">print</span>
                내역 출력
            </button>
            <button class="btn btn-primary fw-bold shadow-sm d-flex align-items-center gap-2 border-0 rounded-3 px-3 py-2">
                <span class="material-symbols-outlined fs-5">check_circle</span>
                예약 승인
            </button>
        </div>
    </div>

    <div class="row g-4">
        <!-- Left Column: Core Info -->
        <div class="col-lg-8">
            <!-- Reservation Info Card -->
            <div class="fh-card p-4 mb-4 shadow-sm">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h3 class="h6 fw-bold m-0 d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-primary">info</span>
                        핵심 예약 정보
                    </h3>
                    <span class="badge bg-success bg-opacity-10 text-success fw-bold px-3 py-2 rounded-pill">확정됨</span>
                </div>
                <div class="row g-4">
                    <div class="col-md-4">
                        <p class="small text-muted mb-1">예약 사이트</p>
                        <p class="fw-bold text-dark mb-0 fs-5">오크우드 03</p>
                        <p class="small text-secondary m-0">프리미엄 숲속 텐트 구역</p>
                    </div>
                    <div class="col-md-4 border-start border-end px-md-4">
                        <p class="small text-muted mb-1">이용 인원</p>
                        <p class="fw-bold text-dark mb-0 fs-5">총 3명</p>
                        <p class="small text-secondary m-0">성인 2, 아동 1</p>
                    </div>
                    <div class="col-md-4">
                        <p class="small text-muted mb-1">총 결제 금액</p>
                        <p class="fw-bold text-primary mb-0 fs-4">₩ 250,000</p>
                        <p class="small text-secondary m-0">신용카드 결제 완료</p>
                    </div>
                </div>
            </div>

            <!-- Schedule Info Card -->
            <div class="fh-card p-4 mb-4 shadow-sm">
                <h3 class="h6 fw-bold mb-4 d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined text-primary">calendar_month</span>
                    이용 일정 상세
                </h3>
                <div class="row g-3">
                    <div class="col-md-5">
                        <div class="p-3 bg-light rounded-3 text-center">
                            <p class="small text-muted mb-1">체크인 (Check-in)</p>
                            <p class="h5 fw-bold text-dark mb-0">2023.11.10 (금)</p>
                            <p class="small text-secondary mb-0 mt-1">14:00 이후</p>
                        </div>
                    </div>
                    <div class="col-md-2 d-flex align-items-center justify-content-center py-2">
                        <div class="text-center">
                            <span class="material-symbols-outlined fs-2 text-muted">arrow_forward</span>
                            <div class="small fw-bold text-primary">2박</div>
                        </div>
                    </div>
                    <div class="col-md-5">
                        <div class="p-3 bg-light rounded-3 text-center border-start border-4 border-primary">
                            <p class="small text-muted mb-1">체크아웃 (Check-out)</p>
                            <p class="h5 fw-bold text-dark mb-0">2023.11.12 (일)</p>
                            <p class="small text-secondary mb-0 mt-1">11:00 이전</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Detailed Table -->
            <div class="fh-card p-0 overflow-hidden shadow-sm">
                <div class="p-4 border-bottom">
                    <h3 class="h6 fw-bold m-0 d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-primary">receipt_long</span>
                        요금 산출 내역
                    </h3>
                </div>
                <table class="table table-hover m-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="px-4 py-3 small fw-bold text-secondary">항목</th>
                            <th class="px-4 py-3 small fw-bold text-secondary text-end">단가</th>
                            <th class="px-4 py-3 small fw-bold text-secondary text-center">수량</th>
                            <th class="px-4 py-3 small fw-bold text-secondary text-end">합계</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="px-4 py-3 fw-bold">기본 숙박 요금 (주말)</td>
                            <td class="px-4 py-3 text-end">90,000원</td>
                            <td class="px-4 py-3 text-center">2박</td>
                            <td class="px-4 py-3 text-end fw-bold">180,000원</td>
                        </tr>
                        <tr>
                            <td class="px-4 py-3 fw-bold">추가 인원 요금 (아동)</td>
                            <td class="px-4 py-3 text-end">10,000원</td>
                            <td class="px-4 py-3 text-center">2박 / 1명</td>
                            <td class="px-4 py-3 text-end fw-bold">20,000원</td>
                        </tr>
                        <tr class="bg-primary bg-opacity-5">
                            <td colspan="3" class="px-4 py-3 text-end fw-bold">총 합계</td>
                            <td class="px-4 py-3 text-end h5 fw-bold text-primary mb-0">200,000원</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Right Column: Sidebar Info -->
        <div class="col-lg-4">
            <!-- Customer Card -->
            <div class="fh-card p-4 mb-4 shadow-sm">
                <h3 class="h6 fw-bold mb-4 d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined text-primary">person</span>
                    예약자 및 방문자 정보
                </h3>
                <div class="d-flex align-items-center gap-3 mb-4 p-3 bg-light rounded-3">
                    <div class="bg-white rounded-circle shadow-sm d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                        <span class="material-symbols-outlined text-primary fs-3">account_circle</span>
                    </div>
                    <div>
                        <p class="fw-bold text-dark m-0">김철수 (xogurrh012)</p>
                        <p class="small text-secondary m-0">최근 예약 3회 (단골 고객)</p>
                    </div>
                </div>
                <div class="d-flex flex-column gap-3">
                    <div class="d-flex justify-content-between">
                        <span class="small text-muted">방문자 성함</span>
                        <span class="small fw-bold">김철수</span>
                    </div>
                    <div class="d-flex justify-content-between border-top pt-2">
                        <span class="small text-muted">비상 연락처</span>
                        <span class="small fw-bold">010-1234-5678</span>
                    </div>
                </div>
                <button class="btn btn-outline-primary btn-sm w-100 mt-4 fw-bold rounded-2">사용자 상세 정보 보기</button>
            </div>

            <!-- Admin Note Card -->
            <div class="fh-card p-4 shadow-sm">
                <h3 class="h6 fw-bold mb-3 d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined text-primary">edit_note</span>
                    관리자 메모
                </h3>
                <textarea class="form-control bg-light border-0 small mb-3" rows="4" placeholder="예약 특이사항이나 얼리 체크인 요청 등을 기록하세요..."></textarea>
                <button class="btn btn-primary btn-sm w-100 fw-bold rounded-2 py-2">메모 저장하기</button>
            </div>
        </div>
    </div>
</div>

{{> layout/admin-footer}}
