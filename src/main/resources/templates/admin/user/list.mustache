{{> layout/admin-header}}
<div class="p-4 p-lg-5">
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <h2 class="display-6 fw-black text-dark mb-1">사용자 목록</h2>
            <p class="text-secondary fw-medium mb-0">등록된 모든 사용자의 정보를 관리하고 상태를 제어할 수 있습니다.</p>
        </div>
        <button class="btn btn-primary px-4 py-2.5 fw-bold d-flex align-items-center gap-2 shadow-sm border-0">
            <span class="material-symbols-outlined fs-5">person_add</span>
            <span>사용자 추가</span>
        </button>
    </div>

    <!-- Table Content -->
    <div class="fh-table-container shadow-sm border-0 overflow-hidden bg-white">
        <table class="fh-table m-0">
            <thead>
                <tr>
                    <th class="px-4 py-3">ID</th>
                    <th class="px-4 py-3">이름</th>
                    <th class="px-4 py-3">이메일</th>
                    <th class="px-4 py-3">전화번호</th>
                    <th class="px-4 py-3 text-center">총 예약</th>
                    <th class="px-4 py-3">단골 등급</th>
                    <th class="px-4 py-3">상태</th>
                    <th class="px-4 py-3 text-end">관리</th>
                </tr>
            </thead>
            <tbody>
                {{#userPage.content}}
                <tr onclick="location.href='/admin/users/{{id}}'" class="cursor-pointer">
                    <td class="px-4 py-4 text-secondary small fw-bold">USR-{{id}}</td>
                    <td class="px-4 py-4 fw-bold text-dark">{{name}} ({{username}})</td>
                    <td class="px-4 py-4 small">{{email}}</td>
                    <td class="px-4 py-4 small">{{phone}}</td>
                    <td class="px-4 py-4 text-center fw-bold">-</td>
                    <td class="px-4 py-4"><span class="tier-badge tier-silver">{{role}}</span></td>
                    <td class="px-4 py-4"><span class="text-success small fw-bold d-flex align-items-center"><span class="status-dot status-active"></span>{{status}}</span></td>
                    <td class="px-4 py-4 text-end">
                        <div class="d-flex justify-content-end gap-2">
                            <button class="btn btn-sm btn-light p-1.5 border-0"><span class="material-symbols-outlined fs-5">edit</span></button>
                        </div>
                    </td>
                </tr>
                {{/userPage.content}}
            </tbody>
        </table>

        <!-- Pagination -->
        <div class="p-4 bg-light bg-opacity-50 d-flex justify-content-between align-items-center border-top">
            <p class="text-secondary small m-0 fw-medium">전체 회원 수: {{userPage.totalElements}}명</p>
            <nav>
                <ul class="pagination pagination-sm m-0 gap-1">
                    <li class="page-item {{#userPage.first}}disabled{{/userPage.first}}">
                        <a class="page-link border-0 rounded-2 text-secondary bg-transparent" href="?page={{userPage.number}}&page={{#userPage.number}}-1{{/userPage.number}}">
                            <span class="material-symbols-outlined fs-6">chevron_left</span>
                        </a>
                    </li>
                    <li class="page-item active"><a class="page-link border-0 rounded-2 bg-primary text-white fw-bold" href="#">{{userPage.number}}</a></li>
                    <li class="page-item {{#userPage.last}}disabled{{/userPage.last}}">
                        <a class="page-link border-0 rounded-2 text-secondary bg-transparent" href="?page={{userPage.number}}&page={{#userPage.number}}+1{{/userPage.number}}">
                            <span class="material-symbols-outlined fs-6">chevron_right</span>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>
{{> layout/admin-footer}}
