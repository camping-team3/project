{{> layout/admin-header}}
<div class="p-4 p-lg-5" style="max-width: 1280px; margin: 0 auto;">
    <!-- User Overview Card -->
    <div class="fh-card p-4 p-lg-5 mb-5 border-0 shadow-sm bg-white overflow-hidden position-relative">
        <div class="position-absolute top-0 end-0 p-4">
            <span class="badge bg-primary bg-opacity-10 text-primary fw-bold px-3 py-2 rounded-pill">활성 계정</span>
        </div>

        <div class="d-flex flex-column flex-lg-row align-items-center align-items-lg-start gap-5">
            <div class="position-relative">
                <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuBjLWnR5btJ7Vzl2F04dSFUDs6e0IKd58PvnxI3ZZGgasEy7loQLOdAO-NWWF9_ZbE9BA2KUDbK7XrCjW1nRsYyGnoW5JXLZ8m3RjezY92d5L6z-kuLYZJWjm4G1dXXDVOI3Neb0fKHeUauozDKtXdTWcS_5k_faLEyWd2-0tWT69kVhjz6yDDZcLnl1ii3Bj4_8nnbmQrwyYCBeSyHOrqt8BXhN2Fo5TdnYBQ7NKYrtp2pST2OxuZMhYP70qvBMTp2oeAJ9CtzrPV0" class="customer-profile-img shadow-lg" alt="User">
                <button class="btn btn-primary btn-sm rounded-circle position-absolute bottom-0 end-0 p-2 shadow-lg border-2 border-white">
                    <span class="material-symbols-outlined fs-6">edit</span>
                </button>
            </div>

            <div class="flex-grow-1 text-center text-lg-start">
                <div class="mb-4">
                    <h2 class="display-6 fw-black text-dark mb-1">{{user.name}}</h2>
                    <p class="text-secondary fw-medium m-0">{{user.email}} ({{user.username}})</p>
                </div>

                <div class="row g-4 justify-content-center justify-content-lg-start">
                    <div class="col-auto">
                        <div class="d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined text-primary fs-5">calendar_today</span>
                            <div class="text-start">
                                <p class="text-xxs fw-bold text-secondary text-uppercase tracking-wider m-0">아이디</p>
                                <p class="small fw-bold text-dark m-0">{{user.username}}</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-auto px-lg-4 border-lg-start border-lg-end">
                        <div class="d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined text-primary fs-5">badge</span>
                            <div class="text-start">
                                <p class="text-xxs fw-bold text-secondary text-uppercase tracking-wider m-0">현재 권한</p>
                                <p class="small fw-bold text-dark m-0">{{user.role}}</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-column gap-2 w-100 w-lg-auto">
                <form action="/admin/users/{{user.id}}/update-role" method="post" class="d-flex flex-column gap-2">
                    <select name="role" class="form-select fw-bold shadow-sm">
                        <option value="USER">일반 사용자(USER)</option>
                        <option value="ADMIN">관리자(ADMIN)</option>
                    </select>
                    <button type="submit" class="btn btn-primary px-4 py-2.5 fw-bold rounded-3 shadow-sm border-0">권한 변경 적용</button>
                </form>
            </div>
        </div>
    </div>

    <!-- Detail Content -->
    <div class="row g-5">
        <div class="col-lg-8">
            <!-- Tabs -->
            <div class="detail-tab-nav mb-5 px-2">
                <div class="detail-tab-item active">최근 예약 내역</div>
            </div>

            <!-- Reservation Table -->
            <div class="fh-card border-0 shadow-sm bg-white overflow-hidden mb-5 p-5 text-center text-secondary">
                준비 중인 기능입니다 (예약 연동 예정)
            </div>
        </div>

        <div class="col-lg-4">
            <h3 class="h6 fw-bold text-dark mb-4">계정 추가 정보</h3>
            <div class="d-flex flex-column gap-3">
                <div class="sub-info-card">
                    <p class="text-xxs fw-bold text-secondary text-uppercase tracking-wider mb-2">연락처</p>
                    <p class="small fw-bold text-dark m-0">{{user.phone}}</p>
                </div>
                <div class="sub-info-card">
                    <p class="text-xxs fw-bold text-secondary text-uppercase tracking-wider mb-2">이메일</p>
                    <p class="small fw-bold text-dark m-0">{{user.email}}</p>
                </div>
            </div>
        </div>
    </div>
</div>
{{> layout/admin-footer}}
