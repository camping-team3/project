{{> layout/admin-header}}
<div class="p-4 p-lg-5" style="max-width: 1400px; margin: 0 auto;">
    <!-- User Overview Card (안정적인 3단 그리드 레이아웃) -->
    <div class="fh-card p-4 p-lg-5 mb-5 border-0 shadow-sm bg-white rounded-4">
        <div class="row g-5 align-items-center">
            
            <!-- [1단] 좌측: 프로필 이미지 및 주요 정보 -->
            <div class="col-xl-3 border-end border-light text-center">
                <div class="position-relative d-inline-block mb-4">
                    <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuBjLWnR5btJ7Vzl2F04dSFUDs6e0IKd58PvnxI3ZZGgasEy7loQLOdAO-NWWF9_ZbE9BA2KUDbK7XrCjW1nRsYyGnoW5JXLZ8m3RjezY92d5L6z-kuLYZJWjm4G1dXXDVOI3Neb0fKHeUauozDKtXdTWcS_5k_faLEyWd2-0tWT69kVhjz6yDDZcLnl1ii3Bj4_8nnbmQrwyYCBeSyHOrqt8BXhN2Fo5TdnYBQ7NKYrtp2pST2OxuZMhYP70qvBMTp2oeAJ9CtzrPV0" 
                         alt="User" 
                         style="width: 140px; height: 140px; object-fit: cover; border-radius: 30px;" 
                         class="shadow-sm border border-light">
                    <button class="btn btn-primary btn-sm rounded-circle position-absolute bottom-0 end-0 p-2 shadow border-2 border-white">
                        <span class="material-symbols-outlined fs-6">edit</span>
                    </button>
                </div>
                <h2 class="h3 fw-black text-dark mb-1">{{user.name}}</h2>
                <p class="text-secondary small mb-0 text-truncate px-2">{{user.email}}</p>
            </div>

            <!-- [2단] 중앙: 계정 상세 정보 그리드 -->
            <div class="col-xl-6">
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="p-3 rounded-4 bg-light bg-opacity-50 border border-white">
                            <p class="text-xxs fw-bold text-secondary text-uppercase mb-1">아이디</p>
                            <p class="fw-bold text-dark m-0">{{user.username}}</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 rounded-4 bg-light bg-opacity-50 border border-white">
                            <p class="text-xxs fw-bold text-secondary text-uppercase mb-1">현재 권한</p>
                            <p class="fw-bold text-dark m-0">{{user.role}}</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 rounded-4 bg-light bg-opacity-50 border border-white">
                            <p class="text-xxs fw-bold text-secondary text-uppercase mb-1">연락처</p>
                            <p class="fw-bold text-dark m-0">{{user.phone}}</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 rounded-4 bg-light bg-opacity-50 border border-white">
                            <p class="text-xxs fw-bold text-secondary text-uppercase mb-1">가입일</p>
                            <p class="fw-bold text-dark m-0">2026.03.24</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- [3단] 우측: 계정 관리 액션 -->
            <div class="col-xl-3 border-start border-light ps-xl-5">
                <div class="mb-4 text-center text-xl-start">
                    <p class="text-xxs fw-bold text-secondary text-uppercase mb-2">계정 상태</p>
                    <span class="badge bg-success bg-opacity-10 text-success fw-bold px-3 py-2 rounded-pill">
                        <span class="d-inline-block bg-success rounded-circle me-1" style="width: 6px; height: 6px;"></span>
                        활성 계정
                    </span>
                </div>
                
                <hr class="my-4 d-xl-none">

                <div class="admin-action-box">
                    <p class="text-xxs fw-bold text-secondary text-uppercase mb-2 ps-1">권한 변경</p>
                    <form action="/admin/users/{{user.id}}/update-role" method="post" class="d-flex flex-column gap-2">
                        <select name="role" class="form-select fw-bold shadow-sm border-light bg-light">
                            <option value="USER">일반 사용자(USER)</option>
                            <option value="ADMIN">관리자(ADMIN)</option>
                        </select>
                        <button type="submit" class="btn btn-primary px-4 py-2.5 fw-bold rounded-3 shadow-sm border-0">적용하기</button>
                    </form>
                </div>
            </div>

        </div>
    </div>

    <!-- 하단 데이터 영역 -->
    <div class="row">
        <div class="col-12 px-2">
            <div class="detail-tab-nav mb-4 border-bottom border-light">
                <div class="detail-tab-item active d-inline-block pb-3 fw-bold text-primary border-bottom border-primary border-3" style="cursor: pointer;">최근 활동 내역</div>
            </div>
            <div class="fh-card border-0 shadow-sm bg-white p-5 text-center text-secondary rounded-4">
                <span class="material-symbols-outlined fs-1 mb-3 opacity-25">history</span>
                <p class="m-0">이 사용자의 상세 예약 및 활동 내역을 불러오는 중입니다.</p>
            </div>
        </div>
    </div>
</div>
{{> layout/admin-footer}}
