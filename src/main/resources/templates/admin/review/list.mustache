{{> layout/admin-header}}

<style>
/* 상단 네비게이션 제거 */
.admin-header {
    display: none !important;
}
/* 네비게이션 제거로 인한 여백 조정 */
.admin-content {
    padding-top: 0 !important;
}
/* 리뷰 상세 토글 스타일 */
.review-detail-row {
    display: none;
    background-color: #f8f9fa;
}
.review-content-clickable {
    cursor: pointer;
    transition: background-color 0.2s;
}
.review-content-clickable:hover {
    background-color: rgba(0,0,0,0.02);
}
.detail-content-box {
    padding: 20px;
    border-left: 4px solid #dee2e6;
}
.ai-badge-high {
    background-color: #ffebee;
    color: #c62828;
    border: 1px solid #ffcdd2;
}
.ai-badge-normal {
    background-color: #e8f5e9;
    color: #2e7d32;
    border: 1px solid #c8e6c9;
}
</style>

<div class="d-flex justify-content-between align-items-end mb-5">
    <div>
        <h2 class="display-6 fw-black text-dark mb-1">리뷰 관리</h2>
        <p class="text-secondary fw-medium m-0">AI 비방 분석 결과를 확인하고 부적절한 리뷰를 관리합니다. 내용을 클릭하면 상세 내용을 볼 수 있습니다.</p>
    </div>
</div>

    <!-- Filter & Search Bar -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex gap-2">
            <a href="/admin/reviews?sort=danger" class="btn {{#isDangerSort}}btn-primary{{/isDangerSort}}{{^isDangerSort}}btn-outline-secondary{{/isDangerSort}} fw-bold rounded-pill px-3 py-1.5 text-xs">
                위험도 높은순
            </a>
            <a href="/admin/reviews?sort=latest" class="btn {{^isDangerSort}}btn-primary{{/isDangerSort}}{{#isDangerSort}}btn-outline-secondary{{/isDangerSort}} fw-bold rounded-pill px-3 py-1.5 text-xs">
                최신순
            </a>
            <a href="/admin/reviews?filter=pending" class="btn btn-outline-secondary fw-bold rounded-pill px-3 py-1.5 text-xs d-flex align-items-center gap-1">
                <span class="material-symbols-outlined fs-6">error</span>
                검토 대기중
            </a>
        </div>
        
        <form action="/admin/reviews" method="GET" class="d-flex gap-2" style="max-width: 350px;">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-white border-end-0">
                    <span class="material-symbols-outlined fs-5 text-secondary">search</span>
                </span>
                <input type="text" name="keyword" class="form-control border-start-0 ps-0" placeholder="작성자 또는 내용 검색" value="{{keyword}}">
                <button class="btn btn-outline-primary fw-bold" type="submit">검색</button>
            </div>
        </form>
    </div>

    <!-- Review Table -->
    <div class="fh-card shadow-sm border-primary border-opacity-10 overflow-hidden mb-4 bg-white">
        <div class="table-responsive">
            <table class="fh-table m-0">
                <thead class="bg-light bg-opacity-50">
                    <tr>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider px-4" style="width: 60px;">No.</th>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider px-4" style="width: 100px;">작성자</th>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider px-4" style="width: 150px;">사이트</th>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider px-4" style="width: 80px;">평점</th>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider px-4">리뷰 내용 (클릭 시 펼치기)</th>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider px-4" style="width: 100px;">AI 위험도</th>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider px-4" style="width: 100px;">상태</th>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider text-center px-4" style="width: 140px;">관리</th>
                    </tr>
                </thead>
                <tbody>
                    {{#response.reviews}}
                    <tr class="review-content-clickable {{#isHighDanger}}bg-danger bg-opacity-10{{/isHighDanger}} {{#isExpelled}}opacity-50 text-muted{{/isExpelled}}" onclick="toggleDetail({{id}})">
                        <td class="px-4 text-secondary small">{{id}}</td>
                        <td class="px-4">
                            <div class="d-flex align-items-center gap-2">
                                <span class="fw-bold">{{username}}</span>
                                {{#isExpelled}}
                                <span class="badge bg-danger bg-opacity-10 text-danger fw-bold rounded-pill text-xxs px-1.5">탈퇴회원</span>
                                {{/isExpelled}}
                                {{^isExpelled}}
                                    {{#penaltyCount}}
                                    <span class="badge {{#canExpel}}bg-danger{{/canExpel}}{{^canExpel}}bg-warning{{/canExpel}} bg-opacity-10 {{#canExpel}}text-danger{{/canExpel}}{{^canExpel}}text-warning{{/canExpel}} fw-bold rounded-pill text-xxs px-1.5" title="누적 위반 횟수">
                                        ⚠️{{penaltyCount}}
                                    </span>
                                    {{/penaltyCount}}
                                {{/isExpelled}}
                            </div>
                        </td>
                        <td class="px-4 small text-secondary">{{zoneName}} / {{siteName}}</td>
                        <td class="px-4 text-warning">⭐ {{rating}}</td>
                        <td class="px-4">
                            <div class="d-flex align-items-center gap-2">
                                <p class="m-0 text-truncate" style="max-width: 350px;">{{content}}</p>
                                <span class="material-symbols-outlined fs-6 text-secondary" id="icon-{{id}}">expand_more</span>
                            </div>
                        </td>
                        <td class="px-4">
                            <span class="badge {{#isHighDanger}}ai-badge-high{{/isHighDanger}}{{^isHighDanger}}ai-badge-normal{{/isHighDanger}} fw-bold px-2.5 py-1 rounded-pill text-xs">
                                {{aiDangerScore}}점
                            </span>
                        </td>
                        <td class="px-4">
                            {{#isDeleted}}
                            <span class="badge bg-secondary bg-opacity-10 text-secondary fw-bold px-2.5 py-1 rounded-pill text-xs" title="사유: {{adminReason}}">삭제됨</span>
                            {{/isDeleted}}
                            {{^isDeleted}}
                                {{#isReviewed}}
                                <span class="badge bg-success bg-opacity-10 text-success fw-bold px-2.5 py-1 rounded-pill text-xs">유지됨</span>
                                {{/isReviewed}}
                                {{^isReviewed}}
                                <span class="badge bg-warning bg-opacity-10 text-warning fw-bold px-2.5 py-1 rounded-pill text-xs">검토대기</span>
                                {{/isReviewed}}
                            {{/isDeleted}}
                        </td>
                        <td class="px-4 text-center">
                            <div class="d-flex justify-content-center gap-1" onclick="event.stopPropagation()">
                                {{^isReviewed}}
                                <button onclick="processReview({{id}}, 'keep')" class="btn btn-sm btn-outline-success fw-bold text-xs py-1 px-2">유지</button>
                                <button onclick="openDeleteModal({{id}})" class="btn btn-sm btn-outline-danger fw-bold text-xs py-1 px-2">삭제</button>
                                {{/isReviewed}}
                                {{#isReviewed}}
                                <span class="small text-muted">-</span>
                                {{/isReviewed}}
                                
                                {{#canExpel}}
                                <button onclick="expelUser({{userId}}, '{{username}}')" class="btn btn-sm btn-danger fw-bold text-xs py-1 px-2 shadow-sm">강제탈퇴</button>
                                {{/canExpel}}
                            </div>
                        </td>
                    </tr>
                    <!-- Detail Toggle Row -->
                    <tr id="detail-{{id}}" class="review-detail-row">
                        <td colspan="8" class="px-4 py-0">
                            <div class="detail-content-box my-3 bg-white shadow-sm rounded-3">
                                <div class="row">
                                    <div class="col-md-8">
                                        <h6 class="fw-bold text-dark mb-3 d-flex align-items-center gap-2">
                                            <span class="material-symbols-outlined fs-5">subject</span>
                                            리뷰 전체 내용
                                        </h6>
                                        <p class="text-secondary small lh-lg" style="white-space: pre-wrap;">{{content}}</p>
                                        {{#images.size}}
                                        <div class="mt-3 d-flex gap-2">
                                            {{#images}}
                                            <a href="/upload/{{.}}" target="_blank">
                                                <img src="/upload/{{.}}" class="rounded-2 border shadow-sm" style="width: 120px; height: 120px; object-fit: cover;">
                                            </a>
                                            {{/images}}
                                        </div>
                                        {{/images.size}}
                                    </div>
                                    <div class="col-md-4 border-start">
                                        <h6 class="fw-bold text-dark mb-3 d-flex align-items-center gap-2">
                                            <span class="material-symbols-outlined fs-5">analytics</span>
                                            AI 분석 상세
                                        </h6>
                                        <div class="bg-light p-3 rounded-3">
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <span class="small text-secondary">위험 점수</span>
                                                <span class="fw-bold {{#isHighDanger}}text-danger{{/isHighDanger}}{{^isHighDanger}}text-success{{/isHighDanger}}">{{aiDangerScore}} / 5</span>
                                            </div>
                                            <div class="progress mb-3" style="height: 6px;">
                                                <div class="progress-bar {{#isHighDanger}}bg-danger{{/isHighDanger}}{{^isHighDanger}}bg-success{{/isHighDanger}}" 
                                                     role="progressbar" style="width: {{aiDangerScore}}0%*2;"></div>
                                            </div>
                                            <p class="text-xs text-muted mb-0">
                                                {{#isHighDanger}}
                                                ⚠️ 비방성 또는 공격적인 표현이 감지되었습니다. 신속한 검토가 필요합니다.
                                                {{/isHighDanger}}
                                                {{^isHighDanger}}
                                                ✅ 일반적인 리뷰 내용으로 판단됩니다.
                                                {{/isHighDanger}}
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                    {{/response.reviews}}
                    {{^response.reviews}}
                    <tr>
                        <td colspan="8" class="text-center py-5 text-secondary">등록된 리뷰가 없습니다.</td>
                    </tr>
                    {{/response.reviews}}
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="px-4 py-3 bg-light bg-opacity-50 d-flex justify-content-between align-items-center border-top">
            <div class="text-secondary small">총 {{response.pagination.totalElements}}개 항목</div>
            <nav>
                <ul class="pagination pagination-sm m-0 gap-1">
                    {{#response.pagination.hasPrev}}
                    <li class="page-item">
                        <a class="page-link border-0 rounded-2 text-secondary bg-white d-flex align-items-center justify-content-center" href="?page={{response.pagination.prevPage}}" style="width: 32px; height: 32px;">
                            <span class="material-symbols-outlined fs-6">chevron_left</span>
                        </a>
                    </li>
                    {{/response.pagination.hasPrev}}
                    
                    {{#response.pagination.pageNumbers}}
                    <li class="page-item {{#isCurrent}}active{{/isCurrent}}">
                        <a class="page-link border-0 rounded-2 {{#isCurrent}}bg-primary text-white{{/isCurrent}}{{^isCurrent}}text-secondary bg-white{{/isCurrent}} fw-bold shadow-sm d-flex align-items-center justify-content-center" href="?page={{number}}" style="width: 32px; height: 32px;">{{displayDigit}}</a>
                    </li>
                    {{/response.pagination.pageNumbers}}
                    
                    {{#response.pagination.hasNext}}
                    <li class="page-item">
                        <a class="page-link border-0 rounded-2 text-secondary bg-white d-flex align-items-center justify-content-center" href="?page={{response.pagination.nextPage}}" style="width: 32px; height: 32px;">
                            <span class="material-symbols-outlined fs-6">chevron_right</span>
                        </a>
                    </li>
                    {{/response.pagination.hasNext}}
                </ul>
            </nav>
        </div>
    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
// 상세 토글 함수
function toggleDetail(id) {
    const detailRow = document.getElementById('detail-' + id);
    const icon = document.getElementById('icon-' + id);
    
    if (detailRow.style.display === 'table-row') {
        detailRow.style.display = 'none';
        icon.innerText = 'expand_more';
    } else {
        // 다른 열려있는 행 닫기 (선택 사항)
        document.querySelectorAll('.review-detail-row').forEach(row => row.style.display = 'none');
        document.querySelectorAll('.material-symbols-outlined[id^="icon-"]').forEach(i => i.innerText = 'expand_more');
        
        detailRow.style.display = 'table-row';
        icon.innerText = 'expand_less';
    }
}

function processReview(id, action) {
    if (action === 'keep') {
        Swal.fire({
            title: '리뷰를 유지하시겠습니까?',
            text: "검토 완료 상태로 변경됩니다.",
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#2c5926',
            confirmButtonText: '유지 확정',
            cancelButtonText: '취소'
        }).then((result) => {
            if (result.isConfirmed) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = ('/admin/reviews/' + id + '/keep').trim();
                document.body.appendChild(form);
                form.submit();
            }
        });
    }
}

function openDeleteModal(id) {
    Swal.fire({
        title: '리뷰 삭제 사유 입력',
        input: 'textarea',
        inputPlaceholder: '사용자에게 보여질 삭제 사유를 입력하세요...',
        showCancelButton: true,
        confirmButtonColor: '#dc3545',
        confirmButtonText: '삭제 실행',
        cancelButtonText: '취소',
        preConfirm: (reason) => {
            if (!reason) {
                Swal.showValidationMessage('삭제 사유를 반드시 입력해야 합니다.');
            }
            return reason;
        }
    }).then((result) => {
        if (result.isConfirmed) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = ('/admin/reviews/' + id + '/delete').trim();
            
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'reason';
            input.value = result.value.trim();
            
            form.appendChild(input);
            document.body.appendChild(form);
            form.submit();
        }
    });
}

function expelUser(userId, username) {
    Swal.fire({
        title: '회원 강제 탈퇴 및 블랙리스트 등록',
        html: '작성자 <b>' + username + '</b>님을 강제 탈퇴시키겠습니까?<br><small class="text-danger">탈퇴 사유를 입력해주세요. 로그인 시 해당 사유가 안내됩니다.</small>',
        input: 'textarea',
        inputPlaceholder: '예: 부적절한 리뷰 반복 작성 및 커뮤니티 가이드 위반',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        confirmButtonText: '탈퇴 및 차단 처리',
        cancelButtonText: '취소',
        preConfirm: (reason) => {
            if (!reason) {
                Swal.showValidationMessage('차단 사유를 반드시 입력해야 합니다.');
            }
            return reason;
        }
    }).then((result) => {
        if (result.isConfirmed) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = ('/admin/users/' + userId + '/expel').trim();
            
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'reason';
            input.value = result.value.trim();
            
            form.appendChild(input);
            document.body.appendChild(form);
            form.submit();
        }
    });
}
</script>

{{> layout/admin-footer}}
