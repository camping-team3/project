{{> admin/layout/header}}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">리뷰 관리</h2>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="px-4 py-3 text-secondary small fw-bold" style="width: 80px;">번호</th>
                            <th class="py-3 text-secondary small fw-bold" style="width: 120px;">작성자</th>
                            <th class="py-3 text-secondary small fw-bold" style="width: 100px;">별점</th>
                            <th class="py-3 text-secondary small fw-bold">내용</th>
                            <th class="py-3 text-secondary small fw-bold" style="width: 150px;">이미지</th>
                            <th class="py-3 text-secondary small fw-bold" style="width: 150px;">구역/사이트</th>
                            <th class="py-3 text-secondary small fw-bold" style="width: 150px;">등록일</th>
                            <th class="px-4 py-3 text-secondary small fw-bold text-end" style="width: 100px;">관리</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#response.reviews}}
                        <tr>
                            <td class="px-4 small text-secondary">{{id}}</td>
                            <td class="fw-bold">{{username}}</td>
                            <td>
                                <div class="text-warning d-flex gap-1">
                                    <span class="material-symbols-outlined fs-6" style="font-variation-settings: 'FILL' 1">star</span>
                                    <span class="fw-bold">{{rating}}</span>
                                </div>
                            </td>
                            <td>
                                <div class="text-truncate" style="max-width: 300px;" title="{{content}}">
                                    {{content}}
                                </div>
                            </td>
                            <td>
                                <div class="d-flex gap-1 overflow-hidden">
                                    {{#images}}
                                    <img src="/upload/{{.}}" class="rounded" style="width: 40px; height: 40px; object-fit: cover;">
                                    {{/images}}
                                    {{^images}}
                                    <span class="text-muted small">없음</span>
                                    {{/images}}
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border">{{zoneName}} - {{siteName}}</span>
                            </td>
                            <td class="small text-secondary">{{createdAt}}</td>
                            <td class="px-4 text-end">
                                <form action="/admin/reviews/{{id}}/delete" method="POST" onsubmit="return confirm('정말로 이 리뷰를 삭제하시겠습니까? 삭제 시 해당 사이트/구역의 평점도 즉시 조정됩니다.');">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">삭제</button>
                                </form>
                            </td>
                        </tr>
                        {{/response.reviews}}
                        {{^response.reviews}}
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">등록된 리뷰가 없습니다.</td>
                        </tr>
                        {{/response.reviews}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Pagination -->
    {{#response.pagination}}
    <nav class="d-flex justify-content-center">
        <ul class="pagination pagination-sm gap-1">
            <li class="page-item {{^hasPrev}}disabled{{/hasPrev}}">
                <a class="page-link border-0 rounded-circle" href="?page={{prevPage}}">
                    <span class="material-symbols-outlined fs-5">chevron_left</span>
                </a>
            </li>
            
            {{#pageNumbers}}
            <li class="page-item {{#isCurrent}}active{{/isCurrent}}">
                <a class="page-link border-0 rounded-circle px-3" href="?page={{number}}">{{displayDigit}}</a>
            </li>
            {{/pageNumbers}}

            <li class="page-item {{^hasNext}}disabled{{/hasNext}}">
                <a class="page-link border-0 rounded-circle" href="?page={{nextPage}}">
                    <span class="material-symbols-outlined fs-5">chevron_right</span>
                </a>
            </li>
        </ul>
    </nav>
    {{/response.pagination}}
</div>

{{> admin/layout/footer}}
