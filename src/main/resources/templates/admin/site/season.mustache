{{> layout/admin-header}}
<link href="/css/admin/site/season.css" rel="stylesheet">

<!-- Page Title -->
<div class="mb-5">
        <h2 class="display-6 fw-black text-dark mb-1">시즌 요금 및 일정 관리</h2>
        <p class="text-secondary fw-medium m-0">캠핑장의 시즌별 요금을 설정하고 일정을 체계적으로 관리합니다.</p>
    </div>

    <div class="row g-4 mb-5">
        <!-- Create Season Form -->
        <div class="col-lg-4">
            <div class="fh-card shadow-sm h-100 p-4">
                <h4 class="h6 fw-bold text-dark mb-4 d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined text-primary fs-5">add_circle</span>
                    새 시즌 생성
                </h4>
                <div class="mb-3">
                    <label class="form-label text-xs fw-bold text-secondary text-uppercase tracking-wider">시즌 명칭</label>
                    <input type="text" class="form-control py-2 shadow-none border-secondary border-opacity-25 season-form-input" placeholder="예: 2024 여름 극성수기">
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label text-xs fw-bold text-secondary text-uppercase tracking-wider">시작일</label>
                        <input type="date" class="form-control py-2 shadow-none border-secondary border-opacity-25 season-form-input">
                    </div>
                    <div class="col-6">
                        <label class="form-label text-xs fw-bold text-secondary text-uppercase tracking-wider">종료일</label>
                        <input type="date" class="form-control py-2 shadow-none border-secondary border-opacity-25 season-form-input">
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label text-xs fw-bold text-secondary text-uppercase tracking-wider">시즌 유형</label>
                    <select class="form-select py-2 shadow-none border-secondary border-opacity-25 season-form-input">
                        <option value="peak">극성수기 (Peak)</option>
                        <option value="semi-peak">준성수기 (Semi-peak)</option>
                        <option value="off-season">비수기 (Off-season)</option>
                    </select>
                </div>
                <div class="mb-4">
                    <label class="form-label text-xs fw-bold text-secondary text-uppercase tracking-wider">요금 조정</label>
                    <div class="d-flex gap-2">
                        <div class="input-group flex-grow-1">
                            <input type="number" class="form-control py-2 shadow-none border-secondary border-opacity-25 season-form-input" placeholder="조정 값">
                            <span class="input-group-text bg-white border-secondary border-opacity-25 text-secondary small">%</span>
                        </div>
                        <select class="form-select py-2 shadow-none border-secondary border-opacity-25 w-auto season-form-input">
                            <option value="percent">퍼센트</option>
                            <option value="fixed">정액</option>
                        </select>
                    </div>
                </div>
                <button class="btn btn-primary w-100 py-3 fw-bold shadow-lg d-flex align-items-center justify-content-center gap-2 border-0 mt-2">
                    <span class="material-symbols-outlined fs-5">save</span>
                    <span class="small">시즌 일정 등록하기</span>
                </button>
            </div>
        </div>

        <!-- Calendar Preview -->
        <div class="col-lg-8">
            <div class="fh-card shadow-sm h-100 p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="h6 fw-bold text-dark m-0 d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-primary fs-5">calendar_month</span>
                        캘린더 미리보기
                    </h4>
                    <div class="d-flex align-items-center gap-3">
                        <div class="d-flex align-items-center gap-1 small fw-bold text-secondary text-xxs">
                            <span class="legend-dot bg-dot-peak"></span> 극성수기
                        </div>
                        <div class="d-flex align-items-center gap-1 small fw-bold text-secondary text-xxs">
                            <span class="legend-dot bg-dot-semi"></span> 준성수기
                        </div>
                        <div class="d-flex align-items-center gap-1 small fw-bold text-secondary text-xxs">
                            <span class="legend-dot bg-dot-off"></span> 비수기
                        </div>
                        <div class="d-flex align-items-center gap-2 ms-3">
                            <button class="btn btn-sm btn-light p-1 border-0"><span class="material-symbols-outlined fs-6">chevron_left</span></button>
                            <span class="fw-bold text-dark small">{{currentYear}}년 {{currentMonth}}월</span>
                            <button class="btn btn-sm btn-light p-1 border-0"><span class="material-symbols-outlined fs-6">chevron_right</span></button>
                        </div>
                    </div>
                </div>

                <div class="calendar-grid">
                    <div class="calendar-day-header">Sun</div>
                    <div class="calendar-day-header">Mon</div>
                    <div class="calendar-day-header">Tue</div>
                    <div class="calendar-day-header">Wed</div>
                    <div class="calendar-day-header">Thu</div>
                    <div class="calendar-day-header">Fri</div>
                    <div class="calendar-day-header">Sat</div>
                    
                    {{#calendarDays}}
                    <div class="calendar-day {{^isCurrentMonth}}other-month{{/isCurrentMonth}} {{#isToday}}bg-primary bg-opacity-10{{/isToday}}">
                        <span class="{{#isToday}}fw-bold text-primary{{/isToday}}">{{day}}</span>
                    </div>
                    {{/calendarDays}}
                </div>
            </div>
        </div>
    </div>

    <!-- Season List -->
    <div class="fh-card shadow-sm border-primary border-opacity-10 overflow-hidden mb-4">
        <div class="p-4 border-bottom d-flex justify-content-between align-items-center bg-white">
            <h4 class="h6 fw-bold text-dark m-0 d-flex align-items-center gap-2">
                <span class="material-symbols-outlined text-primary fs-5">list_alt</span>
                시즌 목록
            </h4>
            <div class="d-flex gap-2">
                <button class="btn btn-light btn-sm fw-bold px-3">전체보기</button>
                <button class="btn btn-light btn-sm fw-bold px-3 shadow-sm border border-secondary border-opacity-10">내보내기 (Excel)</button>
            </div>
        </div>
        <div class="table-responsive">
            <table class="fh-table">
                <thead class="bg-light">
                    <tr>
                        <th class="text-xs fw-bold text-secondary uppercase">시즌명</th>
                        <th class="text-xs fw-bold text-secondary uppercase">기간</th>
                        <th class="text-xs fw-bold text-secondary uppercase">유형</th>
                        <th class="text-xs fw-bold text-secondary uppercase text-center">요금 조정</th>
                        <th class="text-xs fw-bold text-secondary uppercase text-end">관리</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="fw-bold text-dark">2024 여름 휴가 극성수기</td>
                        <td class="text-secondary small">2024.07.20 ~ 2024.08.15</td>
                        <td><span class="badge bg-danger bg-opacity-10 text-danger fw-bold px-2.5 py-1 rounded-pill badge-season-type">극성수기</span></td>
                        <td class="text-center text-danger fw-bold">+30%</td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-1">
                                <button class="btn btn-icon btn-sm hover-primary bg-light rounded"><span class="material-symbols-outlined fs-5">edit</span></button>
                                <button class="btn btn-icon btn-sm hover-danger bg-light rounded"><span class="material-symbols-outlined fs-5">delete</span></button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-bold text-dark">7월 준성수기</td>
                        <td class="text-secondary small">2024.07.13 ~ 2024.07.19</td>
                        <td><span class="badge bg-warning bg-opacity-10 text-warning fw-bold px-2.5 py-1 rounded-pill badge-season-type">준성수기</span></td>
                        <td class="text-center text-warning fw-bold">+15%</td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-1">
                                <button class="btn btn-icon btn-sm hover-primary bg-light rounded"><span class="material-symbols-outlined fs-5">edit</span></button>
                                <button class="btn btn-icon btn-sm hover-danger bg-light rounded"><span class="material-symbols-outlined fs-5">delete</span></button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-bold text-dark">기본 비수기</td>
                        <td class="text-secondary small">상시 적용</td>
                        <td><span class="badge bg-primary bg-opacity-10 text-primary fw-bold px-2.5 py-1 rounded-pill badge-season-type">비수기</span></td>
                        <td class="text-center text-secondary">0%</td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-1">
                                <button class="btn btn-icon btn-sm hover-primary bg-light rounded"><span class="material-symbols-outlined fs-5">edit</span></button>
                                <button class="btn btn-icon btn-sm hover-danger bg-light rounded"><span class="material-symbols-outlined fs-5">delete</span></button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <!-- Pagination -->
        <div class="px-4 py-3 bg-light bg-opacity-50 d-flex justify-content-center border-top">
            <nav>
                <ul class="pagination pagination-sm m-0 gap-1">
                    <li class="page-item"><a class="page-link border bg-white text-secondary rounded" href="#"><span class="material-symbols-outlined fs-6">keyboard_arrow_left</span></a></li>
                    <li class="page-item active"><a class="page-link border-0 rounded bg-primary text-white fw-bold" href="#">1</a></li>
                    <li class="page-item"><a class="page-link border bg-white text-dark fw-bold" href="#">2</a></li>
                    <li class="page-item"><a class="page-link border bg-white text-dark fw-bold" href="#">3</a></li>
                    <li class="page-item"><a class="page-link border bg-white text-secondary rounded" href="#"><span class="material-symbols-outlined fs-6">keyboard_arrow_right</span></a></li>
                </ul>
            </nav>
        </div>
    </div>
</div>
{{> layout/admin-footer}}
