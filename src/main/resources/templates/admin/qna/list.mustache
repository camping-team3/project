{{> layout/admin-header}}
<div class="p-4 p-lg-5">
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <h2 class="display-6 fw-black text-dark mb-1">질의응답 관리</h2>
            <p class="text-secondary fw-medium m-0 small">사용자들의 문의 사항을 실시간으로 확인하고 답변을 등록합니다.</p>
        </div>
        <button class="btn btn-primary px-4 py-2.5 fw-bold d-flex align-items-center gap-2 shadow-lg border-0 rounded-3">
            <span class="material-symbols-outlined fs-5">download</span>
            <span>내보내기 (Excel)</span>
        </button>
    </div>

    <!-- Tabs -->
    <div class="d-flex align-items-center gap-4 mb-4 border-bottom border-light px-2">
        <div class="admin-tab-item active fw-bold text-primary border-bottom border-primary border-3 pb-2">전체</div>
        <div class="admin-tab-item fw-medium text-secondary pb-2">답변 대기</div>
        <div class="admin-tab-item fw-medium text-secondary pb-2">답변 완료</div>
    </div>

    <!-- Table -->
    <div class="fh-card shadow-sm border-primary border-opacity-10 overflow-hidden mb-5">
        <div class="table-responsive">
            <table class="fh-table">
                <thead class="bg-light bg-opacity-50">
                    <tr>
                        <th class="text-xs fw-bold text-secondary uppercase px-4 col-id">ID</th>
                        <th class="text-xs fw-bold text-secondary uppercase px-4">문의 제목</th>
                        <th class="text-xs fw-bold text-secondary uppercase px-4 col-author">작성자</th>
                        <th class="text-xs fw-bold text-secondary uppercase px-4 col-date">등록일</th>
                        <th class="text-xs fw-bold text-secondary uppercase px-4 col-status">상태</th>
                        <th class="text-xs fw-bold text-secondary uppercase px-4 text-end col-action">관리</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Row 1 -->
                    <tr class="hover-bg-primary-5 transition-colors">
                        <td class="text-secondary fw-bold px-4">105</td>
                        <td class="px-4">
                            <div class="fw-bold text-dark m-0 title-truncate">숲속의 집 예약 문의</div>
                            <div class="text-secondary category-text">카테고리: 예약/결제</div>
                        </td>
                        <td class="px-4 small">김철수</td>
                        <td class="px-4 text-secondary small">2023-10-24</td>
                        <td class="px-4"><span class="badge bg-amber-subtle fw-bold px-2.5 py-1 rounded">답변 대기</span></td>
                        <td class="px-4 text-end">
                            <a href="/admin/qna/105/answer" class="btn-detail-link">상세보기 <span class="material-symbols-outlined">chevron_right</span></a>
                        </td>
                    </tr>
                    <!-- Row 2 -->
                    <tr>
                        <td class="text-secondary fw-bold px-4">104</td>
                        <td class="px-4">
                            <div class="fw-bold text-dark m-0 title-truncate">반려동물 동반 가능 여부</div>
                            <div class="text-secondary category-text">카테고리: 시설안내</div>
                        </td>
                        <td class="px-4 small">이영희</td>
                        <td class="px-4 text-secondary small">2023-10-23</td>
                        <td class="px-4"><span class="badge bg-green-subtle fw-bold px-2.5 py-1 rounded">답변 완료</span></td>
                        <td class="px-4 text-end">
                            <a href="/admin/qna/104/answer" class="btn-detail-completed">상세보기 <span class="material-symbols-outlined">chevron_right</span></a>
                        </td>
                    </tr>
                    <!-- Row 3 -->
                    <tr>
                        <td class="text-secondary fw-bold px-4">103</td>
                        <td class="px-4">
                            <div class="fw-bold text-dark m-0 title-truncate">환불 규정이 궁금합니다</div>
                            <div class="text-secondary category-text">카테고리: 예약/결제</div>
                        </td>
                        <td class="px-4 small">박지민</td>
                        <td class="px-4 text-secondary small">2023-10-22</td>
                        <td class="px-4"><span class="badge bg-green-subtle fw-bold px-2.5 py-1 rounded">답변 완료</span></td>
                        <td class="px-4 text-end">
                            <a href="/admin/qna/103/answer" class="btn-detail-completed">상세보기 <span class="material-symbols-outlined">chevron_right</span></a>
                        </td>
                    </tr>
                    <!-- Row 4 -->
                    <tr class="hover-bg-primary-5 transition-colors">
                        <td class="text-secondary fw-bold px-4">102</td>
                        <td class="px-4">
                            <div class="fw-bold text-dark m-0 title-truncate">단체 예약 할인 혜택</div>
                            <div class="text-secondary category-text">카테고리: 프로모션</div>
                        </td>
                        <td class="px-4 small">최승우</td>
                        <td class="px-4 text-secondary small">2023-10-21</td>
                        <td class="px-4"><span class="badge bg-amber-subtle fw-bold px-2.5 py-1 rounded">답변 대기</span></td>
                        <td class="px-4 text-end">
                            <a href="/admin/qna/102/answer" class="btn-detail-link">상세보기 <span class="material-symbols-outlined">chevron_right</span></a>
                        </td>
                    </tr>
                    <!-- Row 5 -->
                    <tr>
                        <td class="text-secondary fw-bold px-4">101</td>
                        <td class="px-4">
                            <div class="fw-bold text-dark m-0 title-truncate">주차 시설 안내 요청</div>
                            <div class="text-secondary category-text">카테고리: 시설안내</div>
                        </td>
                        <td class="px-4 small">강다니엘</td>
                        <td class="px-4 text-secondary small">2023-10-20</td>
                        <td class="px-4"><span class="badge bg-green-subtle fw-bold px-2.5 py-1 rounded">답변 완료</span></td>
                        <td class="px-4 text-end">
                            <a href="/admin/qna/101/answer" class="btn-detail-completed">상세보기 <span class="material-symbols-outlined">chevron_right</span></a>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <!-- Pagination -->
        <div class="px-4 py-3 bg-light bg-opacity-50 d-flex justify-content-between align-items-center border-top">
            <div class="text-secondary small">전체 105건 중 1-5 표시</div>
            <nav>
                <ul class="pagination pagination-sm m-0 gap-1">
                    <li class="page-item disabled"><a class="page-link border bg-transparent text-secondary rounded" href="#"><span class="material-symbols-outlined fs-6">chevron_left</span></a></li>
                    <li class="page-item active"><a class="page-link border-0 rounded bg-primary text-white fw-bold" href="#">1</a></li>
                    <li class="page-item"><a class="page-link border rounded text-dark fw-bold" href="#">2</a></li>
                    <li class="page-item"><a class="page-link border rounded text-dark fw-bold" href="#">3</a></li>
                    <li class="page-item"><a class="page-link border bg-transparent text-secondary rounded" href="#"><span class="material-symbols-outlined fs-6">chevron_right</span></a></li>
                </ul>
            </nav>
        </div>
    </div>

    <!-- Stats Summary -->
    <div class="row g-4">
        <div class="col-md-4">
            <div class="fh-card d-flex align-items-center gap-4 p-4 border-0 shadow-sm bg-white">
                <div class="icon-box-48 icon-box-pending"><span class="material-symbols-outlined fs-4">pending_actions</span></div>
                <div>
                    <p class="text-xxs fw-bold text-secondary text-uppercase tracking-wider mb-1">미처리 문의</p>
                    <p class="h3 fw-black text-danger m-0">2건</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="fh-card d-flex align-items-center gap-4 p-4 border-0 shadow-sm bg-white">
                <div class="icon-box-48 icon-box-completed"><span class="material-symbols-outlined fs-4">done_all</span></div>
                <div>
                    <p class="text-xxs fw-bold text-secondary text-uppercase tracking-wider mb-1">오늘 완료된 답변</p>
                    <p class="h3 fw-black text-primary m-0">12건</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="fh-card d-flex align-items-center gap-4 p-4 border-0 shadow-sm bg-white">
                <div class="icon-box-48 icon-box-time"><span class="material-symbols-outlined fs-4">timer</span></div>
                <div>
                    <p class="text-xxs fw-bold text-secondary text-uppercase tracking-wider mb-1">평균 답변 시간</p>
                    <p class="h3 fw-black text-dark m-0">1시간 15분</p>
                </div>
            </div>
        </div>
    </div>
</div>
{{> layout/admin-footer}}
