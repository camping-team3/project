{{> layout/admin-header}}
<div class="p-4 p-lg-5">
    <!-- Page Title -->
    {{#qna}}
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <h1 class="display-6 fw-black text-dark mb-1">고객 문의 상세</h1>
            <p class="text-primary fw-bold small m-0 opacity-75">문의 ID: #QA-{{id}}</p>
        </div>
        {{#isAnswered}}
        <span class="badge bg-green-subtle fw-bold px-3 py-2 rounded-pill">답변 완료</span>
        {{/isAnswered}}
        {{^isAnswered}}
        <span class="badge bg-amber-subtle fw-bold px-3 py-2 rounded-pill">답변 대기중</span>
        {{/isAnswered}}
    </div>

    <!-- Customer Question Card -->
    <div class="fh-card shadow-sm border-0 p-0 overflow-hidden mb-5">
        <div class="p-4 bg-white border-bottom d-flex align-items-center gap-4">
            <div class="rounded-circle overflow-hidden shadow-sm customer-profile-img-wrapper" style="width: 48px; height: 48px; background: #eee; display: flex; align-items: center; justify-content: center;">
                <span class="material-symbols-outlined text-secondary">person</span>
            </div>
            <div>
                <h3 class="h6 fw-bold text-dark m-0">{{username}} 고객님</h3>
                <div class="d-flex gap-3 text-secondary small mt-1">
                    <span class="d-flex align-items-center gap-1"><span class="material-symbols-outlined icon-xs">calendar_today</span> {{createdAt}}</span>
                    <span class="opacity-25">|</span>
                    <span class="d-flex align-items-center gap-1"><span class="material-symbols-outlined icon-xs">category</span> {{categoryName}}</span>
                </div>
            </div>
        </div>
        <div class="p-4 p-md-5">
            <h4 class="h4 fw-bold text-dark mb-4">{{title}}</h4>
            <div class="text-secondary leading-relaxed mb-5 content-text">
                {{{content}}}
            </div>
        </div>
    </div>

    <!-- Existing Answers -->
    {{#comments}}
    <div class="fh-card shadow-sm border-0 p-0 overflow-hidden mb-4 bg-light bg-opacity-50">
        <div class="p-4 border-bottom d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2 text-primary">
                <span class="material-symbols-outlined">chat_bubble</span>
                <h3 class="h6 fw-bold m-0">등록된 답변</h3>
            </div>
            <span class="text-secondary small fw-bold">작성일: {{createdAt}}</span>
        </div>
        <div class="p-4">
            <div class="text-dark">{{content}}</div>
            <div class="text-end mt-2 small text-secondary">- 관리자: {{adminName}}</div>
        </div>
    </div>
    {{/comments}}

    <!-- Admin Answer Form -->
    {{^isAnswered}}
    <div class="fh-card answer-form-highlight p-0 overflow-hidden bg-white mb-5">
        <div class="p-4 bg-primary bg-opacity-5 border-bottom d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2 text-primary">
                <span class="material-symbols-outlined">edit_note</span>
                <h3 class="h6 fw-bold m-0">답변 등록</h3>
            </div>
        </div>
        <div class="p-4 p-md-5">
            <form action="/admin/qna/{{id}}/comment" method="post">
                <div class="position-relative mb-4">
                    <textarea name="content" class="form-control bg-light border-0 p-4 shadow-none answer-textarea" rows="10" placeholder="고객님께 정중하고 친절한 답변을 작성해주세요..." required></textarea>
                </div>

                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-primary flex-grow-1 py-3.5 fw-black shadow-lg border-0 d-flex align-items-center justify-content-center gap-2 rounded-3 btn-answer-submit">
                        <span class="material-symbols-outlined fs-5">send</span>
                        <span>답변 등록하기</span>
                    </button>
                    <button type="button" onclick="history.back()" class="btn btn-light px-5 py-3.5 fw-bold text-secondary border bg-white rounded-3">취소</button>
                </div>
            </form>
        </div>
    </div>
    {{/isAnswered}}
    {{/qna}}
</div>
{{> layout/admin-footer}}
