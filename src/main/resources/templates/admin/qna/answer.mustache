{{> layout/admin-header}}
<div class="p-4 p-lg-5">
    <!-- Page Title -->
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <h1 class="display-6 fw-black text-dark mb-1">고객 문의 상세</h1>
            <p class="text-primary fw-bold small m-0 opacity-75">문의 ID: #QA-882910</p>
        </div>
        <span class="badge bg-amber-subtle fw-bold px-3 py-2 rounded-pill">답변 대기중</span>
    </div>

    <!-- Customer Question Card -->
    <div class="fh-card shadow-sm border-0 p-0 overflow-hidden mb-5">
        <div class="p-4 bg-white border-bottom d-flex align-items-center gap-4">
            <div class="rounded-circle overflow-hidden shadow-sm customer-profile-img-wrapper">
                <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuCkW9E4jq2G5TsS1rhSEq-fwSBpA7B96pdFBDSOh83mTzRVyzYOxZNI7m1Yp-Rgv5--CS-PRLwrE8BHdLpbxVkXrsO__HIEkI1Sb2_RoN3FRT6-OCsLyFTn7mnTxd7W1KZXdg8q5bnrvZbfI2YSmOz2hcF84XHoMz6Ruu-bzpIBu7xe4vYio3cQDD5zxDVenHlI7_K4I1N1ZhfqzaBK9bKZdFg76A0WQ2RENLARr5z0Kh6QIk6OWA-I6AArR-P1hnv535bNixMVXvoM" class="w-100 h-100 object-fit-cover" alt="User">
            </div>
            <div>
                <h3 class="h6 fw-bold text-dark m-0">김철수 고객님</h3>
                <div class="d-flex gap-3 text-secondary small mt-1">
                    <span class="d-flex align-items-center gap-1"><span class="material-symbols-outlined icon-xs">calendar_today</span> 2023.10.27 14:30</span>
                    <span class="opacity-25">|</span>
                    <span class="d-flex align-items-center gap-1"><span class="material-symbols-outlined icon-xs">category</span> 예약 문의</span>
                </div>
            </div>
        </div>
        <div class="p-4 p-md-5">
            <h4 class="h4 fw-bold text-dark mb-4">5명 가족이 가려고 하는데 어디 뷰가 좋나요</h4>
            <div class="text-secondary leading-relaxed mb-5 content-text">
                <p>안녕하세요.</p>
                <p>5인 가족이 이번 캠핑장 방문 하려하는데 객실이 많더라구요. 어떤 객실을 이용해야 더 뷰가 좋을지 궁금합니다</p>
                <p class="mt-4">주문 번호: 20231020-0099281<br>상품명: 프리미엄 오토캠핑 텐트 &amp; 감성 캠핑 체어 세트</p>
            </div>
            <div class="mt-5 pt-4 border-top border-dashed">
                <p class="text-xxs fw-bold text-secondary uppercase tracking-wider mb-3">첨부 파일 (1)</p>
                <div class="d-inline-flex align-items-center gap-3 p-2 px-3 bg-light rounded-3 border">
                    <span class="material-symbols-outlined text-primary fs-5">image</span>
                    <span class="small text-dark fw-bold">camping_gear_status.jpg</span>
                    <button class="btn btn-link text-primary small fw-bold p-0 ms-3 text-decoration-none">다운로드</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Admin Answer Form -->
    <div class="fh-card answer-form-highlight p-0 overflow-hidden bg-white mb-5">
        <div class="p-4 bg-primary bg-opacity-5 border-bottom d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2 text-primary">
                <span class="material-symbols-outlined">edit_note</span>
                <h3 class="h6 fw-bold m-0">답변 등록</h3>
            </div>
            <span class="text-secondary small fw-bold">담당 관리자: <span class="text-primary">이민지 팀장</span></span>
        </div>
        <div class="p-4 p-md-5">
            <div class="d-flex gap-2 mb-3">
                <button class="btn btn-light btn-sm fw-bold border text-secondary">상용구 불러오기</button>
                <button class="btn btn-light btn-sm fw-bold border text-secondary">이전 답변 참조</button>
            </div>
            <div class="position-relative mb-4">
                <textarea class="form-control bg-light border-0 p-4 shadow-none answer-textarea" rows="10" placeholder="고객님께 정중하고 친절한 답변을 작성해주세요..."></textarea>
                <div class="position-absolute bottom-0 end-0 p-3 text-secondary opacity-50 char-counter">0 / 2000자</div>
            </div>

            <div class="d-flex flex-column gap-2 mb-5">
                <div class="form-check">
                    <input class="form-check-input shadow-none" type="checkbox" id="check1" checked>
                    <label class="form-check-label small fw-bold text-secondary" for="check1">답변 완료 시 고객에게 알림톡 발송</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input shadow-none" type="checkbox" id="check2">
                    <label class="form-check-label small fw-bold text-secondary" for="check2">비공개 메모로 저장</label>
                </div>
            </div>

            <div class="d-flex gap-3">
                <button class="btn btn-primary flex-grow-1 py-3.5 fw-black shadow-lg border-0 d-flex align-items-center justify-content-center gap-2 rounded-3 btn-answer-submit">
                    <span class="material-symbols-outlined fs-5">send</span>
                    <span>답변 등록하기</span>
                </button>
                <button class="btn btn-light px-5 py-3.5 fw-bold text-secondary border bg-white rounded-3">임시 저장</button>
            </div>
        </div>
    </div>
</div>
{{> layout/admin-footer}}
