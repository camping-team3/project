{{> layout/admin-header}}
<div class="p-5 content-inner-max">
    <!-- Page Title Section -->
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="display-6 fw-bold text-dark mb-1 tracking-tight">새 공지사항 작성</h2>
            <p class="text-secondary small mt-1">캠핑지기 웹사이트 및 앱에 노출될 새로운 공지사항을 등록합니다.</p>
        </div>
        <div class="d-flex gap-3">
            <button onclick="history.back()" class="btn btn-light px-4 py-2.5 fw-bold text-secondary border bg-white rounded-3 small">취소</button>
            <button class="btn btn-primary px-4 py-2.5 fw-bold shadow-md border-0 rounded-3 small">게시하기</button>
        </div>
    </div>

    <div class="space-y-6">
        <!-- Form Card -->
        <div class="form-card shadow-sm">
            <!-- Category & Title -->
            <div class="row g-4 mb-4">
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-dark mb-2">카테고리</label>
                    <select class="form-select py-2.5 shadow-none border-secondary border-opacity-25 text-sm">
                        <option value="important">중요</option>
                        <option selected value="general">일반</option>
                        <option value="event">이벤트</option>
                        <option value="system">시스템</option>
                    </select>
                </div>
                <div class="col-md-9">
                    <label class="form-label small fw-bold text-dark mb-2">공지사항 제목</label>
                    <input type="text" class="form-control py-2.5 shadow-none border-secondary border-opacity-25 text-sm" placeholder="공지사항 제목을 입력해주세요">
                </div>
            </div>

            <!-- Editor -->
            <div class="mb-4">
                <label class="form-label small fw-bold text-dark mb-2">본문 내용</label>
                <div class="fh-editor-container">
                    <div class="fh-editor-toolbar d-flex flex-wrap gap-1">
                        <button class="btn btn-icon btn-sm"><span class="material-symbols-outlined fs-5">format_bold</span></button>
                        <button class="btn btn-icon btn-sm"><span class="material-symbols-outlined fs-5">format_italic</span></button>
                        <button class="btn btn-icon btn-sm"><span class="material-symbols-outlined fs-5">format_underlined</span></button>
                        <div class="vr mx-2 opacity-10"></div>
                        <button class="btn btn-icon btn-sm"><span class="material-symbols-outlined fs-5">format_align_left</span></button>
                        <button class="btn btn-icon btn-sm"><span class="material-symbols-outlined fs-5">format_align_center</span></button>
                        <button class="btn btn-icon btn-sm"><span class="material-symbols-outlined fs-5">format_list_bulleted</span></button>
                        <div class="vr mx-2 opacity-10"></div>
                        <button class="btn btn-icon btn-sm"><span class="material-symbols-outlined fs-5">image</span></button>
                        <button class="btn btn-icon btn-sm"><span class="material-symbols-outlined fs-5">link</span></button>
                    </div>
                    <textarea class="fh-editor-content" placeholder="공지사항 내용을 작성해주세요..."></textarea>
                </div>
            </div>

            <!-- File Upload -->
            <div class="mb-0">
                <label class="form-label small fw-bold text-dark mb-2">첨부 파일 (PDF, DOCX, HWP)</label>
                <div class="file-drop-zone">
                    <span class="material-symbols-outlined icon-upload">upload_file</span>
                    <p class="small fw-medium text-dark mb-1">클릭하거나 파일을 이곳에 드래그하여 업로드하세요</p>
                    <p class="text-secondary" style="font-size: 11px;">최대 20MB 이하의 문서 파일만 가능합니다.</p>
                    <button class="btn btn-white btn-sm px-4 py-2 mt-3 shadow-sm border border-secondary border-opacity-25 fw-bold rounded-2">파일 선택</button>
                </div>

                <!-- Attached Files -->
                <div class="mt-4 d-flex flex-column gap-2">
                    <div class="attached-file-item d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center gap-3">
                            <span class="material-symbols-outlined text-primary fs-5">description</span>
                            <div>
                                <p class="small fw-bold text-dark m-0">2024_동계_안전_수칙_안내.pdf</p>
                                <p class="fs-attach-size m-0">2.4 MB</p>
                            </div>
                        </div>
                        <button class="btn btn-icon text-secondary hover-danger"><span class="material-symbols-outlined fs-5">close</span></button>
                    </div>
                    <div class="attached-file-item d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center gap-3">
                            <span class="material-symbols-outlined text-primary fs-5">description</span>
                            <div>
                                <p class="small fw-bold text-dark m-0">이용약관_개정_대조표.docx</p>
                                <p class="fs-attach-size m-0">156 KB</p>
                            </div>
                        </div>
                        <button class="btn btn-icon text-secondary hover-danger"><span class="material-symbols-outlined fs-5">close</span></button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom Actions -->
        <div class="d-flex align-items-center justify-content-end gap-3 pt-4">
            <span class="text-secondary small italic me-auto opacity-50">마지막 임시 저장: 2024.05.20 14:22:10</span>
            <button onclick="history.back()" class="btn btn-light px-4 py-2.5 rounded-lg border border-secondary border-opacity-10 bg-white small fw-bold text-secondary">취소</button>
            <button class="btn btn-primary px-4 py-2.5 rounded-lg fw-bold shadow-md border-0 small">게시하기</button>
        </div>
    </div>
</div>
{{> layout/admin-footer}}
