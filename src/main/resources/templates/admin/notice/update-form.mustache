{{> layout/admin-header}}

<!-- Summernote Lite CSS (Bootstrap 5 호환) -->
<link href="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.css" rel="stylesheet">

<div class="p-5" style="max-width: 896px; margin: 0 auto;">
    <form id="noticeUpdateForm" action="/admin/notices/{{notice.id}}/update" method="POST" enctype="multipart/form-data">
        <!-- Page Title Section -->
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h2 class="display-6 fw-bold text-dark mb-1 tracking-tight">공지사항 수정</h2>
                <p class="text-secondary small mt-1">기존 공지사항의 내용을 수정합니다.</p>
            </div>
            <div class="d-flex gap-3">
                <button type="button" onclick="history.back()" class="btn btn-light px-4 py-2.5 fw-bold text-secondary border bg-white rounded-3 small">취소</button>
                <button type="button" class="btn btn-primary px-4 py-2.5 fw-bold shadow-md border-0 rounded-3 small btn-notice-update">수정 완료</button>
            </div>
        </div>

        <div id="deleteInputArea">
            <!-- 삭제할 이미지 ID들이 input hidden으로 여기에 쌓입니다 -->
        </div>

        <div class="space-y-6">
            <!-- Form Card -->
            <div class="form-card shadow-sm p-4 bg-white rounded-4 border border-secondary border-opacity-10">
                <!-- isTop & Title -->
                <div class="row g-4 mb-4 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label small fw-bold text-dark mb-2">공지 설정</label>
                        <div class="form-check form-switch p-0 ms-4">
                            <input class="form-check-input" type="checkbox" name="isTop" value="true" id="isTopCheck" style="width: 3em; height: 1.5em;" {{#notice.isTop}}checked{{/notice.isTop}}>
                            <label class="form-check-label ms-2 fw-bold text-primary small" for="isTopCheck">상단 고정 (필독)</label>
                        </div>
                    </div>
                    <div class="col-md-9">
                        <label class="form-label small fw-bold text-dark mb-2">공지사항 제목</label>
                        <input type="text" name="title" class="form-control py-2.5 shadow-none border-secondary border-opacity-25 text-sm" placeholder="공지사항 제목을 입력해주세요" value="{{notice.title}}" required>
                    </div>
                </div>

                <!-- Editor -->
                <div class="mb-4">
                    <label class="form-label small fw-bold text-dark mb-2">본문 내용</label>
                    <textarea id="summernote" name="content">{{notice.content}}</textarea>
                </div>

                <!-- File Upload -->
                <div class="mb-0">
                    <label class="form-label small fw-bold text-dark mb-3">첨부 이미지 수정</label>
                    
                    <!-- 숨겨진 파일 입력창 -->
                    <input type="file" id="imageInput" name="images" multiple accept="image/*" style="display:none">
                    
                    <div id="dropZone" class="file-drop-zone border-dashed p-5 text-center bg-light rounded-4" style="border: 2px dashed #dee2e6; cursor: pointer; transition: all 0.3s ease;">
                        <span class="material-symbols-outlined icon-upload fs-1 text-secondary opacity-50">upload_file</span>
                        <p class="small fw-medium text-dark mb-1 mt-2">이미지 파일을 추가로 드래그하거나 클릭하세요</p>
                        <p class="text-secondary" style="font-size: 11px;">최대 10MB 이하의 이미지를 추가로 등록할 수 있습니다.</p>
                    </div>

                    <!-- 프리뷰 그리드 영역 (기존 이미지 + 새로 선택한 이미지) -->
                    <div id="previewGrid" class="d-flex flex-wrap gap-3 mt-3">
                        {{#notice.images}}
                        <div class="position-relative animate__animated animate__fadeIn" style="width: 120px; height: 120px;">
                            <img src="{{filePath}}" class="w-100 h-100 object-fit-cover rounded-3 border shadow-sm">
                            <div class="position-absolute top-0 start-0 bg-primary text-white text-xs px-2 py-0.5 rounded-br-3 small shadow-sm" style="font-size: 10px;">기존</div>
                            <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 p-0 d-flex align-items-center justify-content-center" 
                                    style="width: 24px; height: 24px; border-radius: 50%; font-size: 16px; transform: translate(30%, -30%); border: 2px solid white;" 
                                    onclick="removeExistingFile(this, {{id}})">×</button>
                        </div>
                        {{/notice.images}}
                        <!-- 동적으로 새로운 프리뷰 이미지가 삽입될 공간 -->
                    </div>
                </div>
            </div>

            <!-- Bottom Actions -->
            <div class="d-flex align-items-center justify-content-end gap-3 pt-4">
                <button type="button" onclick="history.back()" class="btn btn-light px-4 py-2.5 rounded-lg border border-secondary border-opacity-10 bg-white small fw-bold text-secondary">취소</button>
                <button type="button" class="btn btn-primary px-4 py-2.5 rounded-lg fw-bold shadow-md border-0 small btn-notice-update">수정 완료</button>
            </div>
        </div>
    </form>
</div>

<!-- JQuery & Summernote Lite JS (Full 버전 jQuery 사용) -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.js"></script>

<script>
    $(document).ready(function() {
        // Summernote 초기화
        $('#summernote').summernote({
            placeholder: '공지사항 내용을 작성해주세요...',
            tabsize: 2,
            height: 400,
            toolbar: [
                ['style', ['style']],
                ['font', ['bold', 'underline', 'clear']],
                ['color', ['color']],
                ['para', ['ul', 'ol', 'paragraph']],
                ['table', ['table']],
                ['insert', ['link', 'picture', 'video']],
                ['view', ['fullscreen', 'codeview', 'help']]
            ]
        });

        // 수정 완료 버튼 클릭 이벤트 (클래스로 통합)
        $('.btn-notice-update').on('click', function() {
            // Summernote 내용 동기화
            const content = $('#summernote').summernote('code');
            if (!content || content === '<p><br></p>' || content === '') {
                alert('본문 내용을 입력해주세요.');
                return;
            }
            $('#summernote').val(content);

            // 제목 확인
            const title = $('input[name="title"]').val();
            if (!title || title.trim() === '') {
                alert('제목을 입력해주세요.');
                return;
            }

            // 폼 제출 (동기식 전송 -> 서버에서 리다이렉트 응답 처리)
            console.log('Submitting form...');
            $('#noticeUpdateForm').submit();
        });

        // 이미지 업로드 로직 (새로운 파일 전용)
        const dropZone = document.getElementById('dropZone');
        const imageInput = document.getElementById('imageInput');
        const previewGrid = document.getElementById('previewGrid');
        let selectedFiles = [];

        if (dropZone) {
            dropZone.addEventListener('click', () => imageInput.click());
            dropZone.addEventListener('dragover', (e) => {
                e.preventDefault();
                dropZone.style.backgroundColor = 'rgba(13, 110, 253, 0.05)';
                dropZone.style.borderColor = '#0d6efd';
            });
            dropZone.addEventListener('dragleave', () => {
                dropZone.style.backgroundColor = '';
                dropZone.style.borderColor = '#dee2e6';
            });
            dropZone.addEventListener('drop', (e) => {
                e.preventDefault();
                dropZone.style.backgroundColor = '';
                dropZone.style.borderColor = '#dee2e6';
                const files = Array.from(e.dataTransfer.files).filter(file => file.type.startsWith('image/'));
                handleFiles(files);
            });
        }

        if (imageInput) {
            imageInput.addEventListener('change', (e) => {
                const files = Array.from(e.target.files);
                handleFiles(files);
            });
        }

        function handleFiles(files) {
            files.forEach(file => {
                selectedFiles.push(file);
                const reader = new FileReader();
                reader.onload = (e) => {
                    const previewItem = document.createElement('div');
                    previewItem.className = 'position-relative animate__animated animate__fadeIn';
                    previewItem.style.width = '120px';
                    previewItem.style.height = '120px';
                    previewItem.innerHTML = `
                        <img src="${e.target.result}" class="w-100 h-100 object-fit-cover rounded-3 border shadow-sm">
                        <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 p-0 d-flex align-items-center justify-content-center" 
                                style="width: 24px; height: 24px; border-radius: 50%; font-size: 16px; transform: translate(30%, -30%); border: 2px solid white;" 
                                onclick="removeFile(this, '${file.name}')">×</button>
                        <div class="position-absolute top-0 start-0 bg-success text-white text-xs px-2 py-0.5 rounded-br-3 small shadow-sm" style="font-size: 10px;">신규</div>
                    `;
                    previewGrid.appendChild(previewItem);
                };
                reader.readAsDataURL(file);
            });
            updateInputFiles();
        }

        // 새 파일 삭제
        window.removeFile = function(btn, fileName) {
            btn.parentElement.remove();
            selectedFiles = selectedFiles.filter(f => f.name !== fileName);
            updateInputFiles();
        };

        // 기존 파일 삭제 (서버에 전달할 ID 추가)
        window.removeExistingFile = function(btn, imageId) {
            btn.parentElement.remove();
            const deleteInput = document.createElement('input');
            deleteInput.type = 'hidden';
            deleteInput.name = 'deleteImageIds';
            deleteInput.value = imageId;
            document.getElementById('deleteInputArea').appendChild(deleteInput);
        };

        function updateInputFiles() {
            const dataTransfer = new DataTransfer();
            selectedFiles.forEach(file => dataTransfer.items.add(file));
            imageInput.files = dataTransfer.files;
        }
    });
</script>

{{> layout/admin-footer}}
