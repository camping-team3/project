{{> layout/admin-header}}
<div class="p-4 p-lg-5">
    <!-- Page Title -->
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <h2 class="display-6 fw-black text-dark mb-1">공지사항 관리</h2>
            <p class="text-secondary fw-medium m-0">전체 서비스 공지사항을 등록하고 편집할 수 있습니다.</p>
        </div>
        <button onclick="location.href='/admin/notices/new'" class="btn btn-primary px-4 py-2.5 fw-bold d-flex align-items-center gap-2 shadow-sm rounded-3 border-0">
            <span class="material-symbols-outlined fs-5">add</span>
            <span>새 공지 작성</span>
        </button>
    </div>

    <!-- Admin Tabs -->
    <div class="admin-tabs border-bottom mb-4 px-2">
        <div class="admin-tab-item active fw-bold border-bottom border-primary border-2 pb-2">전체 (42)</div>
        <div class="admin-tab-item fw-medium text-secondary pb-2">필독</div>
        <div class="admin-tab-item fw-medium text-secondary pb-2">일반</div>
        <div class="admin-tab-item fw-medium text-secondary pb-2">이벤트</div>
    </div>

    <!-- Notice Table -->
    <div class="fh-card shadow-sm border-primary border-opacity-10 overflow-hidden mb-4 bg-white">
        <div class="table-responsive">
            <table class="fh-table m-0">
                <thead class="bg-light bg-opacity-50">
                    <tr>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider px-4" style="width: 80px;">No.</th>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider px-4" style="width: 120px;">카테고리</th>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider px-4">제목</th>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider px-4" style="width: 150px;">등록일</th>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider text-center px-4" style="width: 100px;">조회수</th>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider text-center px-4" style="width: 120px;">관리</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Row 1 -->
                    <tr>
                        <td class="px-4 text-secondary">42</td>
                        <td class="px-4"><span class="badge bg-danger bg-opacity-10 text-danger fw-bold px-2.5 py-1 rounded-pill text-xs">필독</span></td>
                        <td class="px-4">
                            <a href="#" class="text-dark fw-bold text-decoration-none hover-primary">2024년 하반기 서버 정기 점검 안내</a>
                            <span class="material-symbols-outlined pin-icon">push_pin</span>
                        </td>
                        <td class="px-4 text-secondary small">2024.10.24</td>
                        <td class="px-4 text-center text-secondary small">1,204</td>
                        <td class="px-4 text-center">
                            <div class="d-flex justify-content-center gap-1">
                                <button class="btn btn-icon btn-sm hover-primary bg-light rounded-2"><span class="material-symbols-outlined fs-5">edit</span></button>
                                <button class="btn btn-icon btn-sm hover-danger bg-light rounded-2"><span class="material-symbols-outlined fs-5 text-danger opacity-75">delete</span></button>
                            </div>
                        </td>
                    </tr>
                    <!-- Row 2 -->
                    <tr>
                        <td class="px-4 text-secondary">41</td>
                        <td class="px-4"><span class="badge bg-primary bg-opacity-10 text-primary fw-bold px-2.5 py-1 rounded-pill text-xs">일반</span></td>
                        <td class="px-4"><a href="#" class="text-dark fw-bold text-decoration-none hover-primary">사용자 약관 및 개인정보 처리방침 개정 안내</a></td>
                        <td class="px-4 text-secondary small">2024.10.22</td>
                        <td class="px-4 text-center text-secondary small">856</td>
                        <td class="px-4 text-center">
                            <div class="d-flex justify-content-center gap-1">
                                <button class="btn btn-icon btn-sm hover-primary bg-light rounded-2"><span class="material-symbols-outlined fs-5">edit</span></button>
                                <button class="btn btn-icon btn-sm hover-danger bg-light rounded-2"><span class="material-symbols-outlined fs-5 text-danger opacity-75">delete</span></button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="px-4 py-3 bg-light bg-opacity-50 d-flex justify-content-between align-items-center border-top">
            <div class="text-secondary small">총 42개 항목 중 1-2 표시</div>
            <nav>
                <ul class="pagination pagination-sm m-0 gap-1">
                    <li class="page-item disabled"><a class="page-link border-0 rounded-2 text-secondary bg-transparent" href="#"><span class="material-symbols-outlined fs-6">chevron_left</span></a></li>
                    <li class="page-item active"><a class="page-link border-0 rounded-2 bg-primary text-white fw-bold" href="#">1</a></li>
                    <li class="page-item"><a class="page-link border-0 rounded-2 text-dark fw-bold bg-white" href="#">2</a></li>
                    <li class="page-item"><a class="page-link border-0 rounded-2 text-dark fw-bold bg-white" href="#">3</a></li>
                    <li class="page-item"><a class="page-link border-0 rounded-2 text-secondary bg-transparent" href="#"><span class="material-symbols-outlined fs-6">chevron_right</span></a></li>
                </ul>
            </nav>
        </div>
    </div>

    <!-- Admin Action Bar -->
    <div class="bulk-action-bar d-flex justify-content-between align-items-center bg-white shadow-sm">
        <div class="d-flex align-items-center gap-4">
            <span class="small fw-bold text-primary">일괄 관리</span>
            <div class="d-flex gap-2">
                <button class="btn btn-light btn-sm px-3 shadow-none border border-secondary border-opacity-10 fw-bold bg-white rounded-2">선택 삭제</button>
                <button class="btn btn-light btn-sm px-3 shadow-none border border-secondary border-opacity-10 fw-bold bg-white rounded-2">상태 변경</button>
            </div>
        </div>
        <div class="d-flex gap-4 text-secondary text-xs fw-medium">
            <div class="d-flex align-items-center gap-2"><span class="status-indicator-dot bg-danger"></span> 필독 공지</div>
            <div class="d-flex align-items-center gap-2"><span class="status-indicator-dot bg-primary"></span> 일반 소식</div>
            <div class="d-flex align-items-center gap-2"><span class="status-indicator-dot bg-info"></span> 프로모션/이벤트</div>
        </div>
    </div>
</div>
{{> layout/admin-footer}}
