{{> layout/admin-header}}
<div class="p-4 p-lg-5">
    <!-- Page Title -->
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <h2 class="display-6 fw-black text-dark mb-1">공지사항 관리</h2>
            <p class="text-secondary fw-medium m-0">전체 서비스 공지사항을 등록하고 편집할 수 있습니다.</p>
        </div>
        <button onclick="location.href='/admin/notices/save-form'" class="btn btn-primary px-4 py-2.5 fw-bold d-flex align-items-center gap-2 shadow-sm rounded-3 border-0">
            <span class="material-symbols-outlined fs-5">add</span>
            <span>새 공지 작성</span>
        </button>
    </div>

    <!-- Search Bar -->
    <div class="mb-4">
        <form action="/admin/notices" method="GET" class="d-flex gap-2" style="max-width: 400px;">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-white border-end-0">
                    <span class="material-symbols-outlined fs-5 text-secondary">search</span>
                </span>
                <input type="text" name="keyword" class="form-control border-start-0 ps-0" placeholder="제목 또는 내용 검색" value="{{keyword}}">
                <button class="btn btn-outline-primary fw-bold" type="submit">검색</button>
            </div>
        </form>
    </div>

    <!-- Notice Table -->
    <div class="fh-card shadow-sm border-primary border-opacity-10 overflow-hidden mb-4 bg-white">
        <div class="table-responsive">
            <table class="fh-table m-0">
                <thead class="bg-light bg-opacity-50">
                    <tr>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider px-4" style="width: 80px;">No.</th>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider px-4" style="width: 120px;">구분</th>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider px-4">제목</th>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider px-4" style="width: 150px;">등록일</th>
                        <th class="text-xs fw-bold text-secondary text-uppercase tracking-wider text-center px-4" style="width: 120px;">관리</th>
                    </tr>
                </thead>
                <tbody>
                    {{#notices.content}}
                    <tr>
                        <td class="px-4 text-secondary">{{id}}</td>
                        <td class="px-4">
                            {{#isTop}}
                            <span class="badge bg-danger bg-opacity-10 text-danger fw-bold px-2.5 py-1 rounded-pill text-xs">필독</span>
                            {{/isTop}}
                            {{^isTop}}
                            <span class="badge bg-primary bg-opacity-10 text-primary fw-bold px-2.5 py-1 rounded-pill text-xs">일반</span>
                            {{/isTop}}
                        </td>
                        <td class="px-4">
                            <a href="/admin/notices/{{id}}/update-form" class="text-dark fw-bold text-decoration-none hover-primary">{{title}}</a>
                            {{#isTop}}
                            <span class="material-symbols-outlined pin-icon ms-1" style="font-size: 16px; vertical-align: middle; color: #dc3545;">push_pin</span>
                            {{/isTop}}
                        </td>
                        <td class="px-4 text-secondary small">{{createdAt}}</td>
                        <td class="px-4 text-center">
                            <div class="d-flex justify-content-center gap-1">
                                <a href="/admin/notices/{{id}}/update-form" class="btn btn-icon btn-sm hover-primary bg-light rounded-2">
                                    <span class="material-symbols-outlined fs-5">edit</span>
                                </a>
                                <form action="/admin/notices/{{id}}/delete" method="POST" onsubmit="return confirm('정말 삭제하시겠습니까?');" style="display: inline;">
                                    <button type="submit" class="btn btn-icon btn-sm hover-danger bg-light rounded-2 border-0">
                                        <span class="material-symbols-outlined fs-5 text-danger opacity-75">delete</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {{/notices.content}}
                    {{^notices.content}}
                    <tr>
                        <td colspan="5" class="text-center py-5 text-secondary fw-medium">검색 결과가 없거나 등록된 공지사항이 없습니다.</td>
                    </tr>
                    {{/notices.content}}
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="px-4 py-3 bg-light bg-opacity-50 d-flex justify-content-between align-items-center border-top">
            <div class="text-secondary small">총 {{notices.totalElements}}개 항목</div>
            <nav>
                <ul class="pagination pagination-sm m-0 gap-1">
                    {{#notices.hasPrevious}}
                    <li class="page-item">
                        <a class="page-link border-0 rounded-2 text-dark fw-bold bg-white shadow-sm" href="?page={{notices.previousPage}}&keyword={{keyword}}">
                            <span class="material-symbols-outlined fs-6">chevron_left</span>
                        </a>
                    </li>
                    {{/notices.hasPrevious}}
                    
                    <li class="page-item active">
                        <a class="page-link border-0 rounded-2 bg-primary text-white fw-bold shadow-sm" href="#">{{notices.number}}</a>
                    </li>
                    
                    {{#notices.hasNext}}
                    <li class="page-item">
                        <a class="page-link border-0 rounded-2 text-dark fw-bold bg-white shadow-sm" href="?page={{notices.nextPage}}&keyword={{keyword}}">
                            <span class="material-symbols-outlined fs-6">chevron_right</span>
                        </a>
                    </li>
                    {{/notices.hasNext}}
                </ul>
            </nav>
        </div>
    </div>
</div>
{{> layout/admin-footer}}
