{{> layout/header}}

        <main class="container py-5" style="max-width: 960px; margin: 0 auto;">
            <div class="mb-5 px-2">
                <h2 class="display-5 fw-black text-dark mb-2">Q&A 커뮤니티</h2>
                <p class="text-secondary fw-medium fs-5 opacity-75">캠핑장과 관련해 궁금한 점을 관리자에게 물어보세요.</p>
            </div>

            <!-- Filter & Action Bar -->
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-4 mb-5 px-2">
                <div class="d-flex gap-2">
                    <a href="/qna?status=all" class="btn {{#isAll}}btn-primary{{/isAll}}{{^isAll}}btn-light bg-white border border-secondary border-opacity-10 text-secondary{{/isAll}} rounded-pill px-4 fw-bold small transition-all">전체보기</a>
                    <a href="/qna?status=pending" class="btn {{#isPending}}btn-primary{{/isPending}}{{^isPending}}btn-light bg-white border border-secondary border-opacity-10 text-secondary{{/isPending}} rounded-pill px-4 fw-bold small transition-all">답변대기</a>
                    <a href="/qna?status=completed" class="btn {{#isCompleted}}btn-primary{{/isCompleted}}{{^isCompleted}}btn-light bg-white border border-secondary border-opacity-10 text-secondary{{/isCompleted}} rounded-pill px-4 fw-bold small transition-all">답변완료</a>
                </div>
                <button onclick="location.href='/qna/new'" class="btn btn-primary px-4 py-2.5 fw-bold shadow-lg border-0 d-flex align-items-center gap-2 rounded-3">
                    <span class="material-symbols-outlined fs-5">edit</span>
                    <span>질문하기</span>
                </button>
            </div>

            <!-- Question List -->
            <div class="d-flex flex-column gap-3">
                {{#qnas}}
                <!-- Item: {{id}} -->
                <div class="fh-card question-item p-4 border-0 shadow-sm rounded-4 transition-all bg-white">
                    <div class="d-flex gap-4">
                        <div class="status-icon-box {{#isAnswered}}status-completed{{/isAnswered}}{{^isAnswered}}status-pending{{/isAnswered}} shadow-sm">
                            <span class="material-symbols-outlined">{{#isAnswered}}task_alt{{/isAnswered}}{{^isAnswered}}pending{{/isAnswered}}</span>
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                {{#isAnswered}}
                                <span class="badge bg-primary bg-opacity-10 text-primary fw-bold badge-res-status">답변완료</span>
                                {{/isAnswered}}
                                {{^isAnswered}}
                                <span class="badge bg-warning bg-opacity-10 text-warning fw-bold badge-res-status">답변대기</span>
                                {{/isAnswered}}
                                <span class="text-secondary small fw-bold opacity-50">{{categoryName}}</span>
                                {{#isAnswered}}
                                <span class="lock-badge"><span class="material-symbols-outlined icon-14">lock</span> 수정제한</span>
                                {{/isAnswered}}
                            </div>
                            <a href="/qna/{{id}}" class="text-decoration-none">
                                <h3 class="h6 fw-bold text-dark mb-3 hover-primary transition-colors cursor-pointer">{{title}}</h3>
                            </a>
                            <div class="d-flex align-items-center gap-3 text-secondary text-xxs">
                                <span class="fw-black text-dark">{{username}}</span>
                                <span class="opacity-25">•</span>
                                <span>{{createdAt}}</span>
                                <span class="opacity-25">•</span>
                                <span class="d-flex align-items-center gap-1"><span class="material-symbols-outlined icon-14">visibility</span> {{hits}}</span>
                            </div>
                        </div>
                        <div class="d-flex gap-2 align-self-start">
                            {{#isOwner}}
                                {{#isAnswered}}
                                <div class="custom-tooltip">
                                    <button class="btn btn-sm fw-bold px-3 border-0 opacity-50 cursor-not-allowed bg-light text-secondary rounded-3" disabled>수정</button>
                                    <span class="tooltip-text">답변이 완료되어 수정할 수 없습니다.</span>
                                </div>
                                {{/isAnswered}}
                                {{^isAnswered}}
                                <button onclick="location.href='/qna/{{id}}/edit-form'" class="btn btn-sm fw-bold px-3 border-0 transition-all btn-edit-action">수정</button>
                                {{/isAnswered}}
                                <form action="/qna/{{id}}/delete" method="post" onsubmit="return confirm('정말 삭제하시겠습니까?');">
                                    <button type="submit" class="btn btn-sm fw-bold px-3 border-0 transition-all btn-delete-action">삭제</button>
                                </form>
                            {{/isOwner}}
                        </div>
                    </div>
                </div>
                {{/qnas}}
                {{^qnas}}
                <div class="text-center py-5">
                    <p class="text-secondary">등록된 질문이 없습니다.</p>
                </div>
                {{/qnas}}
            </div>

            <!-- Pagination -->
            {{#pagination}}
            <div class="d-flex justify-content-center gap-2 mt-5">
                {{#hasPrev}}
                <a href="/qna?status={{status}}&page={{prevPage}}" class="btn btn-icon border border-secondary border-opacity-10 btn-light bg-white rounded-3">
                    <span class="material-symbols-outlined fs-6">chevron_left</span>
                </a>
                {{/hasPrev}}
                {{^hasPrev}}
                <button class="btn btn-icon border border-secondary border-opacity-10 btn-light bg-white rounded-3 opacity-50 cursor-not-allowed" disabled>
                    <span class="material-symbols-outlined fs-6">chevron_left</span>
                </button>
                {{/hasPrev}}

                {{#pageNumbers}}
                <a href="/qna?status={{status}}&page={{number}}" 
                   class="btn {{#isCurrent}}btn-primary{{/isCurrent}}{{^isCurrent}}btn-light bg-white border border-secondary border-opacity-10 text-secondary{{/isCurrent}} px-3 py-1.5 small fw-bold rounded-3">
                   {{displayDigit}}
                </a>
                {{/pageNumbers}}

                {{#hasNext}}
                <a href="/qna?status={{status}}&page={{nextPage}}" class="btn btn-icon border border-secondary border-opacity-10 btn-light bg-white rounded-3">
                    <span class="material-symbols-outlined fs-6">chevron_right</span>
                </a>
                {{/hasNext}}
                {{^hasNext}}
                <button class="btn btn-icon border border-secondary border-opacity-10 btn-light bg-white rounded-3 opacity-50 cursor-not-allowed" disabled>
                    <span class="material-symbols-outlined fs-6">chevron_right</span>
                </button>
                {{/hasNext}}
            </div>
            {{/pagination}}
        </main>

{{> layout/footer}}
