{{> layout/header}}

        <main class="container py-5" style="max-width: 800px; margin: 0 auto;">
            <div class="mb-5 px-2">
                <h2 class="display-5 fw-black text-dark mb-2">질문하기</h2>
                <p class="text-secondary fw-medium fs-5 opacity-75">포레스트 헤이븐에 대해 궁금한 점을 남겨주세요. 운영진이 확인 후 답변해 드립니다.</p>
            </div>

            <div class="fh-card shadow-sm border-0 p-4 p-md-5 bg-white rounded-4">
                <form action="/qna/save" method="post">
                    <!-- Category -->
                    <div class="mb-4">
                        <label class="form-label form-label-bold small mb-2">카테고리 선택</label>
                        <select name="category" class="form-select py-3 bg-input-soft shadow-none rounded-3" required>
                            <option disabled selected value="">문의 유형을 선택해 주세요</option>
                            <option value="RESERVATION">예약문의</option>
                            <option value="FACILITY">시설문의</option>
                            <option value="ETC">기타</option>
                        </select>
                    </div>

                    <!-- Title -->
                    <div class="mb-4">
                        <label class="form-label form-label-bold small mb-2">제목</label>
                        <input type="text" name="title" class="form-control py-3 bg-input-soft shadow-none rounded-3" placeholder="제목을 입력해 주세요" required>
                    </div>

                    <!-- Editor -->
                    <div class="mb-5">
                        <label class="form-label form-label-bold small mb-2">내용</label>
                        <div class="fh-editor-container border-light-subtle rounded-3 overflow-hidden">
                            <div class="fh-editor-toolbar bg-light bg-opacity-50 py-2">
                                <button type="button" class="btn btn-icon btn-sm"><span class="material-symbols-outlined fs-6">format_bold</span></button>
                                <button type="button" class="btn btn-icon btn-sm"><span class="material-symbols-outlined fs-6">format_italic</span></button>
                                <button type="button" class="btn btn-icon btn-sm"><span class="material-symbols-outlined fs-6">format_underlined</span></button>
                                <div class="vr mx-2 opacity-10"></div>
                                <button type="button" class="btn btn-icon btn-sm"><span class="material-symbols-outlined fs-6">format_list_bulleted</span></button>
                                <button type="button" class="btn btn-icon btn-sm"><span class="material-symbols-outlined fs-6">link</span></button>
                            </div>
                            <textarea name="content" class="fh-editor-content bg-input-soft editor-min-height border-0" placeholder="내용을 입력해 주세요" required></textarea>
                        </div>
                    </div>

                    <!-- Image Upload -->
                    <div class="mb-5">
                        <label class="form-label form-label-bold small mb-3">이미지 첨부 (선택)</label>
                        <input type="file" id="imageInput" name="images" multiple accept="image/*" style="display: none;">
                        <div class="question-upload-zone shadow-sm border-light-subtle" id="uploadZone">
                            <span class="material-symbols-outlined text-secondary fs-1 mb-2 opacity-25">add_photo_alternate</span>
                            <p class="text-dark small fw-bold mb-1">이미지를 드래그하거나 클릭하여 업로드하세요</p>
                            <p class="text-secondary text-xxs">최대 3장, 각 5MB 이하 (JPG, PNG)</p>
                            <div id="fileList" class="mt-3 text-start small text-primary fw-bold"></div>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="row g-3">
                        <div class="col-8">
                            <button type="submit" class="btn btn-primary w-100 py-3.5 fw-bold shadow-lg border-0 rounded-3">등록하기</button>
                        </div>
                        <div class="col-4">
                            <button type="button" onclick="history.back()" class="btn btn-cancel-hover w-100 py-3.5 fw-bold rounded-3">취소</button>
                        </div>
                    </div>
                </form>
            </div>
        </main>

        <script>
            const uploadZone = document.getElementById('uploadZone');
            const imageInput = document.getElementById('imageInput');
            const fileList = document.getElementById('fileList');

            uploadZone.addEventListener('click', () => {
                imageInput.click();
            });

            imageInput.addEventListener('change', (e) => {
                const files = e.target.files;
                fileList.innerHTML = '';
                if (files.length > 0) {
                    const list = document.createElement('ul');
                    list.className = 'list-unstyled m-0';
                    for (let i = 0; i < Math.min(files.length, 3); i++) {
                        const item = document.createElement('li');
                        item.className = 'd-flex align-items-center gap-2 mb-1';
                        item.innerHTML = `<span class="material-symbols-outlined fs-6">image</span> ${files[i].name}`;
                        list.appendChild(item);
                    }
                    if (files.length > 3) {
                        const warning = document.createElement('li');
                        warning.className = 'text-danger x-small';
                        warning.innerText = '* 최대 3장까지만 업로드 가능합니다.';
                        list.appendChild(warning);
                    }
                    fileList.appendChild(list);
                }
            });

            // 드래그 앤 드롭 기능 추가
            uploadZone.addEventListener('dragover', (e) => {
                e.preventDefault();
                uploadZone.classList.add('bg-primary', 'bg-opacity-10');
            });

            uploadZone.addEventListener('dragleave', () => {
                uploadZone.classList.remove('bg-primary', 'bg-opacity-10');
            });

            uploadZone.addEventListener('drop', (e) => {
                e.preventDefault();
                uploadZone.classList.remove('bg-primary', 'bg-opacity-10');
                imageInput.files = e.dataTransfer.files;
                imageInput.dispatchEvent(new Event('change'));
            });
        </script>

        <!-- Floating Chatbot -->
        <div class="position-fixed bottom-0 end-0 p-4 floating-container">
            <button class="btn btn-primary rounded-circle shadow-lg d-flex align-items-center justify-content-center btn-floating-chat">
                <span class="material-symbols-outlined fs-2">smart_toy</span>
            </button>
        </div>
{{> layout/footer}}
