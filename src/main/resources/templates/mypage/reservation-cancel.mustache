{{> layout/header}}

<div class="container py-5">
    <div class="row g-4">
        <!-- Sidebar Navigation -->
        <aside class="col-lg-3">
            <div class="fh-card p-4 mb-4">
                <div class="fh-profile-card">
                    <div class="profile-section">
                        <div class="profile-img">
                            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuArVyFD1kByWmCBF0Rz4ccl-L4vIMovS-krTT4u-KVYHhX2hMPUkaQzOLuSXFNkjKwDG0hbQZ7gaRgh8ytv6BK6xFB6ClZmg6H-wq586rl1mmMaOrnlkhWvj-w0KNrgyc3qLGo11qHIdPwOfdKeuTDw6OltxRnbG17NoLNHNk1YZI1Li_g3-PSh5baMbRafh3KgP2jo5_izMzuKYzAJm9zDtUrAJHJSePSvnmDcctJdXnbujZtx4x7j3Nub2X0XNELdrx0zZBwepMns" alt="Profile">
                        </div>
                        <div class="profile-info">
                            <h3>{{user.name}} 님</h3>
                            <p>{{user.role}} Member</p>
                        </div>
                    </div>
                </div>
                <nav class="fh-sidebar-nav">
                    <a href="/mypage" class="nav-item">
                        <span class="material-symbols-outlined">home</span>
                        <span>홈</span>
                    </a>
                    <a href="/mypage/info" class="nav-item">
                        <span class="material-symbols-outlined">person</span>
                        <span>회원 정보</span>
                    </a>
                    <a href="/mypage/reservations" class="nav-item active">
                        <span class="material-symbols-outlined">calendar_today</span>
                        <span>예약 내역</span>
                    </a>
                    <a href="/mypage/reviews" class="nav-item">
                        <span class="material-symbols-outlined">rate_review</span>
                        <span>내가 적은 리뷰</span>
                    </a>
                </nav>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="col-lg-9">
            <section class="mb-5 px-2">
                <h1 class="display-6 fw-bold text-dark">예약 취소 요청</h1>
                <p class="text-secondary fw-medium italic">불가피한 사정으로 예약을 취소하실 경우 안전하게 접수해 드립니다.</p>
            </section>

            <!-- Existing Reservation Info (change.mustache 스타일 적용) -->
            <section class="mb-5">
                <div class="fh-card p-0 overflow-hidden shadow-sm">
                    <div class="bg-primary bg-opacity-10 px-4 py-3 border-bottom border-primary border-opacity-10">
                        <h3 class="h6 fw-bold text-primary m-0">취소 대상 예약 정보</h3>
                    </div>
                    <div class="p-4 d-flex flex-column flex-sm-row gap-4 align-items-center align-items-sm-start">
                        <img src="{{reservation.siteImage}}" alt="Reservation Preview" class="reservation-preview-img shadow-sm" style="width: 12rem; height: 8rem; object-fit: cover; border-radius: 12px;">
                        <div class="flex-grow-1">
                            <span class="badge bg-primary bg-opacity-10 text-primary fw-bold px-3 py-2 mb-2">RESERV-{{reservation.id}}</span>
                            <h4 class="h4 fw-bold mb-2">{{reservation.siteName}} ({{reservation.zoneName}})</h4>
                            <div class="d-flex flex-column gap-2 text-secondary small">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="material-symbols-outlined fs-6 text-primary">calendar_today</span>
                                    <span class="fw-medium">{{reservation.checkIn}} ~ {{reservation.checkOut}} ({{reservation.nights}}박)</span>
                                </div>
                                <div class="d-flex align-items-center justify-content-between pt-1">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="material-symbols-outlined fs-6 text-primary">payments</span>
                                        <span class="fw-medium">총 결제금액:</span>
                                    </div>
                                    <span class="fs-5 fw-bold text-dark">{{reservation.totalPrice}}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Cancel Request Form (change.mustache 스타일 적용) -->
            <section>
                <form action="/mypage/reservations/{{reservation.id}}/cancel-request" method="POST" id="cancelRequestForm" class="fh-card shadow-sm p-4 needs-validation" novalidate>
                    <div class="mb-4">
                        <label class="form-label fw-bold text-dark small mb-2 d-flex align-items-center gap-1">
                            <span class="material-symbols-outlined fs-5">help</span>
                            취소 사유
                        </label>
                        <textarea name="reason" class="form-control py-2.5 shadow-none border-secondary border-opacity-25" rows="3" placeholder="취소 사유를 구체적으로 입력해주세요." required></textarea>
                        <div class="form-text small">작성해주신 사유는 관리자 확인 후 취소 승인 여부 결정에 참고됩니다.</div>
                    </div>

                    <!-- 환불 계좌 정보 (기존 폼 레이아웃 유지하며 스타일만 조정) -->
                    <div class="bg-light bg-opacity-50 rounded-4 p-4 mb-4 border border-secondary border-opacity-10">
                        <h5 class="fw-bold mb-3 d-flex align-items-center gap-2 small text-uppercase tracking-wider">
                            <span class="material-symbols-outlined text-primary fs-5">account_balance_wallet</span>
                            환불 계좌 정보
                        </h5>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-secondary mb-1">은행명</label>
                                <input type="text" name="refundBank" class="form-control py-2 shadow-none border-secondary border-opacity-25" placeholder="예: 국민은행" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-secondary mb-1">계좌번호</label>
                                <input type="text" name="refundAccount" class="form-control py-2 shadow-none border-secondary border-opacity-25" placeholder="'-' 제외하고 입력" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-secondary mb-1">예금주</label>
                                <input type="text" name="refundAccountHolder" class="form-control py-2 shadow-none border-secondary border-opacity-25" placeholder="성함" required>
                            </div>
                        </div>
                    </div>

                    <!-- 안내 사항 (change.mustache의 info-banner 스타일 적용) -->
                    <div class="info-banner d-flex gap-3 p-4 mb-5 border-dashed">
                        <span class="material-symbols-outlined text-warning fs-4">warning</span>
                        <div class="small leading-relaxed">
                            <p class="fw-bold text-warning mb-1">취소 전 유의사항</p>
                            <ul class="mb-0 ps-3 text-secondary">
                                <li class="mb-1">이용일 3일 전까지만 온라인 취소 요청이 가능하며, 이후에는 고객센터를 통해서만 가능합니다.</li>
                                <li class="mb-1">관리자의 최종 승인 후 취소가 완료되며, 환불까지 최대 3~7일이 소요될 수 있습니다.</li>
                                <li>취소 시점에 따라 <strong>위약금(최대 100%)</strong>이 발생할 수 있습니다.</li>
                            </ul>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-6">
                            <button type="submit" class="btn btn-danger w-100 py-3 shadow-sm fw-bold">취소 요청하기</button>
                        </div>
                        <div class="col-6">
                            <a href="/mypage/reservations" class="btn btn-light bg-secondary bg-opacity-10 text-secondary w-100 py-3 fw-bold border-0 shadow-sm text-center">목록으로</a>
                        </div>
                    </div>
                </form>
            </section>
        </main>
    </div>
</div>

<style>
.border-dashed { border: 2px dashed #dee2e6; }
.info-banner { background-color: #fff9f0; border-radius: 12px; }
.reservation-preview-img { border-radius: 12px; }
</style>

{{> layout/footer}}
