{{> layout/header}}

<div class="container py-5">
    <div class="row g-4">
        <!-- 1. Sidebar Navigation (3칸) -->
        <aside class="col-lg-3">
            <div class="fh-card p-4 mb-4">
                <div class="fh-profile-card">
                    <div class="profile-section">
                        <div class="profile-img">
                            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuArVyFD1kByWmCBF0Rz4ccl-L4vIMovS-krTT4u-KVYHhX2hMPUkaQzOLuSXFNkjKwDG0hbQZ7gaRgh8ytv6BK6xFB6ClZmg6H-wq586rl1mmMaOrnlkhWvj-w0KNrgyc3qLGo11qHIdPwOfdKeuTDw6OltxRnbG17NoLNHNk1YZI1Li_g3-PSh5baMbRafh3KgP2jo5_izMzuKYzAJm9zDtUrAJHJSePSvnmDcctJdXnbujZtx4x7j3Nub2X0XNELdrx0zZBwepMns" alt="Profile">
                        </div>
                        <div class="profile-info">
                            <h3>{{user.name}} 님</h3>
                            <p>{{user.role}} Member</p>
                        </div>
                    </div>
                </div>
                <nav class="fh-sidebar-nav">
                    <a href="/mypage" class="nav-item">
                        <span class="material-symbols-outlined">home</span>
                        <span>홈</span>
                    </a>
                    <a href="/mypage/info" class="nav-item active">
                        <span class="material-symbols-outlined">person</span>
                        <span>회원 정보</span>
                    </a>
                    <a href="/mypage/reservations" class="nav-item">
                        <span class="material-symbols-outlined">calendar_today</span>
                        <span>예약 내역</span>
                    </a>
                    <a href="/mypage/reviews" class="nav-item">
                        <span class="material-symbols-outlined">rate_review</span>
                        <span>내가 적은 리뷰</span>
                    </a>
                </nav>
            </div>
        </aside>

        <!-- 2. Main Content Area (9칸) -->
        <main class="col-lg-9">
            <!-- Title Section -->
            <section class="mb-5 px-2">
                <h1 class="display-6 fw-bold text-dark mb-2">회원 정보</h1>
                <p class="text-secondary fw-medium m-0">Forest Haven의 회원 정보를 확인하고 관리할 수 있습니다.</p>
            </section>

            <!-- 8:4 구조를 위한 내부 Row -->
            <div class="row g-4">
                <!-- [왼쪽 8칸] 기본 정보 카드 -->
                <div class="col-lg-8">
                    <div class="fh-card p-4 p-md-5 shadow-sm bg-white border-0 rounded-4">
                        <div class="row g-4">
                            <!-- Username -->
                            <div class="col-md-6">
                                <div class="p-3 rounded-3 bg-light bg-opacity-50">
                                    <label class="form-label small fw-bold text-muted text-uppercase mb-1">아이디</label>
                                    <div class="fw-bold text-dark">{{user.username}}</div>
                                </div>
                            </div>
                            <!-- Name -->
                            <div class="col-md-6">
                                <div class="p-3 rounded-3 bg-light bg-opacity-50">
                                    <label class="form-label small fw-bold text-muted text-uppercase mb-1">이름</label>
                                    <div class="fw-bold text-dark">{{user.name}}</div>
                                </div>
                            </div>
                            <!-- Role -->
                            <div class="col-12">
                                <div class="p-3 rounded-3 bg-light bg-opacity-50">
                                    <label class="form-label small fw-bold text-muted text-uppercase mb-1">회원 등급</label>
                                    <div class="d-flex align-items-center gap-2 mt-1">
                                        <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 fw-bold rounded-pill">
                                            {{user.role}} Member
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="my-5 border-dashed opacity-25">

                        <!-- Actions -->
                        <div class="d-flex flex-column flex-sm-row gap-3">
                            <a href="/mypage/info-update-form" class="btn btn-primary px-4 py-3 shadow-sm fw-bold flex-grow-1 flex-sm-grow-0 rounded-3 border-0">
                                정보 수정하기
                            </a>
                            <a href="/mypage" class="btn btn-outline-fh px-4 py-3 fw-bold rounded-3">
                                돌아가기
                            </a>
                        </div>
                    </div>
                </div>

                <!-- [오른쪽 4칸] 계정 추가 정보 -->
                <div class="col-lg-4">
                    <div class="fh-card p-4 shadow-sm bg-white border-0 rounded-4 h-100">
                        <h3 class="h6 fw-bold text-dark mb-4">계정 추가 정보</h3>
                        <div class="d-flex flex-column gap-3">
                            <div class="p-3 rounded-3 bg-light bg-opacity-50">
                                <p class="text-xxs fw-bold text-secondary text-uppercase tracking-wider mb-2">연락처</p>
                                <p class="small fw-bold text-dark m-0">{{user.phone}}</p>
                            </div>
                            <div class="p-3 rounded-3 bg-light bg-opacity-50">
                                <p class="text-xxs fw-bold text-secondary text-uppercase tracking-wider mb-2">이메일</p>
                                <p class="small fw-bold text-dark m-0">{{user.email}}</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div> <!-- 내부 row 끝 -->
        </main> <!-- col-lg-9 끝 -->
    </div> <!-- 메인 row 끝 -->
</div> <!-- container 끝 -->

{{> layout/footer}}
