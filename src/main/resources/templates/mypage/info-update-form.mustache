{{> layout/header}}

<div class="container py-5">
    <div class="row g-4">
        <!-- Sidebar Navigation -->
        <aside class="col-lg-3">
            <div class="fh-card p-4 mb-4">
                <div class="fh-profile-card">
                    <div class="profile-section">
                        <div class="profile-img">
                            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuArVyFD1kByWmCBF0Rz4ccl-L4vIMovS-krTT4u-KVYHhX2hMPUkaQzOLuSXFNkjKwDG0hbQZ7gaRgh8ytv6BK6xFB6ClZmg6H-wq586rl1mmMaOrnlkhWvj-w0KNrgyc3qLGo11qHIdPwOfdKeuTDw6OltxRnbG17NoLNHNk1YZI1Li_g3-PSh5baMbRafh3KgP2jo5_izMzuKYzAJm9zDtUrAJHJSePSvnmDcctJdXnbujZtx4x7j3Nub2X0XNELdrx0zZBwepMns" alt="Profile">
                        </div>
                        <div class="profile-info">
                            <h3>{{user.name}} 님</h3>
                            <p>{{user.role}} Member</p>
                        </div>
                    </div>
                </div>
                <nav class="fh-sidebar-nav">
                    <a href="/mypage" class="nav-item">
                        <span class="material-symbols-outlined">home</span>
                        <span>홈</span>
                    </a>
                    <a href="/mypage/info" class="nav-item active">
                        <span class="material-symbols-outlined">person</span>
                        <span>회원 정보</span>
                    </a>
                    <a href="/mypage/reservations" class="nav-item">
                        <span class="material-symbols-outlined">calendar_today</span>
                        <span>예약 내역</span>
                    </a>
                    <a href="/mypage/reviews" class="nav-item">
                        <span class="material-symbols-outlined">rate_review</span>
                        <span>내가 적은 리뷰</span>
                    </a>
                </nav>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="col-lg-9">
            <!-- Title Section -->
            <section class="mb-5 px-2">
                <h1 class="display-6 fw-bold text-dark">정보 수정하기</h1>
                <p class="text-secondary fw-medium">안전한 정보 관리를 위해 현재 비밀번호를 입력해 주세요.</p>
            </section>

            <!-- Update Form Card -->
            <div class="fh-card p-4 p-md-5 shadow-sm">
                <form action="/mypage/info-update" method="post">
                    <div class="row g-4">
                        <!-- Username (Readonly) -->
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted text-uppercase mb-1">아이디</label>
                            <input type="text" class="form-control form-control-lg bg-light" value="{{user.username}}" readonly>
                            <div class="form-text small">아이디는 변경할 수 없습니다.</div>
                        </div>

                        <!-- Name -->
                        <div class="col-md-6">
                            <label for="name" class="form-label small fw-bold text-muted text-uppercase mb-1">이름</label>
                            <input type="text" id="name" name="name" class="form-control form-control-lg" value="{{user.name}}" required>
                        </div>

                        <!-- Email -->
                        <div class="col-md-6">
                            <label for="email" class="form-label small fw-bold text-muted text-uppercase mb-1">이메일</label>
                            <input type="email" id="email" name="email" class="form-control form-control-lg" value="{{user.email}}" required>
                        </div>

                        <!-- Phone -->
                        <div class="col-md-6">
                            <label for="phone" class="form-label small fw-bold text-muted text-uppercase mb-1">전화번호</label>
                            <input type="tel" id="phone" name="phone" class="form-control form-control-lg" value="{{user.phone}}" required>
                        </div>

                        <hr class="my-4 border-dashed opacity-25">

                        <!-- Current Password (Required) -->
                        <div class="col-12">
                            <div class="alert alert-warning border-0 bg-opacity-10 bg-warning p-3 rounded-3 mb-4">
                                <div class="d-flex gap-2 text-warning-emphasis">
                                    <span class="material-symbols-outlined fs-5">lock</span>
                                    <span class="small fw-bold">정보 수정을 위해 현재 비밀번호를 입력해 주세요.</span>
                                </div>
                            </div>
                            <label for="currentPassword" class="form-label small fw-bold text-muted text-uppercase mb-1">현재 비밀번호</label>
                            <input type="password" id="currentPassword" name="currentPassword" class="form-control form-control-lg" placeholder="현재 비밀번호 입력" required>
                        </div>

                        <!-- New Password (Optional) -->
                        <div class="col-md-6">
                            <label for="newPassword" class="form-label small fw-bold text-muted text-uppercase mb-1">새 비밀번호 (선택)</label>
                            <input type="password" id="newPassword" name="newPassword" class="form-control form-control-lg" placeholder="변경할 비밀번호">
                        </div>

                        <!-- New Password Confirm -->
                        <div class="col-md-6">
                            <label for="newPasswordConfirm" class="form-label small fw-bold text-muted text-uppercase mb-1">새 비밀번호 확인</label>
                            <input type="password" id="newPasswordConfirm" name="newPasswordConfirm" class="form-control form-control-lg" placeholder="비밀번호 재입력">
                        </div>
                    </div>

                    <div class="d-flex flex-column flex-sm-row gap-3 mt-5">
                        <button type="submit" class="btn btn-primary px-5 py-3 shadow-sm fw-bold flex-grow-1 flex-sm-grow-0">
                            저장하기
                        </button>
                        <button type="button" class="btn btn-outline-fh px-5 py-3 fw-bold" onclick="history.back()">
                            취소하기
                        </button>
                    </div>
                </form>
            </div>
        </main>
    </div>
</div>

{{> layout/footer}}
