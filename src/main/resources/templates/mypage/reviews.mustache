{{> layout/header}}

        <div class="container py-5">
            <div class="row g-4">
                <!-- Sidebar Navigation -->
                <aside class="col-lg-3">
                    <div class="fh-card p-4 mb-4">
                        <div class="fh-profile-card">
                            <div class="profile-section">
                                <div class="profile-img">
                                    <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuArVyFD1kByWmCBF0Rz4ccl-L4vIMovS-krTT4u-KVYHhX2hMPUkaQzOLuSXFNkjKwDG0hbQZ7gaRgh8ytv6BK6xFB6ClZmg6H-wq586rl1mmMaOrnlkhWvj-w0KNrgyc3qLGo11qHIdPwOfdKeuTDw6OltxRnbG17NoLNHNk1YZI1Li_g3-PSh5baMbRafh3KgP2jo5_izMzuKYzAJm9zDtUrAJHJSePSvnmDcctJdXnbujZtx4x7j3Nub2X0XNELdrx0zZBwepMns" alt="Profile">
                                </div>
                                <div class="profile-info">
                                    <h3>김철수 님</h3>
                                    <p>Forest Member</p>
                                </div>
                            </div>
                        </div>
                        <nav class="fh-sidebar-nav">
                            <a href="/mypage" class="nav-item">
                                <span class="material-symbols-outlined">home</span>
                                <span>홈</span>
                            </a>
                            <a href="/mypage/info" class="nav-item">
                                <span class="material-symbols-outlined">person</span>
                                <span>회원 정보</span>
                            </a>
                            <a href="/mypage/reservations" class="nav-item">
                                <span class="material-symbols-outlined">calendar_today</span>
                                <span>예약 내역</span>
                            </a>
                            <a href="/mypage/reviews" class="nav-item active">
                                <span class="material-symbols-outlined">rate_review</span>
                                <span>내가 적은 리뷰</span>
                            </a>
                        </nav>
                    </div>
                </aside>

                <!-- Main Content Area -->
                <main class="col-lg-9">
                    <!-- Title + Tabs -->
                    <section class="mb-4 pb-3 border-bottom">
                        <div class="d-flex align-items-end justify-content-between">
                            <div>
                                <h1 class="display-6 fw-bold text-dark">내가 적은 리뷰</h1>
                                <p class="text-secondary fw-medium mb-0">작성하신 소중한 리뷰들을 모아볼 수 있습니다.</p>
                            </div>
                            <div class="d-flex gap-3 small fw-bold">
                                <button class="border-0 bg-transparent border-bottom border-2 border-primary pb-2 text-primary">리뷰 (12)</button>
                                <button class="border-0 bg-transparent pb-2 text-secondary">Q&A (5)</button>
                            </div>
                        </div>
                    </section>

                    <!-- Review List -->
                    <div class="d-flex flex-column gap-4">

                        <!-- Review Item 1 -->
                        <div class="fh-card p-4 shadow-sm">
                            <div class="d-flex flex-column flex-sm-row gap-4">
                                <div class="flex-shrink-0 rounded-3 overflow-hidden" style="width: 6rem; height: 6rem;">
                                    <img src="https://placeholder.pics/svg/300" alt="Review" class="w-100 h-100 object-fit-cover">
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center justify-content-between mb-1">
                                        <span class="small fw-semibold text-uppercase text-primary">4인용 프리미엄 블랙 텐트</span>
                                        <div class="d-flex align-items-center gap-0 text-warning">
                                            <span class="material-symbols-outlined small">star</span>
                                            <span class="material-symbols-outlined small">star</span>
                                            <span class="material-symbols-outlined small">star</span>
                                            <span class="material-symbols-outlined small">star</span>
                                            <span class="material-symbols-outlined small">star</span>
                                        </div>
                                    </div>
                                    <h4 class="fw-bold mb-2">배송도 빠르고 상품이 아주 마음에 듭니다!</h4>
                                    <p class="small text-secondary mb-3">디자인이 사진보다 실물이 훨씬 예뻐요. 착용감도 너무 푹신하고 좋습니다. 런닝할 때 발목을 잘 잡아주는 느낌이라 아주 만족합니다. 친구들에게도 추천했어요!</p>
                                    <div class="d-flex align-items-center justify-content-between pt-2 border-top">
                                        <span class="small text-secondary">2023.11.15 작성됨</span>
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1">
                                                <span class="material-symbols-outlined fs-6">edit_note</span>
                                                수정
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1">
                                                <span class="material-symbols-outlined fs-6">delete</span>
                                                삭제
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Review Item 2 -->
                        <div class="fh-card p-4 shadow-sm">
                            <div class="d-flex flex-column flex-sm-row gap-4">
                                <div class="flex-shrink-0 rounded-3 overflow-hidden" style="width: 6rem; height: 6rem;">
                                    <img src="https://placeholder.pics/svg/300" alt="Review" class="w-100 h-100 object-fit-cover">
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center justify-content-between mb-1">
                                        <span class="small fw-semibold text-uppercase text-primary">4인용 프리미엄 블랙 텐트</span>
                                        <div class="d-flex align-items-center gap-0 text-warning">
                                            <span class="material-symbols-outlined small">star</span>
                                            <span class="material-symbols-outlined small">star</span>
                                            <span class="material-symbols-outlined small">star</span>
                                            <span class="material-symbols-outlined small">star</span>
                                            <span class="material-symbols-outlined small text-secondary">star</span>
                                        </div>
                                    </div>
                                    <h4 class="fw-bold mb-2">가죽 질감이 부드럽고 수납공간이 넉넉해요</h4>
                                    <p class="small text-secondary mb-3">데일리로 들기 너무 좋습니다. 가방이 생각보다 가벼워서 어깨에 무리가 덜 가네요. 다만 색상이 화면보다는 약간 어두운 베이지 느낌입니다.</p>
                                    <div class="d-flex align-items-center justify-content-between pt-2 border-top">
                                        <span class="small text-secondary">2023.10.28 작성됨</span>
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1">
                                                <span class="material-symbols-outlined fs-6">edit_note</span>
                                                수정
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1">
                                                <span class="material-symbols-outlined fs-6">delete</span>
                                                삭제
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Review Item 3 (No Image) -->
                        <div class="fh-card p-4 shadow-sm">
                            <div class="d-flex flex-column gap-4">
                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center justify-content-between mb-1">
                                        <span class="small fw-semibold text-uppercase text-primary">4인용 프리미엄 블랙 텐트</span>
                                        <div class="d-flex align-items-center gap-0 text-warning">
                                            <span class="material-symbols-outlined small">star</span>
                                            <span class="material-symbols-outlined small">star</span>
                                            <span class="material-symbols-outlined small text-secondary">star</span>
                                            <span class="material-symbols-outlined small text-secondary">star</span>
                                            <span class="material-symbols-outlined small text-secondary">star</span>
                                        </div>
                                    </div>
                                    <h4 class="fw-bold mb-2">사이즈가 조금 작게 나온 것 같아요</h4>
                                    <p class="small text-secondary mb-3">재질은 정말 부드럽고 좋은데, 평소 L 입으시는 분들은 XL 사야할 것 같습니다. 교환하기 귀찮아서 그냥 입으려구요.</p>
                                    <div class="d-flex align-items-center justify-content-between pt-2 border-top">
                                        <span class="small text-secondary">2023.09.12 작성됨</span>
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1">
                                                <span class="material-symbols-outlined fs-6">edit_note</span>
                                                수정
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1">
                                                <span class="material-symbols-outlined fs-6">delete</span>
                                                삭제
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- Pagination -->
                    <nav class="d-flex justify-content-center py-4 mt-3">
                        <ul class="pagination gap-2 mb-0">
                            <li class="page-item">
                                <button class="btn btn-outline-secondary btn-sm d-flex align-items-center justify-content-center" style="width: 2.5rem; height: 2.5rem;">
                                    <span class="material-symbols-outlined">chevron_left</span>
                                </button>
                            </li>
                            <li class="page-item">
                                <button class="btn btn-primary btn-sm fw-bold" style="width: 2.5rem; height: 2.5rem;">1</button>
                            </li>
                            <li class="page-item">
                                <button class="btn btn-outline-secondary btn-sm" style="width: 2.5rem; height: 2.5rem;">2</button>
                            </li>
                            <li class="page-item">
                                <button class="btn btn-outline-secondary btn-sm" style="width: 2.5rem; height: 2.5rem;">3</button>
                            </li>
                            <li class="page-item">
                                <button class="btn btn-outline-secondary btn-sm d-flex align-items-center justify-content-center" style="width: 2.5rem; height: 2.5rem;">
                                    <span class="material-symbols-outlined">chevron_right</span>
                                </button>
                            </li>
                        </ul>
                    </nav>
                </main>
            </div>
        </div>

{{> layout/footer}}