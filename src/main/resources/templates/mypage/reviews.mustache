{{> layout/header}}

<div class="container py-5">
    <div class="row g-4">
        <!-- Sidebar Navigation -->
        <aside class="col-lg-3">
            <div class="fh-card p-4 mb-4">
                <div class="fh-profile-card">
                    <div class="profile-section">
                        <div class="profile-img">
                            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuArVyFD1kByWmCBF0Rz4ccl-L4vIMovS-krTT4u-KVYHhX2hMPUkaQzOLuSXFNkjKwDG0hbQZ7gaRgh8ytv6BK6xFB6ClZmg6H-wq586rl1mmMaOrnlkhWvj-w0KNrgyc3qLGo11qHIdPwOfdKeuTDw6OltxRnbG17NoLNHNk1YZI1Li_g3-PSh5baMbRafh3KgP2jo5_izMzuKYzAJm9zDtUrAJHJSePSvnmDcctJdXnbujZtx4x7j3Nub2X0XNELdrx0zZBwepMns" alt="Profile">
                        </div>
                        <div class="profile-info">
                            <h3>{{user.name}} 님</h3>
                            <p>{{user.role}} Member</p>
                        </div>
                    </div>
                </div>
                <nav class="fh-sidebar-nav">
                    <a href="/mypage" class="nav-item">
                        <span class="material-symbols-outlined">home</span>
                        <span>홈</span>
                    </a>
                    <a href="/mypage/info" class="nav-item">
                        <span class="material-symbols-outlined">person</span>
                        <span>회원 정보</span>
                    </a>
                    <a href="/mypage/reservations" class="nav-item">
                        <span class="material-symbols-outlined">calendar_today</span>
                        <span>예약 내역</span>
                    </a>
                    <a href="/mypage/reviews" class="nav-item active">
                        <span class="material-symbols-outlined">rate_review</span>
                        <span>내가 적은 리뷰</span>
                    </a>
                </nav>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="col-lg-9">
            <!-- Title Section -->
            <section class="mb-5 px-2 d-flex justify-content-between align-items-end">
                <div>
                    <h1 class="display-6 fw-bold text-dark mb-2">내가 적은 리뷰</h1>
                    <p class="text-secondary fw-medium m-0">작성하신 소중한 리뷰들을 모아볼 수 있습니다.</p>
                </div>
                <span class="badge bg-primary rounded-pill px-3 py-2 fw-bold shadow-sm">{{reviews.size}}개의 리뷰</span>
            </section>

            <!-- Review List -->
            <div class="d-flex flex-column gap-4">
                {{#reviews}}
                <div class="fh-card p-4 shadow-sm border-0 {{#isDeleted}}bg-light opacity-75{{/isDeleted}}{{^isDeleted}}bg-white{{/isDeleted}} rounded-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h4 class="fw-bold text-dark mb-1">{{siteName}} ({{zoneName}})</h4>
                            <div class="d-flex align-items-center gap-2">
                                <div class="rating-stars d-flex">
                                    {{#stars}}
                                    <span class="material-symbols-outlined icon-fill-1 fs-6 {{#active}}text-warning{{/active}}{{^active}}text-secondary opacity-25{{/active}}">star</span>
                                    {{/stars}}
                                </div>
                                <span class="text-secondary small fw-bold">{{createdAt}}</span>
                                {{#isDeleted}}
                                <span class="badge bg-danger bg-opacity-10 text-danger fw-bold rounded-pill text-xs ms-2">삭제됨</span>
                                {{/isDeleted}}
                            </div>
                        </div>
                        {{^isDeleted}}
                        <div class="d-flex gap-2">
                            <a href="/reviews/{{id}}/edit" class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1 px-3">
                                <span class="material-symbols-outlined fs-6">edit_note</span>
                                수정
                            </a>
                            <form action="/reviews/{{id}}/delete" method="post" onsubmit="return confirm('정말 삭제하시겠습니까?');" style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1 px-3">
                                    <span class="material-symbols-outlined fs-6">delete</span>
                                    삭제
                                </button>
                            </form>
                        </div>
                        {{/isDeleted}}
                    </div>
                    
                    {{#isDeleted}}
                    <div class="alert alert-danger border-0 bg-danger bg-opacity-10 rounded-3 mb-3 p-3">
                        <div class="d-flex align-items-center gap-2 text-danger fw-bold mb-1">
                            <span class="material-symbols-outlined fs-5">warning</span>
                            <span>관리자에 의해 삭제되었습니다.</span>
                        </div>
                        <p class="small m-0 text-danger opacity-75">사유: {{adminReason}}</p>
                    </div>
                    {{/isDeleted}}

                    <p class="text-secondary mb-3 {{#isDeleted}}text-decoration-line-through opacity-50{{/isDeleted}}" style="white-space: pre-wrap;">{{content}}</p>
                    
                    {{#images.size}}
                    <div class="d-flex gap-2 mt-2 overflow-auto pb-2">
                        {{#images}}
                        <img src="/upload/{{fileName}}" class="rounded-3 shadow-sm" style="width: 100px; height: 100px; object-fit: cover;">
                        {{/images}}
                    </div>
                    {{/images.size}}
                </div>
                {{/reviews}}

                {{^reviews}}
                <div class="fh-card p-5 text-center shadow-sm rounded-4 bg-white border-0">
                    <span class="material-symbols-outlined fs-1 text-secondary mb-3 opacity-25">rate_review</span>
                    <h4 class="fw-bold text-secondary">작성한 리뷰가 없습니다.</h4>
                    <p class="text-muted">캠핑을 마친 후 소중한 후기를 남겨주세요!</p>
                    <a href="/mypage/reservations" class="btn btn-primary mt-3 px-4 py-2 fw-bold shadow-sm border-0 rounded-3">예약 내역 보러가기</a>
                </div>
                {{/reviews}}
            </div>

            <!-- Pagination (Optional: If needed later) -->
            <!-- 현재는 전체 목록 출력 방식이므로 주석 처리하거나 필요 시 구현 -->
        </main>
    </div>
</div>

{{> layout/footer}}
