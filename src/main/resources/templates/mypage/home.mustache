{{> layout/header}}

<div class="container py-5">
    <div class="row g-4">
        <!-- Sidebar Navigation -->
        <aside class="col-lg-3">
            <div class="fh-card p-4 mb-4">
                <div class="fh-profile-card">
                    <div class="profile-section">
                        <div class="profile-img">
                            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuArVyFD1kByWmCBF0Rz4ccl-L4vIMovS-krTT4u-KVYHhX2hMPUkaQzOLuSXFNkjKwDG0hbQZ7gaRgh8ytv6BK6xFB6ClZmg6H-wq586rl1mmMaOrnlkhWvj-w0KNrgyc3qLGo11qHIdPwOfdKeuTDw6OltxRnbG17NoLNHNk1YZI1Li_g3-PSh5baMbRafh3KgP2jo5_izMzuKYzAJm9zDtUrAJHJSePSvnmDcctJdXnbujZtx4x7j3Nub2X0XNELdrx0zZBwepMns" alt="Profile">
                        </div>
                        <div class="profile-info">
                            <h3>{{user.name}} 님</h3>
                            <p>{{user.role}} Member</p>
                        </div>
                    </div>
                </div>
                <nav class="fh-sidebar-nav">
                    <a href="/mypage" class="nav-item active">
                        <span class="material-symbols-outlined">home</span>
                        <span>홈</span>
                    </a>
                    <a href="/mypage/info" class="nav-item">
                        <span class="material-symbols-outlined">person</span>
                        <span>회원 정보</span>
                    </a>
                    <a href="/mypage/reservations" class="nav-item">
                        <span class="material-symbols-outlined">calendar_today</span>
                        <span>예약 내역</span>
                    </a>
                    <a href="/mypage/reviews" class="nav-item">
                        <span class="material-symbols-outlined">rate_review</span>
                        <span>내가 적은 리뷰</span>
                    </a>
                </nav>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="col-lg-9">
            <!-- Welcome Section -->
            <section class="mb-5">
                <h1 class="display-6 fw-bold text-dark">마이 페이지</h1>
                <p class="text-secondary fw-medium">포레스트 헤이븐에 오신 것을 환영합니다. {{user.name}} 님의 휴식 일정을 관리해보세요.</p>
            </section>

            <!-- Summary Cards -->
            <section class="row g-3 mb-5">
                <div class="col-md-6">
                    <div class="fh-card p-4 shadow-sm">
                        <span class="text-primary small fw-semibold text-uppercase">진행 중인 예약</span>
                        <div class="d-flex align-items-baseline justify-content-between mt-2">
                            <span class="fs-2 fw-bold">{{response.activeReservationCount}}<span class="fs-6 fw-normal text-secondary ms-1">건</span></span>
                            <div class="bg-primary bg-opacity-10 p-2 rounded-3 text-primary">
                                <span class="material-symbols-outlined">event_available</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="fh-card p-4 shadow-sm">
                        <span class="text-primary small fw-semibold text-uppercase">작성 가능한 리뷰</span>
                        <div class="d-flex align-items-baseline justify-content-between mt-2">
                            <span class="fs-2 fw-bold">0<span class="fs-6 fw-normal text-secondary ms-1">건</span></span>
                            <div class="bg-primary bg-opacity-10 p-2 rounded-3 text-primary">
                                <span class="material-symbols-outlined">edit_note</span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Recent Reservation -->
            <section class="mb-0">
                <div class="d-flex align-items-center justify-content-between mb-3 px-2">
                    <h2 class="h5 fw-bold mb-0">최근 예약 내역</h2>
                    <a class="small fw-bold text-primary text-decoration-none" href="/mypage/reservations">전체 보기</a>
                </div>

                {{#isNoReservations}}
                <div class="fh-card p-5 text-center shadow-sm">
                    <div class="bg-light bg-opacity-50 rounded-circle d-inline-flex p-4 mb-3">
                        <span class="material-symbols-outlined fs-1 text-secondary opacity-50">calendar_today</span>
                    </div>
                    <h3 class="h6 fw-bold text-dark mb-2">최근 예약 내역이 없습니다</h3>
                    <p class="small text-secondary mb-4">포레스트 헤이븐의 아름다운 숲속 사이트를 지금 예약해보세요.</p>
                    <a href="/reservations" class="btn btn-primary px-4 fw-bold shadow-sm">캠핑장 예약하기</a>
                </div>
                {{/isNoReservations}}

                {{^isNoReservations}}
                <div class="d-flex flex-column gap-3">
                    {{#response.recentReservations}}
                    <div class="fh-card p-0 overflow-hidden shadow-sm transition-all">
                        <div class="d-flex flex-column flex-md-row">
                            <div class="reservation-thumb" style="width: 14rem; min-height: 12rem;">
                                <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuA8SrJ9cHTLvTKgKN_4X7Vqx1ber4B8vhMO-lJgtcNr_AWwDJuF-re-pmNPRkIhdMQ5RTImrNm6pRNHv-cl7evmVFUMHnO5iymi_SfynJS5GadTufLyPYs3MKcS0PspZmsP3J5jqCh2VJjA4TfeM_6V0T-HU0MFlhmTsG-AJBXoJ5EPX8Uxt8yZWF4pJgZfRHQYLQFTrL28b1BhC454KNlCZFlWCUqz09jyMuGa0xdCsp_oSvwmd1FL8xng1JJnJ8YTXwDaAbk50RaG" alt="Camping" class="w-100 h-100 object-fit-cover">
                            </div>
                            <div class="flex-grow-1 p-4">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <span class="badge bg-{{statusClass}} bg-opacity-10 text-{{statusClass}} fw-bold px-3 py-1">{{statusText}}</span>
                                    <span class="small text-secondary">예약번호: {{reservationIdDisplay}}</span>
                                </div>
                                <h3 class="h5 fw-bold mb-3">{{siteName}}</h3>
                                <div class="row g-3 mb-4">
                                    <div class="col-sm-7">
                                        <div class="d-flex align-items-center gap-2 text-secondary small">
                                            <span class="material-symbols-outlined fs-6 text-primary">calendar_month</span>
                                            <span>{{checkIn}} ~ {{checkOut}} ({{nights}}박)</span>
                                        </div>
                                    </div>
                                    <div class="col-sm-5 text-sm-end">
                                        <div class="text-dark">
                                            <span class="small text-secondary me-1">결제 금액:</span>
                                            <span class="fw-bold fs-5 text-primary">₩ <span class="total-price">{{totalPrice}}</span></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="d-flex gap-2 mt-1">
                                    <a href="/mypage/reservations/{{id}}/detail" class="btn btn-primary flex-grow-1 text-center py-2 small">예약 상세 보기</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    {{/response.recentReservations}}
                </div>
                {{/isNoReservations}}
            </section>
        </main>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const priceElements = document.querySelectorAll('.total-price');
        priceElements.forEach(el => {
            const price = parseInt(el.textContent);
            if (!isNaN(price)) {
                el.textContent = price.toLocaleString();
            }
        });
    });
</script>

{{> layout/footer}}
