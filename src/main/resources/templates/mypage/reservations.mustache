                                                <span class="material-symbols-outlined fs-6">rate_review</span>
                                                리뷰 작성하기
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Item 3: Review Done -->
                        <div class="fh-card p-0 overflow-hidden shadow-sm" style="opacity: 0.9;">
                            <div class="d-flex flex-column flex-sm-row p-4 gap-4">
                                <div class="reservation-thumb flex-shrink-0 rounded-3 overflow-hidden" style="width: 12rem; height: 8rem; filter: grayscale(0.8);">
                                    <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuBpbUxSGTAuYd1_NI_fwD-5hg8ICyxD_zTCVyvuuA2vJq2lrZMLneIP3e53H6Nor9vX97UpZD9hsmoBWJfNCofhP78jAZdJ7ymwivKr63Eg_mt8xkPU_Y8QmqYVMKgb_ksHE1pomovZoJW0kzUf-1QB4Rkpv77ioo9LHU0exdnY6AWQvD5oD75BZuAWPd7HFYpt0VNudqtd89plt4O824811_RJyPQi90152WC1OlJ2E5Oe8lPLfhGh6fxhLfRKKc2WuD4-Ln6uiAOh" alt="Co-working space" class="w-100 h-100 object-fit-cover">
