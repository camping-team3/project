                                        <div class="d-flex gap-2">
                                            <a href="/mypage/reservations/1" class="btn btn-outline-fh btn-sm d-flex align-items-center gap-1">
                                                <span class="material-symbols-outlined fs-6">visibility</span>
                                                상세 보기
                                            </a>
                                            <a href="/mypage/reservations/1/change" class="btn btn-primary btn-sm d-flex align-items-center gap-1">
                                                <span class="material-symbols-outlined fs-6">edit_calendar</span>
                                                예약 변경
                                            </a>
                                            <a href="/mypage/reservations/1/cancel" class="btn btn-outline-secondary btn-sm d-flex align-items-center gap-1">
                                                <span class="material-symbols-outlined fs-6">cancel</span>
