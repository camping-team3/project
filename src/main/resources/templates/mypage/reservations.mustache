                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center justify-content-between mb-1">
                                        <span class="small fw-semibold text-uppercase text-secondary">RESERV-20231012C</span>
                                        <span class="small text-secondary">예약일: 2023.09.28</span>
