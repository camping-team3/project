{{> layout/header}}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 text-center">
            <!-- Success Icon -->
            <div class="mb-4">
                <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                    <span class="material-symbols-outlined text-primary display-3">check_circle</span>
                </div>
            </div>

            <!-- Header Text -->
            <h1 class="display-5 fw-bold text-dark mb-3">예약 변경 신청 완료</h1>
            <p class="text-secondary fs-5 mb-5">요청하신 변경 신청이 정상적으로 접수되었습니다.<br>관리자 승인 후 최종 확정됩니다.</p>

            <!-- Request Details Card -->
            <div class="fh-card shadow-sm p-4 mb-5 text-start">
                <h3 class="h5 fw-bold text-primary mb-4 border-bottom pb-3">변경 신청 상세 내역</h3>
                
                <div class="row g-4">
                    <div class="col-sm-6">
                        <div class="small text-secondary mb-1">예약 번호</div>
                        <div class="fw-bold">RESERV-{{changeRequest.reservationId}}</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="small text-secondary mb-1">신청 일자</div>
                        <div class="fw-bold">{{changeRequest.requestDate}}</div>
                    </div>
                    <div class="col-sm-12">
                        <div class="small text-secondary mb-1">신청 사이트</div>
                        <div class="fw-bold text-dark fs-5">{{changeRequest.newSiteName}} <span class="text-secondary fs-6 fw-normal">({{changeRequest.newZoneName}})</span></div>
                    </div>
                    <div class="col-sm-12">
                        <div class="small text-secondary mb-1">변경 일정</div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined fs-6 text-primary">calendar_month</span>
                            <span class="fw-bold">{{changeRequest.newCheckIn}} ~ {{changeRequest.newCheckOut}}</span>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="small text-secondary mb-1">변경 인원</div>
                        <div class="fw-bold">{{changeRequest.newPeopleCount}}인</div>
                    </div>
                </div>
            </div>

            <!-- Info Banner -->
            <div class="bg-light rounded-4 p-4 mb-5 border">
                <div class="d-flex gap-3 text-start">
                    <span class="material-symbols-outlined text-primary">info</span>
                    <div class="small text-secondary">
                        <p class="mb-2"><strong>알려드립니다:</strong></p>
                        <ul class="mb-0 ps-3">
                            <li class="mb-1">예약 변경 승인 결과는 마이페이지 예약 내역에서 확인하실 수 있습니다.</li>
                            <li>승인 과정에서 사이트 요금 차이가 발생할 경우 별도의 안내 전화를 드릴 예정입니다.</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                <a href="/mypage/reservations" class="btn btn-primary px-5 py-3 fw-bold shadow-sm">마이페이지로 이동</a>
                <a href="/" class="btn btn-outline-secondary px-5 py-3 fw-bold shadow-sm">홈으로 가기</a>
            </div>
        </div>
    </div>
</div>

<style>
    .fh-card {
        border: 1px solid rgba(0,0,0,0.05);
        border-radius: 20px;
    }
</style>

{{> layout/footer}}
