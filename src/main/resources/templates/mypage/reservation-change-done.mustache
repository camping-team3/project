{{> layout/header}}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 text-center">
            <!-- Success Icon -->
            <div class="mb-4">
                <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                    <span class="material-symbols-outlined text-primary display-3">check_circle</span>
                </div>
            </div>

            <!-- Header Text -->
            <h1 class="display-5 fw-bold text-dark mb-3">예약 변경 신청 완료</h1>
            <p class="text-secondary fs-5 mb-5">요청하신 변경 신청이 정상적으로 접수되었습니다.</p>

            <!-- Settlement Info Section (정산 정보) -->
            <div class="mb-5">
                {{#changeRequest.isAdditionalPay}}
                <div class="alert alert-warning border-0 rounded-4 p-4 shadow-sm">
                    <div class="d-flex align-items-center gap-3 justify-content-center mb-3">
                        <span class="material-symbols-outlined text-warning fs-1">payments</span>
                        <h4 class="h4 fw-bold m-0 text-dark">차액 결제 필요</h4>
                    </div>
                    <p class="text-secondary mb-4">변경하신 조건의 요금이 더 높습니다.<br><strong>₩{{changeRequest.amount}}</strong>원을 추가 결제하시면 예약 변경이 확정됩니다.</p>
                    <button id="btn-pay-diff" class="btn btn-warning w-100 py-3 fw-bold shadow-sm rounded-3">차액 ₩{{changeRequest.amount}} 결제하기</button>
                </div>
                {{/changeRequest.isAdditionalPay}}

                {{#changeRequest.isPartialRefund}}
                <div class="alert alert-info border-0 rounded-4 p-4 shadow-sm">
                    <div class="d-flex align-items-center gap-3 justify-content-center mb-3">
                        <span class="material-symbols-outlined text-info fs-1">account_balance_wallet</span>
                        <h4 class="h4 fw-bold m-0 text-dark">부분 환불 예정</h4>
                    </div>
                    <p class="text-secondary mb-0">변경하신 조건의 요금이 더 저렴합니다.<br>차액 <strong>₩{{changeRequest.amount}}</strong>원은 관리자 승인 시<br>환불 규정에 따라 부분 환불 처리됩니다.</p>
                </div>
                {{/changeRequest.isPartialRefund}}

                {{#changeRequest.isNone}}
                <div class="alert alert-light border rounded-4 p-4 shadow-sm">
                    <p class="text-secondary m-0">요금 변동이 없는 예약 변경 건입니다.<br>관리자 승인 후 즉시 확정됩니다.</p>
                </div>
                {{/changeRequest.isNone}}
            </div>

            <!-- Request Details Card -->
            <div class="fh-card shadow-sm p-4 mb-5 text-start">
                <h3 class="h5 fw-bold text-primary mb-4 border-bottom pb-3">변경 신청 상세 내역</h3>
                
                <div class="row g-4">
                    <div class="col-sm-6">
                        <div class="small text-secondary mb-1">예약 번호</div>
                        <div class="fw-bold">RESERV-{{changeRequest.reservationId}}</div>
                    </div>
                    <div class="col-sm-6 text-sm-end">
                        <div class="small text-secondary mb-1">최종 결제 금액 (합계)</div>
                        <div class="fw-bold text-primary fs-5">₩{{changeRequest.newTotalPrice}}</div>
                    </div>
                    <div class="col-sm-12">
                        <div class="small text-secondary mb-1">신청 사이트</div>
                        <div class="fw-bold text-dark fs-5">{{changeRequest.newSiteName}} <span class="text-secondary fs-6 fw-normal">({{changeRequest.newZoneName}})</span></div>
                    </div>
                    <div class="col-sm-12">
                        <div class="small text-secondary mb-1">변경 일정</div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined fs-6 text-primary">calendar_month</span>
                            <span class="fw-bold">{{changeRequest.newCheckIn}} ~ {{changeRequest.newCheckOut}}</span>
                        </div>
                    </div>
                    <div class="col-sm-12">
                        <div class="small text-secondary mb-1">변경 인원</div>
                        <div class="fw-bold">{{changeRequest.newPeopleCount}}인</div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                <a href="/mypage/reservations" class="btn btn-primary px-5 py-3 fw-bold shadow-sm">마이페이지 예약 내역</a>
                <a href="/" class="btn btn-outline-secondary px-5 py-3 fw-bold shadow-sm">홈으로 가기</a>
            </div>
        </div>
    </div>
</div>

<!-- PortOne SDK -->
<script src="https://cdn.portone.io/v2/browser-sdk.js"></script>

<script>
    // Mustache 데이터를 JS 변수로 안전하게 추출
    const settlementType = "{{changeRequest.settlementType}}";
    const requestId = "{{changeRequest.requestId}}";
    const storeId = "{{storeId}}";
    const channelKey = "{{channelKey}}";

    console.log(">>> [ChangeDone] Settlement Info:", { settlementType, requestId, storeId, channelKey });

    document.getElementById('btn-pay-diff')?.addEventListener('click', async function() {
        console.log(">>> [Payment] 차액 결제 버튼 클릭됨");
        
        try {
            // 1. 서버로부터 결제에 필요한 데이터 조회
            const response = await fetch(`/api/reservation/change/${requestId}/payment-data`);
            if (!response.ok) throw new Error("결제 데이터 조회에 실패했습니다.");
            
            const result = await response.json();
            console.log(">>> [Payment] Server Data:", result);
            
            if (result.status !== 200) {
                alert(result.msg);
                return;
            }

            const data = result.body;

            // 2. 포트원 결제창 호출
            console.log(">>> [Payment] PortOne 결제 요청 시작...");
            const payment = await PortOne.requestPayment({
                storeId: storeId,
                channelKey: channelKey,
                paymentId: data.merchantUid,
                orderName: `[변경차액] ${data.siteName}`,
                totalAmount: data.amount,
                currency: "CURRENCY_KRW",
                payMethod: "CARD",
                customer: {
                    fullName: data.visitorName,
                    phoneNumber: data.visitorPhone,
                }
            });

            console.log(">>> [Payment] PortOne Response:", payment);

            // 3. 결제 결과 처리
            if (payment.code != null) {
                alert("결제에 실패했습니다: " + payment.message);
                return;
            }

            // 4. 서버에 결제 성공 알림 및 확정 처리
            const successResp = await fetch('/api/reservation/change/payment/success', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    requestId: data.requestId,
                    impUid: payment.txId || payment.paymentId
                })
            });

            const successResult = await successResp.json();
            if (successResult.status === 200) {
                alert("결제가 완료되어 예약 변경이 확정되었습니다!");
                location.href = "/mypage/reservations";
            } else {
                alert("정산 처리 중 오류가 발생했습니다: " + successResult.msg);
            }

        } catch (e) {
            console.error(">>> [Payment] Error:", e);
            alert("결제 진행 중 예기치 못한 오류가 발생했습니다. 브라우저 콘솔 로그를 확인해 주세요.");
        }
    });
</script>

<style>
    .fh-card {
        border: 1px solid rgba(0,0,0,0.05);
        border-radius: 20px;
    }
    .alert-warning { background-color: #fffbeb; color: #854d0e; }
    .alert-info { background-color: #f0f9ff; color: #075985; }
</style>

{{> layout/footer}}
