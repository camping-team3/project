{{> layout/header}}

<div class="container py-5">
    <div class="row g-4">
        <!-- Sidebar Navigation -->
        <aside class="col-lg-3">
            <div class="fh-card p-4 mb-4">
                <div class="fh-profile-card">
                    <div class="profile-section">
                        <div class="profile-img">
                            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuArVyFD1kByWmCBF0Rz4ccl-L4vIMovS-krTT4u-KVYHhX2hMPUkaQzOLuSXFNkjKwDG0hbQZ7gaRgh8ytv6BK6xFB6ClZmg6H-wq586rl1mmMaOrnlkhWvj-w0KNrgyc3qLGo11qHIdPwOfdKeuTDw6OltxRnbG17NoLNHNk1YZI1Li_g3-PSh5baMbRafh3KgP2jo5_izMzuKYzAJm9zDtUrAJHJSePSvnmDcctJdXnbujZtx4x7j3Nub2X0XNELdrx0zZBwepMns" alt="Profile">
                        </div>
                        <div class="profile-info">
                            <h3>{{userName}} 님</h3> <!-- 동적 이름 바인딩 -->
                            <p>Forest Member</p>
                        </div>
                    </div>
                </div>
                <nav class="fh-sidebar-nav">
                    <a href="/mypage" class="nav-item">
                        <span class="material-symbols-outlined">home</span>
                        <span>홈</span>
                    </a>
                    <a href="#" class="nav-item">
                        <span class="material-symbols-outlined">person</span>
                        <span>회원 정보</span>
                    </a>
                    <a href="/mypage/reservations" class="nav-item active">
                        <span class="material-symbols-outlined">calendar_today</span>
                        <span>예약 내역</span>
                    </a>
                    <a href="/mypage/reviews" class="nav-item">
                        <span class="material-symbols-outlined">rate_review</span>
                        <span>내가 적은 리뷰</span>
                    </a>
                </nav>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="col-lg-9">
            <section class="mb-5">
                <h1 class="display-6 fw-bold text-dark">예약 변경 신청</h1>
                <p class="text-secondary fw-medium italic">기존 예약을 안전하게 변경해 드립니다.</p>
            </section>

            <!-- Existing Reservation Info -->
            <section class="mb-5">
                <div class="fh-card p-0 overflow-hidden shadow-sm">
                    <div class="bg-primary bg-opacity-10 px-4 py-3 border-bottom border-primary border-opacity-10">
                        <h3 class="h6 fw-bold text-primary m-0">기존 예약 정보</h3>
                    </div>
                    <div class="p-4 d-flex flex-column flex-sm-row gap-4 align-items-center align-items-sm-start">
                        <img src="{{reservation.siteImage}}" alt="Reservation Preview" class="reservation-preview-img shadow-sm">
                        <div class="flex-grow-1">
                            <span class="badge bg-primary bg-opacity-10 text-primary fw-bold px-3 py-2 mb-2">예약 완료</span>
                            <h4 class="h4 fw-bold mb-3">{{reservation.siteName}} ({{reservation.zoneName}})</h4>
                            <div class="d-flex flex-column gap-2 text-secondary small">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="material-symbols-outlined fs-6 text-primary">calendar_today</span>
                                    <span class="fw-medium">{{reservation.checkIn}} ~ {{reservation.checkOut}}</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="material-symbols-outlined fs-6 text-primary">group</span>
                                    <span class="fw-medium">예약 인원: {{reservation.peopleCount}}명</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Change Request Form -->
            <section>
                <form action="/mypage/reservations/{{reservation.id}}/change-request" method="POST" id="changeRequestForm" class="fh-card shadow-sm">
                    <input type="hidden" name="reservationId" value="{{reservation.id}}">
                    <input type="hidden" name="newSiteId" id="newSiteId" value=""> <!-- AJAX로 선택 시 값 주입 -->

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-dark small mb-2">변경 희망 체크인</label>
                            <div class="form-icon-wrapper">
                                <span class="material-symbols-outlined">calendar_month</span>
                                <input type="date" name="newCheckIn" id="newCheckIn" class="form-control py-2.5 shadow-none border-secondary border-opacity-25" value="{{reservation.checkIn}}">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-dark small mb-2">변경 희망 체크아웃</label>
                            <div class="form-icon-wrapper">
                                <span class="material-symbols-outlined">calendar_month</span>
                                <input type="date" name="newCheckOut" id="newCheckOut" class="form-control py-2.5 shadow-none border-secondary border-opacity-25" value="{{reservation.checkOut}}">
                            </div>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-12">
                            <label class="form-label fw-bold text-dark small mb-2">변경 희망 인원</label>
                            <div class="form-icon-wrapper">
                                <span class="material-symbols-outlined">groups</span>
                                <select name="newPeopleCount" id="newPeopleCount" class="form-select py-2.5 shadow-none border-secondary border-opacity-25">
                                    <option value="1">1인</option>
                                    <option value="2" selected>2인</option>
                                    <option value="3">3인</option>
                                    <option value="4">4인</option>
                                    <option value="5">5인</option>
                                    <option value="6">6인</option> <!-- 6인까지 확장 -->
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Available Sites Selection Section -->
                    <div class="mb-5">
                        <label class="form-label fw-bold text-dark small mb-3">변경 가능 사이트 선택</label>
                        <div id="availableSitesContainer" class="row row-cols-1 row-cols-md-2 g-3">
                            <!-- AJAX 결과가 여기에 렌더링됩니다. -->
                            <div class="col-12 text-center py-4 text-muted border rounded-3 bg-light">
                                <p class="m-0">날짜와 인원을 선택하면 변경 가능한 사이트 목록이 나타납니다.</p>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-dark small mb-2">변경 사유</label>
                        <textarea name="reason" class="form-control py-2.5 shadow-none border-secondary border-opacity-25" rows="4" placeholder="예약 날짜를 변경하시려는 사유를 간단히 입력해주세요." required></textarea>
                    </div>

                    <div class="info-banner d-flex gap-3 p-4 mb-5 border-dashed">
                        <span class="material-symbols-outlined text-primary fs-4">info</span>
                        <div class="small leading-relaxed">
                            <p class="fw-bold text-primary mb-1">안내 사항</p>
                            <p class="text-secondary mb-0">예약 변경은 관리자 승인 후 최종 확정됩니다. 요청 후 마이페이지에서 진행 상태를 확인하실 수 있습니다. 변경 조건에 따라 추가 비용이 발생할 수 있습니다.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-6">
                            <button type="submit" class="btn btn-primary w-100 py-3 shadow-sm">변경 요청하기</button>
                        </div>
                        <div class="col-6">
                            <a href="/mypage/reservations" class="btn btn-light bg-secondary bg-opacity-10 text-secondary w-100 py-3 fw-bold border-0 shadow-sm text-center">취소</a>
                        </div>
                    </div>
                </form>
            </section>
        </main>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const checkInInput = document.getElementById('newCheckIn');
    const checkOutInput = document.getElementById('newCheckOut');
    const peopleInput = document.getElementById('newPeopleCount');
    const sitesContainer = document.getElementById('availableSitesContainer');
    const siteIdInput = document.getElementById('newSiteId');

    // 실시간 조회 함수
    async function fetchSites() {
        const checkIn = checkInInput.value;
        const checkOut = checkOutInput.value;
        const peopleCount = peopleInput.value;

        if (!checkIn || !checkOut || !peopleCount) return;

        sitesContainer.innerHTML = '<div class="col-12 text-center py-4"><div class="spinner-border text-primary spinner-border-sm" role="status"></div><span class="ms-2">사이트를 찾는 중...</span></div>';

        try {
            const response = await fetch(`/api/reservations/available-sites?checkIn=${checkIn}&checkOut=${checkOut}&peopleCount=${peopleCount}`);
            const sites = await response.json();

            if (sites.length === 0) {
                sitesContainer.innerHTML = '<div class="col-12 text-center py-4 text-danger border rounded-3 bg-light"><p class="m-0 small">해당 조건에 예약 가능한 사이트가 없습니다.</p></div>';
                return;
            }

            sitesContainer.innerHTML = '';
            sites.forEach(site => {
                const card = document.createElement('div');
                card.className = 'col';
                card.innerHTML = `
                    <div class="fh-card p-3 h-100 border cursor-pointer site-card" data-site-id="${site.id}">
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-2 overflow-hidden bg-light" style="width: 60px; height: 60px;">
                                <img src="/upload/1df7d7fc-2f49-4f29-a27b-71f68cbfb104_wesley-shen-2l2EslhTaOM-unsplash.jpg" class="w-100 h-100 object-fit-cover">
                            </div>
                            <div>
                                <h4 class="h6 fw-bold mb-1">${site.siteName}</h4>
                                <div class="small text-secondary">
                                    <span>${site.zoneName}</span> | <span>최대 ${site.maxPeople}인</span>
                                </div>
                                <div class="small fw-bold text-primary mt-1">₩${site.pricePerNight.toLocaleString()} / 박</div>
                            </div>
                        </div>
                    </div>
                `;
                
                card.querySelector('.site-card').addEventListener('click', function() {
                    document.querySelectorAll('.site-card').forEach(c => c.classList.remove('border-primary', 'bg-primary', 'bg-opacity-10'));
                    this.classList.add('border-primary', 'bg-primary', 'bg-opacity-10');
                    siteIdInput.value = this.dataset.siteId;
                });
                
                sitesContainer.appendChild(card);
            });
        } catch (error) {
            sitesContainer.innerHTML = '<div class="col-12 text-center py-4 text-danger border rounded-3 bg-light"><p class="m-0 small">정보를 불러오는 중 오류가 발생했습니다.</p></div>';
        }
    }

    // 이벤트 리스너 등록
    [checkInInput, checkOutInput, peopleInput].forEach(el => {
        el.addEventListener('change', fetchSites);
    });

    // 폼 전송 시 검증
    document.getElementById('changeRequestForm').addEventListener('submit', function(e) {
        if (!siteIdInput.value) {
            e.preventDefault();
            alert('변경하실 사이트를 선택해주세요.');
        }
    });

    // 초기 로드 시 한 번 실행
    fetchSites();
});
</script>

<style>
.cursor-pointer { cursor: pointer; }
.site-card { transition: all 0.2s ease; }
.site-card:hover { border-color: var(--bs-primary) !important; transform: translateY(-2px); }
.border-dashed { border: 2px dashed #dee2e6; }
</style>

{{> layout/footer}}
