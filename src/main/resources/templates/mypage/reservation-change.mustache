{{> layout/header}}

        <div class="container py-5">
            <div class="row g-4">
                <!-- Sidebar Navigation -->
                <aside class="col-lg-3">
                    <div class="fh-card p-4 mb-4">
                        <div class="fh-profile-card">
                            <div class="profile-section">
                                <div class="profile-img">
                                    <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuArVyFD1kByWmCBF0Rz4ccl-L4vIMovS-krTT4u-KVYHhX2hMPUkaQzOLuSXFNkjKwDG0hbQZ7gaRgh8ytv6BK6xFB6ClZmg6H-wq586rl1mmMaOrnlkhWvj-w0KNrgyc3qLGo11qHIdPwOfdKeuTDw6OltxRnbG17NoLNHNk1YZI1Li_g3-PSh5baMbRafh3KgP2jo5_izMzuKYzAJm9zDtUrAJHJSePSvnmDcctJdXnbujZtx4x7j3Nub2X0XNELdrx0zZBwepMns" alt="Profile">
                                </div>
                                <div class="profile-info">
                                    <h3>김철수 님</h3>
                                    <p>Forest Member</p>
                                </div>
                            </div>
                        </div>
                        <nav class="fh-sidebar-nav">
                            <a href="/mypage" class="nav-item">
                                <span class="material-symbols-outlined">home</span>
                                <span>홈</span>
                            </a>
                            <a href="#" class="nav-item">
                                <span class="material-symbols-outlined">person</span>
                                <span>회원 정보</span>
                            </a>
                            <a href="/mypage/reservations" class="nav-item active">
                                <span class="material-symbols-outlined">calendar_today</span>
                                <span>예약 내역</span>
                            </a>
                            <a href="/mypage/reviews" class="nav-item">
                                <span class="material-symbols-outlined">rate_review</span>
                                <span>내가 적은 리뷰</span>
                            </a>
                        </nav>
                    </div>
                </aside>

                <!-- Main Content Area -->
                <main class="col-lg-9">
                    <section class="mb-5">
                        <h1 class="display-6 fw-bold text-dark">예약 변경 신청</h1>
                        <p class="text-secondary fw-medium italic">기존 예약을 안전하게 변경해 드립니다.</p>
                    </section>

                    <!-- Existing Reservation Info -->
                    <section class="mb-5">
                        <div class="fh-card p-0 overflow-hidden shadow-sm">
                            <div class="bg-primary bg-opacity-10 px-4 py-3 border-bottom border-primary border-opacity-10">
                                <h3 class="h6 fw-bold text-primary m-0">기존 예약 정보</h3>
                            </div>
                            <div class="p-4 d-flex flex-column flex-sm-row gap-4 align-items-center align-items-sm-start">
                                <img src="{{reservation.siteImage}}" alt="Reservation Preview" class="reservation-preview-img shadow-sm">
                                <div class="flex-grow-1">
                                    <span class="badge bg-primary bg-opacity-10 text-primary fw-bold px-3 py-2 mb-2">예약 완료</span>
                                    <h4 class="h4 fw-bold mb-3">{{reservation.siteName}}</h4>
                                    <div class="d-flex flex-column gap-2 text-secondary small">
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="material-symbols-outlined fs-6 text-primary">calendar_today</span>
                                            <span class="fw-medium">{{reservation.checkIn}} ~ {{reservation.checkOut}}</span>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="material-symbols-outlined fs-6 text-primary">group</span>
                                            <span class="fw-medium">예약 인원: {{reservation.peopleCount}}명</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Change Request Form -->
                    <section>
                        <form action="/mypage/reservations/change-request" method="POST" class="fh-card shadow-sm">
                            <input type="hidden" name="reservationId" value="{{reservation.id}}">
                            <!-- 임시로 기존 사이트 ID를 새 사이트 ID로 설정 (추후 사이트 선택 UI 고도화 가능) -->
                            <input type="hidden" name="newSiteId" value="1"> 

                            <div class="row g-4 mb-4">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-dark small mb-2">변경 희망 체크인</label>
                                    <div class="form-icon-wrapper">
                                        <span class="material-symbols-outlined">calendar_month</span>
                                        <input type="date" name="newCheckIn" class="form-control py-2.5 shadow-none border-secondary border-opacity-25" value="{{reservation.checkIn}}">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-dark small mb-2">변경 희망 체크아웃</label>
                                    <div class="form-icon-wrapper">
                                        <span class="material-symbols-outlined">calendar_month</span>
                                        <input type="date" name="newCheckOut" class="form-control py-2.5 shadow-none border-secondary border-opacity-25" value="{{reservation.checkOut}}">
                                    </div>
                                </div>
                            </div>

                            <div class="row g-4 mb-4">
                                <div class="col-md-12">
                                    <label class="form-label fw-bold text-dark small mb-2">변경 희망 인원</label>
                                    <div class="form-icon-wrapper">
                                        <span class="material-symbols-outlined">groups</span>
                                        <select name="newPeopleCount" class="form-select py-2.5 shadow-none border-secondary border-opacity-25">
                                            <option value="1">1인</option>
                                            <option value="2" selected>2인</option>
                                            <option value="3">3인</option>
                                            <option value="4">4인</option>
                                            <option value="5">5인 이상</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold text-dark small mb-2">변경 사유</label>
                                <textarea name="reason" class="form-control py-2.5 shadow-none border-secondary border-opacity-25" rows="4" placeholder="예약 날짜를 변경하시려는 사유를 간단히 입력해주세요."></textarea>
                            </div>

                            <div class="info-banner d-flex gap-3 p-4 mb-5 border-dashed">
                                <span class="material-symbols-outlined text-primary fs-4">info</span>
                                <div class="small leading-relaxed">
                                    <p class="fw-bold text-primary mb-1">안내 사항</p>
                                    <p class="text-secondary mb-0">예약 변경은 관리자 승인 후 최종 확정됩니다. 요청 후 마이페이지에서 진행 상태를 확인하실 수 있습니다. 변경 조건에 따라 추가 비용이 발생할 수 있습니다.</p>
                                </div>
                            </div>

                            <div class="row g-3">
                                <div class="col-6">
                                    <button type="submit" class="btn btn-primary w-100 py-3 shadow-sm">변경 요청하기</button>
                                </div>
                                <div class="col-6">
                                    <button type="button" class="btn btn-light bg-secondary bg-opacity-10 text-secondary w-100 py-3 fw-bold border-0 shadow-sm">취소</button>
                                </div>
                            </div>
                        </form>
                    </section>
                </main>
            </div>
        </div>

{{> layout/footer}}
