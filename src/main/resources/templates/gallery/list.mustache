{{> layout/header}}

<main class="container py-5">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-end mb-5 border-bottom border-secondary border-opacity-10 pb-4">
        <div>
            <h2 class="display-6 fw-black text-primary mb-1">포토 갤러리</h2>
            <p class="text-secondary fw-medium m-0 small">커뮤니티 회원들의 소중한 순간들을 만나보세요.</p>
        </div>
    </div>

    <!-- Gallery Grid -->
    <div class="gallery-grid">
        {{#galleries.content}}
        <div class="gallery-item cursor-pointer" onclick="location.href='/galleries/{{id}}'">
            <div class="gallery-thumb-wrapper shadow-sm mb-3 rounded-4 overflow-hidden position-relative">
                <img src="{{thumbnailPath}}" alt="{{title}}" class="w-100 h-100 object-fit-cover">
                <div class="gallery-overlay position-absolute bottom-0 start-0 w-100 p-2 text-white bg-dark bg-opacity-50 opacity-0 transition-all d-flex align-items-center gap-1 justify-content-center">
                    <span class="material-symbols-outlined fs-6">visibility</span>
                    <span class="text-xs">{{viewCount}}</span>
                </div>
            </div>
            <h3 class="h6 fw-bold text-dark mb-1 hover-primary transition-colors text-truncate">{{title}}</h3>
            <div class="d-flex justify-content-between align-items-center">
                <span class="badge bg-primary bg-opacity-10 text-primary fw-bold text-xxs px-2 py-1 rounded-pill">{{category}}</span>
                <span class="text-secondary text-xxs fw-medium">{{getCreatedAt}}</span>
            </div>
        </div>
        {{/galleries.content}}
        
        {{^galleries.content}}
        <div class="col-12 py-5 text-center">
            <div class="p-5 bg-light rounded-4 border-2 border-dashed border-secondary border-opacity-10">
                <span class="material-symbols-outlined fs-1 text-secondary opacity-25 mb-3">photo_library</span>
                <p class="text-secondary fw-medium m-0">등록된 포토갤러리 게시글이 없습니다.</p>
            </div>
        </div>
        {{/galleries.content}}
    </div>

    <!-- Pagination -->
    {{#galleries.pageNumbers.size}}
    <div class="mt-5 pt-4 d-flex justify-content-center border-top border-light-subtle">
        <nav>
            <ul class="pagination pagination-sm m-0 gap-1">
                <!-- Previous Button -->
                {{#galleries.hasPrevious}}
                <li class="page-item">
                    <a class="page-link border-0 rounded-2 text-dark fw-bold bg-white shadow-sm d-flex align-items-center justify-content-center" href="?page={{galleries.previousPage}}" style="width: 36px; height: 36px;">
                        <span class="material-symbols-outlined fs-6">chevron_left</span>
                    </a>
                </li>
                {{/galleries.hasPrevious}}
                {{^galleries.hasPrevious}}
                <li class="page-item disabled">
                    <a class="page-link border-0 rounded-2 text-secondary bg-white opacity-50 d-flex align-items-center justify-content-center" href="#" style="width: 36px; height: 36px; pointer-events: none;">
                        <span class="material-symbols-outlined fs-6">chevron_left</span>
                    </a>
                </li>
                {{/galleries.hasPrevious}}
                
                <!-- Page Numbers -->
                {{#galleries.pageNumbers}}
                <li class="page-item {{#active}}active{{/active}}">
                    <a class="page-link border-0 rounded-2 {{#active}}bg-primary text-white{{/active}}{{^active}}bg-white text-dark{{/active}} fw-bold shadow-sm d-flex align-items-center justify-content-center" href="?page={{pageIndex}}" style="width: 36px; height: 36px;">{{number}}</a>
                </li>
                {{/galleries.pageNumbers}}
                
                <!-- Next Button -->
                {{#galleries.hasNext}}
                <li class="page-item">
                    <a class="page-link border-0 rounded-2 text-dark fw-bold bg-white shadow-sm d-flex align-items-center justify-content-center" href="?page={{galleries.nextPage}}" style="width: 36px; height: 36px;">
                        <span class="material-symbols-outlined fs-6">chevron_right</span>
                    </a>
                </li>
                {{/galleries.hasNext}}
                {{^galleries.hasNext}}
                <li class="page-item disabled">
                    <a class="page-link border-0 rounded-2 text-secondary bg-white opacity-50 d-flex align-items-center justify-content-center" href="#" style="width: 36px; height: 36px; pointer-events: none;">
                        <span class="material-symbols-outlined fs-6">chevron_right</span>
                    </a>
                </li>
                {{/galleries.hasNext}}
            </ul>
        </nav>
    </div>
    {{/galleries.pageNumbers.size}}
</main>

{{> layout/footer}}
