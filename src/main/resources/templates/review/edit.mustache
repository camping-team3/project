{{> layout/header}}

<div class="container py-5" style="max-width: 800px;">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-primary text-white p-4">
            <h3 class="fw-bold m-0 d-flex align-items-center gap-2">
                <span class="material-symbols-outlined">edit_note</span>
                리뷰 수정하기
            </h3>
            <p class="m-0 mt-1 opacity-75 small">{{review.reservation.site.siteName}} ({{review.reservation.site.zone.name}})</p>
        </div>
        <div class="card-body p-4 p-lg-5">
            <form action="/reviews/{{review.id}}/update" method="post" enctype="multipart/form-data">
                <!-- Rating Selection -->
                <div class="mb-5 text-center bg-light p-4 rounded-4">
                    <label class="form-label fw-bold text-dark d-block mb-3">별점을 선택해주세요</label>
                    <div class="review-star-rating mb-2" id="starContainer" style="cursor: pointer;">
                        <span class="material-symbols-outlined" data-value="1">star</span>
                        <span class="material-symbols-outlined" data-value="2">star</span>
                        <span class="material-symbols-outlined" data-value="3">star</span>
                        <span class="material-symbols-outlined" data-value="4">star</span>
                        <span class="material-symbols-outlined" data-value="5">star</span>
                    </div>
                    <input type="hidden" name="rating" id="ratingInput" value="{{review.rating}}">
                    <p class="text-primary fw-bold m-0" id="ratingText"></p>
                </div>

                <!-- Content Area -->
                <div class="mb-4">
                    <label for="content" class="form-label fw-bold text-dark mb-2">방문 경험을 들려주세요</label>
                    <textarea name="content" id="content" class="form-control rounded-3 p-3 border-0 shadow-sm" rows="8" placeholder="최소 10자 이상 작성해주세요.">{{review.content}}</textarea>
                </div>

                <!-- Image Upload -->
                <div class="mb-5">
                    <label for="images" class="form-label fw-bold text-dark mb-2">사진 수정 (최대 5장)</label>
                    <div class="bg-light p-3 rounded-3 border-start border-primary border-4 mb-3">
                        <p class="small text-muted mb-0">💡 새로운 사진을 업로드하면 기존 사진은 모두 교체됩니다.</p>
                    </div>
                    <input type="file" name="images" id="images" class="form-control rounded-3 border-0 shadow-sm" multiple accept="image/*">
                </div>

                <!-- Submit Buttons -->
                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-primary btn-lg flex-grow-1 py-3.5 fw-bold rounded-3 shadow-sm border-0">수정 완료</button>
                    <button type="button" onclick="history.back();" class="btn btn-light btn-lg px-4 py-3.5 fw-bold rounded-3 text-secondary border-0 shadow-sm">취소</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .review-star-rating { display: flex; gap: 0.5rem; justify-content: center; }
    .review-star-rating .material-symbols-outlined { font-size: 3rem; color: #e2e8f0; transition: all 0.2s; }
    .review-star-rating .material-symbols-outlined.active { color: #fbbf24; font-variation-settings: 'FILL' 1; transform: scale(1.1); }
</style>

<script>
    const stars = document.querySelectorAll('#starContainer span');
    const ratingInput = document.getElementById('ratingInput');
    const ratingText = document.getElementById('ratingText');
    const texts = ["별로예요 (1점)", "그저 그래요 (2점)", "보통이에요 (3점)", "좋아요! (4점)", "최고예요! (5점)"];

    function updateStars(value) {
        stars.forEach(s => {
            if (parseInt(s.getAttribute('data-value')) <= value) {
                s.classList.add('active');
            } else {
                s.classList.remove('active');
            }
        });
        ratingText.textContent = texts[value - 1];
    }

    // 초기 별점 설정
    updateStars(parseInt(ratingInput.value));

    // 클릭 이벤트
    stars.forEach(star => {
        star.addEventListener('click', () => {
            const value = parseInt(star.getAttribute('data-value'));
            ratingInput.value = value;
            updateStars(value);
        });
    });
</script>

{{> layout/footer}}
