{{> layout/header}}

        <main class="container py-5" style="max-width: 800px;">
            <form action="/reviews/save" method="post" enctype="multipart/form-data" id="reviewForm">
                <input type="hidden" name="reservationId" value="{{reservation.id}}">
                <input type="hidden" name="rating" id="ratingInput" value="5">

                <!-- Review Target Info -->
                <section class="mb-5 px-2">
                    <div class="d-flex align-items-center gap-4">
                        <div>
                            <h1 class="h4 fw-bold text-dark mb-1">{{reservation.site.zone.name}} - {{reservation.site.siteName}}</h1>
                            <p class="text-secondary small fw-medium m-0">이용 기간: {{reservation.checkIn}} - {{reservation.checkOut}}</p>
                        </div>
                    </div>
                </section>

                <!-- Star Rating -->
                <section class="fh-card shadow-sm border-0 p-5 mb-4 bg-white rounded-4 text-center">
                    <h3 class="h5 fw-bold text-dark mb-4">캠핑 경험은 어떠셨나요?</h3>
                    <div class="review-star-rating mb-3" id="starContainer" style="cursor: pointer;">
                        <span class="material-symbols-outlined active" data-value="1">star</span>
                        <span class="material-symbols-outlined active" data-value="2">star</span>
                        <span class="material-symbols-outlined active" data-value="3">star</span>
                        <span class="material-symbols-outlined active" data-value="4">star</span>
                        <span class="material-symbols-outlined active" data-value="5">star</span>
                    </div>
                    <p class="text-primary fw-bold" id="ratingText">최고예요! (5점)</p>
                </section>

                <!-- Content Area -->
                <section class="fh-card shadow-sm border-0 p-4 p-md-5 mb-4 bg-white rounded-4">
                    <label class="form-label fw-bold text-dark small mb-3">상세한 후기를 남겨주세요</label>
                    <textarea name="content" id="contentInput" class="form-control bg-light border-0 py-3 px-4 shadow-none rounded-3 mb-4" rows="8" placeholder="최소 10자 이상 1000자 이하로 입력해주세요." required minlength="10" maxlength="1000"></textarea>

                    <label class="form-label fw-bold text-dark small mb-3">사진 첨부 (최대 5장)</label>
                    <input type="file" name="images" id="imageInput" multiple accept="image/jpeg, image/png, image/jpg" class="form-control mb-2">
                    <p class="text-secondary" style="font-size: 11px;">JPG, PNG 파일만 가능</p>
                </section>

                <!-- Submit Button -->
                <div class="mt-5">
                    <button type="submit" class="btn btn-primary w-100 py-3.5 fw-bold shadow-lg border-0 rounded-3">리뷰 등록하기</button>
                </div>
            </form>
        </main>

<script>
    // 별점 로직
    const stars = document.querySelectorAll('#starContainer span');
    const ratingInput = document.getElementById('ratingInput');
    const ratingText = document.getElementById('ratingText');

    const texts = ["별로예요 (1점)", "그저 그래요 (2점)", "보통이에요 (3점)", "좋아요! (4점)", "최고예요! (5점)"];

    function updateStars(value) {
        stars.forEach(s => {
            if (parseInt(s.getAttribute('data-value')) <= value) {
                s.classList.add('active');
            } else {
                s.classList.remove('active');
            }
        });
        ratingText.textContent = texts[value - 1];
    }

    stars.forEach(star => {
        star.addEventListener('click', () => {
            const value = parseInt(star.getAttribute('data-value'));
            ratingInput.value = value;
            updateStars(value);
        });
    });

    // 파일 갯수 제한 및 글자수 제한 폼 서밋
    document.getElementById('reviewForm').addEventListener('submit', function(e) {
        const imageInput = document.getElementById('imageInput');
        const contentInput = document.getElementById('contentInput');

        if (imageInput.files.length > 5) {
            alert('사진은 최대 5장까지만 첨부할 수 있습니다.');
            e.preventDefault();
            return;
        }

        if (contentInput.value.length < 10 || contentInput.value.length > 1000) {
            alert('리뷰는 10자 이상 1000자 이하로 작성해주세요.');
            e.preventDefault();
            return;
        }
    });
</script>
{{> layout/footer}}
