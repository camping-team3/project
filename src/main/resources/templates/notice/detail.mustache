{{> layout/header}}

<main class="container py-5" style="max-width: 896px; margin: 0 auto;">
    <!-- Notice Header -->
    <section class="mb-5">
        <div class="d-flex align-items-center gap-2 mb-3">
            <a href="/notices" class="btn btn-link p-0 text-secondary text-decoration-none d-flex align-items-center gap-1">
                <span class="material-symbols-outlined fs-6">arrow_back</span>
                <span class="small fw-bold">목록으로</span>
            </a>
        </div>
        
        <div class="mb-4">
            <div class="d-flex align-items-center gap-2 mb-2">
                {{#notice.isTop}}
                <span class="badge bg-danger text-white fw-bold px-2 py-1">중요</span>
                {{/notice.isTop}}
                <span class="text-primary small fw-black opacity-75">공지사항</span>
            </div>
            <h1 class="display-6 fw-black text-dark mb-3 tracking-tight">{{notice.title}}</h1>
            <div class="d-flex align-items-center gap-3 text-secondary small fw-medium">
                <span class="d-flex align-items-center gap-1">
                    <span class="material-symbols-outlined fs-6 opacity-50">calendar_today</span>
                    {{notice.createdAt}}
                </span>
                <div class="vr opacity-10"></div>
                <span class="d-flex align-items-center gap-1 text-primary">
                    <span class="material-symbols-outlined fs-6 opacity-50">visibility</span>
                    관리자 게시
                </span>
            </div>
        </div>
        <hr class="opacity-10">
    </section>

    <!-- Notice Content Area -->
    <section class="mb-5 notice-detail-body bg-white p-5 rounded-4 shadow-sm border border-secondary border-opacity-5">
        <div class="notice-main-text leading-relaxed text-dark" style="min-height: 300px;">
            {{{notice.content}}}
        </div>
        
        {{#notice.images.0}}
        <!-- Image Gallery -->
        <div class="mt-5 pt-5 border-top border-secondary border-opacity-10">
            <h5 class="fw-bold text-dark mb-4 d-flex align-items-center gap-2">
                <span class="material-symbols-outlined text-primary">image</span> 첨부 이미지
            </h5>
            <div class="row g-3">
                {{#notice.images}}
                <div class="col-md-4">
                    <div class="rounded-3 overflow-hidden shadow-sm border border-secondary border-opacity-10 cursor-pointer" onclick="window.open('{{filePath}}{{fileName}}', '_blank')">
                        <img src="{{filePath}}{{fileName}}" alt="{{fileName}}" class="w-100 h-100 object-fit-cover hover-scale" style="aspect-ratio: 4/3;">
                    </div>
                </div>
                {{/notice.images}}
            </div>
        </div>
        {{/notice.images.0}}
    </section>

    <!-- Bottom Actions -->
    <section class="d-flex justify-content-center pt-4">
        <a href="/notices" class="btn btn-primary btn-lg px-5 py-3 fw-black shadow-lg border-0 rounded-4">목록으로 돌아가기</a>
    </section>
</main>

<style>
    .notice-detail-body {
        line-height: 1.8;
        font-size: 1.05rem;
    }
    .notice-main-text img {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        margin: 20px 0;
    }
    .hover-scale {
        transition: transform 0.3s ease;
    }
    .hover-scale:hover {
        transform: scale(1.05);
    }
    .cursor-pointer {
        cursor: pointer;
    }
    .leading-relaxed {
        line-height: 1.625;
    }
</style>

{{> layout/footer}}
