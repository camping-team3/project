{{> layout/header}}

<main class="container py-5" style="max-width: 960px; margin: 0 auto;">
    <!-- Hero Banner -->
    <div class="notice-hero shadow-sm mb-5 bg-primary p-5 rounded-4 text-center">
        <h2 class="display-5 fw-black text-white mb-2">공지사항</h2>
        <p class="text-white opacity-75 fw-medium m-0">포레스트 헤이븐의 새로운 소식과 안내를 확인하세요.</p>
    </div>

    <!-- Search -->
    <div class="position-relative mb-5">
        <form action="/notices" method="GET">
            <span class="material-symbols-outlined position-absolute top-50 start-0 translate-middle-y ms-4 text-secondary opacity-50">search</span>
            <input type="text" name="keyword" class="form-control py-3 ps-5 border-0 shadow-sm rounded-4" placeholder="공지사항 검색" value="{{keyword}}">
        </form>
    </div>

    <!-- Notice List -->
    <div class="d-flex flex-column gap-3">
        {{#notices.content}}
        <!-- Notice Item -->
        <div class="fh-card notice-item p-4 border-0 shadow-sm rounded-4 d-flex align-items-start justify-content-between bg-white cursor-pointer" onclick="location.href='/notices/{{id}}'" style="transition: transform 0.2s ease, box-shadow 0.2s ease;">
            <div class="d-flex gap-4">
                <div class="notice-icon-box {{#isTop}}bg-danger bg-opacity-10 text-danger{{/isTop}}{{^isTop}}bg-primary bg-opacity-10 text-primary{{/isTop}} p-3 rounded-3 d-flex align-items-center justify-content-center" style="width: 56px; height: 56px;">
                    <span class="material-symbols-outlined fs-4">{{#isTop}}campaign{{/isTop}}{{^isTop}}info{{/isTop}}</span>
                </div>
                <div>
                    <div class="d-flex align-items-center gap-2 mb-1">
                        {{#isTop}}
                        <span class="badge bg-danger text-white fw-bold px-2 py-1 badge-notice-type">중요</span>
                        {{/isTop}}
                        <h3 class="h6 fw-bold text-dark m-0">{{title}}</h3>
                    </div>
                    <p class="text-secondary small m-0 mb-2 text-truncate notice-desc-truncate">자세한 내용을 확인하시려면 클릭해주세요.</p>
                    <span class="text-secondary opacity-50 fw-bold notice-date-text">{{createdAt}}</span>
                </div>
            </div>
            <span class="material-symbols-outlined text-secondary opacity-25 align-self-center">chevron_right</span>
        </div>
        {{/notices.content}}
        
        {{^notices.content}}
        <div class="text-center py-5 bg-white rounded-4 shadow-sm text-secondary fw-medium">
            검색 결과가 없거나 등록된 공지사항이 없습니다.
        </div>
        {{/notices.content}}
    </div>

    <!-- Pagination -->
    <div class="d-flex justify-content-center gap-2 mt-5">
        {{#notices.hasPrevious}}
        <a href="?page={{notices.previousPage}}&keyword={{keyword}}" class="btn btn-icon border border-secondary border-opacity-10 bg-white d-flex align-items-center justify-content-center shadow-sm rounded-3 p-2">
            <span class="material-symbols-outlined fs-6">chevron_left</span>
        </a>
        {{/notices.hasPrevious}}
        
        <button class="btn btn-primary px-4 py-1.5 small fw-bold shadow-sm rounded-3 border-0">현재 페이지</button>
        
        {{#notices.hasNext}}
        <a href="?page={{notices.nextPage}}&keyword={{keyword}}" class="btn btn-icon border border-secondary border-opacity-10 bg-white d-flex align-items-center justify-content-center shadow-sm rounded-3 p-2">
            <span class="material-symbols-outlined fs-6">chevron_right</span>
        </a>
        {{/notices.hasNext}}
    </div>
</main>

<button class="btn-chatbot shadow-lg border-0 btn-chatbot-large">
    <span class="material-symbols-outlined fs-1">chat</span>
</button>

<style>
    .notice-item:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important;
    }
    .cursor-pointer {
        cursor: pointer;
    }
</style>
{{> layout/footer}}
