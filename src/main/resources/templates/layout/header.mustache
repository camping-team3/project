<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Forest Haven - 숲속의 휴식</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <!-- Common CSS -->
    <link href="/css/common.css" rel="stylesheet"/>
    <!-- Page CSS -->
    <link href="/css/index.css" rel="stylesheet"/>
    <link href="/css/auth/login-form.css" rel="stylesheet"/>
    <link href="/css/auth/join-form.css" rel="stylesheet"/>
    <link href="/css/site/detail.css" rel="stylesheet"/>
    <link href="/css/reservation/new.css" rel="stylesheet"/>
    <link href="/css/reservation/payment.css" rel="stylesheet"/>
    <link href="/css/reservation/complete.css" rel="stylesheet"/>
    <link href="/css/review/new.css" rel="stylesheet"/>
    <link href="/css/notice/list.css" rel="stylesheet"/>
    <link href="/css/gallery/list.css" rel="stylesheet"/>
    <link href="/css/qna/list.css" rel="stylesheet"/>
    <link href="/css/qna/new.css" rel="stylesheet"/>
    <link href="/css/mypage/home.css" rel="stylesheet"/>
    <link href="/css/mypage/reservations.css" rel="stylesheet"/>
    <link href="/css/mypage/reviews.css" rel="stylesheet"/>
    <link href="/css/mypage/reservation-change.css" rel="stylesheet"/>
    <link href="/css/mypage/reservation-change-done.css" rel="stylesheet"/>
    <link href="/css/mypage/reservation-cancel.css" rel="stylesheet"/>
    <link href="/css/mypage/reservation-cancel-done.css" rel="stylesheet"/>
</head>
<body class="bg-light">
    <div class="fh-wrapper">
        <!-- Header -->
        <header class="fh-navbar bg-white bg-opacity-80 backdrop-blur-md sticky-top">
            <div class="navbar-brand">
                <div class="brand-icon shadow-sm">
                    <span class="material-symbols-outlined">forest</span>
                </div>
                <h1 class="brand-name">
                    <a href="/" class="text-decoration-none text-primary">Forest Haven</a>
                </h1>
            </div>
            <nav class="d-none d-lg-flex gap-5">
                <a href="/reviews" class="text-decoration-none text-dark fw-bold small hover-primary">리뷰</a>
                <a href="/galleries" class="text-decoration-none text-dark fw-bold small hover-primary">포토갤러리</a>
                <a href="/qna" class="text-decoration-none text-dark fw-bold small hover-primary">QnA</a>
                <a href="/reservations/new" class="text-decoration-none text-dark fw-bold small hover-primary">예약하기</a>
            </nav>
            <div class="navbar-actions">
                {{#sessionUser}}
                    {{#isAdmin}}
                        <button onclick="location.href='/admin'" class="btn btn-primary px-4 py-2 small fw-bold shadow-sm">관리자페이지</button>
                    {{/isAdmin}}
                    {{^isAdmin}}
                        <button onclick="location.href='/mypage'" class="btn btn-primary px-4 py-2 small fw-bold shadow-sm">마이페이지</button>
                    {{/isAdmin}}
                    <button onclick="location.href='/logout'" class="btn btn-outline px-4 py-2 small fw-bold shadow-sm ms-2">로그아웃</button>
                {{/sessionUser}}
                {{^sessionUser}}
                    <button onclick="location.href='/login-form'" class="btn btn-primary px-4 py-2 small fw-bold shadow-sm">로그인</button>
                {{/sessionUser}}
            </div>
        </header>
