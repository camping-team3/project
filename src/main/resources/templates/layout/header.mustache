<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Forest Haven - 숲속의 휴식</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <!-- Common CSS -->
    {{!-- <link href="/css/common.css" rel="stylesheet"/> --}}
</head>
<body class="bg-light">
    <div class="fh-wrapper">
        <!-- Sticky Header -->
        <header class="sticky-top w-100 border-bottom border-primary border-opacity-10 bg-white bg-opacity-75 backdrop-blur">
            <div class="header-container d-flex align-items-center justify-content-between py-3">
                <div class="d-flex align-items-center gap-2">
                    <div class="brand-icon-wrapper shadow-sm">
                        <span class="material-symbols-outlined fs-4">forest</span>
                    </div>
                    <h1 class="h5 fw-black text-primary m-0">
                        <a href="/" class="text-decoration-none text-primary">Forest Haven</a>
                    </h1>
                </div>

                <nav class="d-none d-lg-flex align-items-center gap-5">
                    <a href="/reviews" class="text-decoration-none text-dark fw-bold small hover-primary">리뷰</a>
                    <a href="/galleries" class="text-decoration-none text-dark fw-bold small hover-primary">포토갤러리</a>
                    <a href="/qna" class="text-decoration-none text-dark fw-bold small hover-primary">QnA</a>
                    <a href="/reservations/new" class="text-decoration-none text-dark fw-bold small hover-primary">예약하기</a>
                </nav>

                <div class="navbar-actions">
                    {{#sessionUser}}
                        {{#isAdmin}}
                            <button onclick="location.href='/admin'" class="btn btn-primary px-4 small fw-bold shadow-lg border-0">관리자페이지</button>
                        {{/isAdmin}}
                        {{^isAdmin}}
                            <button onclick="location.href='/mypage'" class="btn btn-primary px-4 small fw-bold shadow-lg border-0 btn-login">마이페이지</button>
                        {{/isAdmin}}
                    {{/sessionUser}}
                    {{^sessionUser}}
                        <button onclick="location.href='/login-form'" class="btn btn-primary px-4 small fw-bold shadow-lg border-0 btn-login">로그인</button>
                    {{/sessionUser}}
                </div>
            </div>
        </header>
